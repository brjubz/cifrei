<!-- ── SCRIPTS ── -->
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
import { getAuth, signInAnonymously, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
import { getFirestore, doc, setDoc, getDoc, getDocs, deleteDoc, collection, onSnapshot } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

// ── CONFIGURAÇÃO PARA HOSPEDAR NO NETLIFY ──
const MY_FIREBASE_CONFIG = {
  apiKey: "AIzaSyAXNuRqQ_YPJYY3kFOHV9GWVi8V6jtdh1k",
  authDomain: "cifrei-e37f6.firebaseapp.com",
  projectId: "cifrei-e37f6",
  storageBucket: "cifrei-e37f6.firebasestorage.app",
  messagingSenderId: "813647513140",
  appId: "1:813647513140:web:7216af4e7d80a2d03d2c61",
  measurementId: "G-53XMHSHH9L"
};

// ── CONFIGURAÇÃO DO REPERTÓRIO (GitHub) ──
const GIST_ID_SETLIST = '4ddc9a95ef4e523dcafff049a31caeb2';
const GIST_ID_BANCO   = 'ac2d9ca53f29fa99ac1c5f4be584b2b1';

// ── FIREBASE PRESENÇA EM TEMPO REAL ──
let fbDb, fbAuth, fbUser, hbInterval, presenceUnsub;
let _fbInitPromise = null; // Promise que resolve quando Firebase estiver pronto
const appId = typeof __app_id !== 'undefined' ? __app_id : 'cifrei-app';
const avatarColors = ['#34d399', '#60a5fa', '#fbbf24', '#f87171', '#c084fc', '#e879f9'];

// Cache de avatares personalizados {nome_lower: {foto, nome}}
let _avatarsCache = {};
let _avatarsCacheLoaded = false;

async function _carregarAvatarsCache() {
  if (_avatarsCacheLoaded || !fbDb) return;
  try {
    const snap = await getDocs(collection(fbDb, 'avatars_musicos'));
    snap.forEach(d => {
      const data = d.data();
      if (data.nome) _avatarsCache[data.nome.toLowerCase().trim()] = data;
    });
    _avatarsCacheLoaded = true;
  } catch(e) { /* sem permissão ou offline — ignora */ }
}

function _aplicarAvatarCustom(div, nome) {
  const key = (nome||'').toLowerCase().trim();
  const av = _avatarsCache[key];
  if (!av?.foto) return false;
  div.style.backgroundColor = 'transparent';
  div.style.backgroundImage = `url(${av.foto})`;
  div.style.backgroundSize = 'cover';
  div.style.backgroundPosition = 'center';
  div.textContent = '';
  return true;
}

async function initFirebase() {
  if (fbDb) return true; // já inicializado
  let configToUse;
  if (MY_FIREBASE_CONFIG && MY_FIREBASE_CONFIG.apiKey) {
    configToUse = MY_FIREBASE_CONFIG;
  } else if (typeof __firebase_config !== 'undefined') {
    configToUse = JSON.parse(__firebase_config);
  } else {
    console.warn("Aviso: Chaves do Firebase não encontradas!");
    return false;
  }
  try {
    const app = initializeApp(configToUse);
    fbAuth = getAuth(app);
    fbDb = getFirestore(app);
    if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
        await signInWithCustomToken(fbAuth, __initial_auth_token);
    } else {
        await signInAnonymously(fbAuth);
    }
    fbUser = fbAuth.currentUser;
    window._fbDoc = doc;
    window._fbSetDoc = setDoc;
    window._fbGetDoc = getDoc;
    window._fbGetDocs = getDocs;
    window._fbCollection = collection;
    window._fbDeleteDoc = deleteDoc;
    window._fbDb = fbDb; // expõe para uso externo (pad, afinador etc)
    return true;
  } catch(e) {
    console.error('Erro ao conectar Firebase:', e);
    return false;
  }
}

// Timestamp da última atualização que JÁ processamos (evita reload duplicado)
let ultimoUpdateProcessado = 0;

async function startOnlinePresence() {
  const userName = localStorage.getItem('cifrei_username');
  if (!userName || !fbUser || !fbDb) return;
  // Carrega avatares personalizados do Firebase (background, não bloqueia)
  _carregarAvatarsCache();

  // Chave de presença = nome em lowercase — garante que mesmo nome em dispositivos diferentes = 1 avatar
  const presenceKey = userName.toLowerCase().trim().replace(/\s+/g, '_');
  const pRef = doc(fbDb, 'artifacts', appId, 'public', 'data', 'presence', presenceKey);

  // Guarda a chave para usar no salvarNomePerfil e salas
  window._meuPresenceKey = presenceKey;
  window._meuPresenceRef = pRef;

  const ping = async () => {
    try {
      await setDoc(pRef, { name: userName, lastActive: Date.now(), uid: fbUser.uid }, { merge: true });
    } catch(e) {}
  };
  await ping();

  // ── Registra acesso em acessos_app (fonte do dashboard do ADM) ────────────
  // Chave por minuto: captura cada abertura individual do app
  const dataHoje = new Date().toISOString().slice(0, 10);
  const horaAtual = new Date().getHours();
  const minutoAtual = new Date().getMinutes();
  const chaveAcesso = `${dataHoje}_${String(horaAtual).padStart(2,'0')}${String(minutoAtual).padStart(2,'0')}_${presenceKey.slice(-8)}`;
  const tsInicio = Date.now();

  const gravarAcesso = async () => {
    try {
      await setDoc(doc(fbDb, 'acessos_app', chaveAcesso), {
        user: userName,
        data: dataHoje,
        hora: horaAtual,
        minuto: minutoAtual,
        diaSemana: new Date(tsInicio).getDay(),
        tipo: 'acesso',
        tsInicio,
        ts: Date.now(),
        duracaoMin: Math.round((Date.now() - tsInicio) / 60000)
      }, { merge: true });
    } catch(e) {}
  };
  await gravarAcesso();

  if(hbInterval) clearInterval(hbInterval);
  hbInterval = setInterval(async () => { await ping(); await gravarAcesso(); }, 60000);
  if(presenceUnsub) presenceUnsub();
  const collRef = collection(fbDb, 'artifacts', appId, 'public', 'data', 'presence');
  presenceUnsub = onSnapshot(collRef, (snap) => {
    const now = Date.now();
    const online = [];
    snap.forEach(d => {
      const data = d.data();
      if (now - data.lastActive < 10 * 60 * 1000) {
        // id = nome_lower (chave), uid = uid real do Firebase (para salas)
        // Se o documento tem o uid do próprio usuário, usa-o para lógica de salas
        const uid = data.uid || d.id;
        online.push({ id: uid, presenceKey: d.id, ...data });
      }
    });
    renderPresence(online);
  }, (err) => console.error(err));

  escutarSalasAtivas();

  // Escuta mudanças no setlist feitas por outros músicos
  const setlistUserRef = doc(fbDb, 'salas', 'setlist_sync');
  let _ultimoSetlistSync = 0;
  onSnapshot(setlistUserRef, async (snap) => {
    if (!snap.exists()) return;
    const d = snap.data();
    const ts = d.ts || 0;
    if (_ultimoSetlistSync === 0) { _ultimoSetlistSync = ts; return; }
    if (ts <= _ultimoSetlistSync) return;
    if (d.autor === fbUser?.uid) { _ultimoSetlistSync = ts; return; }
    _ultimoSetlistSync = ts;
    const oldTp = {};
    S.songs.forEach(s => oldTp[s.title] = s.tp);
    if (d.setlistContent) {
      S.songs = parseSongs(d.setlistContent);
      S.songs.forEach(s => { if (oldTp[s.title] !== undefined) s.tp = oldTp[s.title]; });
    }
    document.getElementById('nav-cnt').textContent = S.songs.length;
    if (document.getElementById('view-list').classList.contains('active')) renderList();
  }, () => {});

  // ── LISTENER DE ATUALIZAÇÕES DO ADM ──────────────────────────────────────
  // O ADM grava o conteúdo atualizado DIRETAMENTE no Firestore.
  // O app lê do Firestore primeiro (instantâneo) e depois confirma com o Gist.
  const updateRef = doc(fbDb, 'salas', 'adm_update');
  onSnapshot(updateRef, async (snap) => {
    if (!snap.exists()) return;
    const data = snap.data();
    const ts = data.updatedAt || 0;
    if (ultimoUpdateProcessado === 0) { ultimoUpdateProcessado = ts; return; }
    if (ts <= ultimoUpdateProcessado) return;
    ultimoUpdateProcessado = ts;
    const tipo = data.tipo || 'setlist';
    try {
      if (tipo === 'setlist' || tipo === 'ambos') {
        const oldTp = {};
        S.songs.forEach(s => oldTp[s.title] = s.tp);
        let songs = null;
        if (data.setlistContent) {
          songs = parseSongs(data.setlistContent);
        } else {
          const txt = await fetchTxt(GIST_ID_SETLIST);
          songs = parseSongs(txt);
        }
        S.songs = songs;
        S.songs.forEach(s => { if (oldTp[s.title] !== undefined) s.tp = oldTp[s.title]; });
        document.getElementById('nav-cnt').textContent = S.songs.length || '';
        if (document.getElementById('view-list').classList.contains('active')) renderList();
        // Limpa a versão persistida pelos músicos — o ADM publicou um setlist novo/zerado
        if (window._fbDoc && window._fbDeleteDoc) {
          window._fbDeleteDoc(window._fbDoc(fbDb, 'salas', 'setlist_musico')).catch(()=>{});
        }
      }
      if (tipo === 'banco' || tipo === 'ambos') {
        S.bancoCarregado = false;
        if (document.getElementById('view-banco').classList.contains('active')) await carregarBanco();
      }
      showToast('Repertório atualizado ✓');
    } catch(e) { console.warn('Erro no reload automático:', e); }
  }, (err) => console.warn('Listener ADM update:', err));
}

// ── SISTEMA DE SALAS SINCRONIZADAS ───────────────────────────────────────────
let salaUnsub = null;
let minhaSalaRef = null;
let _salaAtualId = null;
let _ignorarProxUpdate = false;

function _getSalaId(uid1, uid2) {
  return [uid1, uid2].sort().join('_');
}

async function abrirSala(songIdx, tp) {
  if (!fbDb || !fbUser) return;
  try {
    S.salaBloqueada = true;
    minhaSalaRef = doc(fbDb, 'salas', fbUser.uid);
    _atualizarFabSala(true); // mostra imediatamente, sem esperar o setDoc
    renderPresence(_presenceUsers || []);
    window.addEventListener('beforeunload', fecharMinhaSala);
    window.addEventListener('pagehide', fecharMinhaSala);
    await setDoc(minhaSalaRef, {
      uid: fbUser.uid,
      nome: localStorage.getItem('cifrei_username') || '?',
      songIdx, tp, ativo: true, bloqueada: true, ts: Date.now()
    });
  } catch(e) {}
}

async function toggleSalaBloqueio() {
  if (!minhaSalaRef) return;
  S.salaBloqueada = !S.salaBloqueada;
  try {
    await setDoc(minhaSalaRef, { bloqueada: S.salaBloqueada }, { merge: true });
  } catch(e) {}
  _atualizarFabSala(true);
  renderPresence(_presenceUsers || []);
  showToast(S.salaBloqueada ? '🔒 Sala bloqueada' : '🔓 Sala aberta para entrada');
}

function _atualizarFabSala(visivel) {
  const ctrl = document.getElementById('fab-sala-controls');
  const ico  = document.getElementById('fab-lock-ico');
  const btn  = document.getElementById('fab-lock-btn');
  if (!ctrl) return;
  ctrl.style.display = visivel ? 'flex' : 'none';
  if (!ico || !btn) return;
  const bloq = S.salaBloqueada !== false;
  const cor = bloq ? '#f87171' : '#34d399';
  ico.setAttribute('stroke', cor);
  btn.style.borderColor = cor;
  btn.style.background = bloq ? 'rgba(248,113,113,.15)' : 'rgba(52,211,153,.15)';
  ico.innerHTML = bloq
    ? '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>'
    : '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/>';
}

// Inicia o listener da sala compartilhada (chamado por ambos: dono e visitante)
function _iniciarListenerSalaShared(salaId) {
  if (salaUnsub) { salaUnsub(); salaUnsub = null; }
  _salaAtualId = salaId;
  const sharedRef = doc(fbDb, 'salas_shared', salaId);
  salaUnsub = onSnapshot(sharedRef, (s) => {
    if (!s.exists()) return;
    const d = s.data();
    if (!d.ativo) return;
    // Notificações de entrada/saída
    if (d.ultimoEvento && d.ultimoEvento !== S._ultimoEventoSala) {
      S._ultimoEventoSala = d.ultimoEvento;
      const meuNome = localStorage.getItem('cifrei_username') || '';
      if (d.eventoTipo === 'entrada' && d.eventoNome && d.eventoNome !== meuNome) {
        showToast(`${d.eventoNome} se juntou a você 🎵`);
      } else if (d.eventoTipo === 'saida' && d.eventoNome && d.eventoNome !== meuNome) {
        showToast(`${d.eventoNome} saiu da sala`);
      }
      // Re-renderiza avatares do reader imediatamente após entrada/saída
      renderPresence(_presenceUsers || []);
    }
    if (!_ignorarProxUpdate) _aplicarUpdateSala(d);
  }, (err) => console.warn('Sala listener:', err));
}

async function atualizarSala(songIdx, tp, conteudo) {
  if (!fbDb || !fbUser || !_salaAtualId) return;
  try {
    _ignorarProxUpdate = true;
    const dados = { songIdx, tp, ts: Date.now(), autor: fbUser.uid };
    if (conteudo !== undefined) dados.conteudo = conteudo;
    await setDoc(doc(fbDb, 'salas_shared', _salaAtualId), dados, { merge: true });
    // Também atualiza salas/{uid} para manter presença visível
    if (minhaSalaRef) await setDoc(minhaSalaRef, { songIdx, tp, ts: Date.now() }, { merge: true });
    setTimeout(() => { _ignorarProxUpdate = false; }, 400);
  } catch(e) { _ignorarProxUpdate = false; }
}

async function fecharMinhaSala() {
  if (salaUnsub) { salaUnsub(); salaUnsub = null; }
  if (minhaSalaRef) {
    try { await setDoc(minhaSalaRef, { ativo: false }, { merge: true }); } catch(e) {}
    minhaSalaRef = null;
  }
  if (_salaAtualId) {
    try { await setDoc(doc(fbDb, 'salas_shared', _salaAtualId), { ativo: false }, { merge: true }); } catch(e) {}
    _salaAtualId = null;
  }
  window.removeEventListener('beforeunload', fecharMinhaSala);
  window.removeEventListener('pagehide', fecharMinhaSala);
}

function _aplicarUpdateSala(d) {
  if (!d || d.autor === fbUser?.uid) return;
  const readerAtivo = document.getElementById('view-reader')?.classList.contains('active');
  if (!readerAtivo) return;

  // Mudança de música — sincroniza para TODOS (cifra e vocal)
  if (d.songIdx !== undefined && d.songIdx !== S.idx && d.songIdx < S.songs.length) {
    const dir = d.songIdx > S.idx ? 1 : -1;
    S.idx = d.songIdx; S.tp = d.tp ?? S.tp;
    if (S.idx >= 0) S.songs[S.idx].tp = S.tp;
    document.getElementById('tp-val').textContent = S.tp >= 0 ? '+'+S.tp : S.tp;
    _animarTrocaMúsica(dir);
    renderReader();
    window.scrollTo({top:0, behavior:'smooth'});
    return;
  }

  // Mudança de tom — só aplica para quem está em modo cifra
  if (d.tp !== undefined && d.tp !== S.tp && !_modoVocal) {
    S.tp = d.tp;
    if (S.idx >= 0) S.songs[S.idx].tp = S.tp;
    document.getElementById('tp-val').textContent = S.tp >= 0 ? '+'+S.tp : S.tp;
    renderCifra(getActiveSongContent());
  }

  // Edição de cifra — só aplica para quem está em modo CIFRA
  if (d.conteudo !== undefined && S.idx >= 0 && !isEditing && !_modoVocal) {
    S.songs[S.idx].content = d.conteudo;
    renderCifra(d.conteudo);
  }

  // Edição de letra — só aplica para quem está em modo VOCAL
  if (d.conteudoLetra !== undefined && S.idx >= 0 && !isEditing && _modoVocal) {
    S.songs[S.idx].letra = d.conteudoLetra;
    renderLetra(d.conteudoLetra);
  }
}

async function entrarNaSala(uid, nome) {
  if (!fbDb || !fbUser) return;
  const salaId = _getSalaId(fbUser.uid, uid);
  S.observandoSala = uid;
  S.observandoNome = nome;
  showToast(`Entrando na sala com ${nome}...`);

  // Registra presença própria
  minhaSalaRef = doc(fbDb, 'salas', fbUser.uid);
  await setDoc(minhaSalaRef, {
    uid: fbUser.uid, nome: localStorage.getItem('cifrei_username') || '?',
    songIdx: S.idx, tp: S.tp, ativo: true, ts: Date.now()
  });

  // Cria/atualiza sala compartilhada
  const sharedRef = doc(fbDb, 'salas_shared', salaId);
  await setDoc(sharedRef, {
    ativo: true, participantes: [fbUser.uid, uid], ts: Date.now(),
    ultimoEvento: Date.now(), eventoTipo: 'entrada',
    eventoNome: localStorage.getItem('cifrei_username') || '?'
  }, { merge: true });

  // ── Busca a música atual do dono com múltiplas fontes ────────────────────
  let songIdx = null, tp = 0;

  // Fonte 1: _salasAtivas em memória (atualizado pelo listener em tempo real)
  if (_salasAtivas[uid]?.songIdx !== undefined) {
    songIdx = _salasAtivas[uid].songIdx;
    tp = _salasAtivas[uid].tp || 0;
    console.log('[sala] songIdx de _salasAtivas:', songIdx);
  }

  // Fonte 2: leitura direta do Firestore (mais recente, sobrescreve se mais novo)
  try {
    const snap = await getDoc(doc(fbDb, 'salas', uid));
    if (snap.exists()) {
      const d = snap.data();
      console.log('[sala] salas/{uid} dados:', d);
      if (d.ativo && d.songIdx !== undefined) {
        // Usa se não tinha nada ainda, ou se é mais recente
        if (songIdx === null || (d.ts || 0) > (_salasAtivas[uid]?.ts || 0)) {
          songIdx = d.songIdx;
          tp = d.tp || 0;
          console.log('[sala] usando songIdx do Firestore:', songIdx);
        }
      }
    }
  } catch(e) { console.warn('[sala] erro lendo salas/{uid}:', e); }

  // Fonte 3: salas_shared (posição mais recente propagada)
  try {
    const sharedSnap = await getDoc(sharedRef);
    if (sharedSnap.exists()) {
      const d = sharedSnap.data();
      if (d.songIdx !== undefined && d.autor !== fbUser.uid) {
        songIdx = d.songIdx;
        tp = d.tp || 0;
        console.log('[sala] usando songIdx de salas_shared:', songIdx);
      }
    }
  } catch(e) {}

  console.log('[sala] songIdx final:', songIdx, '| songs.length:', S.songs.length);

  // Aplica a música correta
  if (songIdx !== null && songIdx >= 0 && songIdx < S.songs.length) {
    S.idx = songIdx;
  }
  S.tp = tp;
  if (S.idx >= 0 && S.idx < S.songs.length) {
    S.songs[S.idx].tp = S.tp;
  }
  document.getElementById('tp-val').textContent = S.tp >= 0 ? '+'+S.tp : S.tp;
  renderReader();
  showView('reader');
  _atualizarFabSala(true);

  // Inicia listener bidirecional
  _iniciarListenerSalaShared(salaId);
}

function sairDaSala(mostrarToast = true) {
  const nome  = S.observandoNome;
  const salaId = _salaAtualId;
  if (salaUnsub && S.observandoSala) {
    // Só encerra listener se era visitante; dono mantém o listener
    salaUnsub(); salaUnsub = null;
    _salaAtualId = null;
  }
  S.observandoSala = null; S.observandoNome = null;
  if (salaId && fbDb && fbUser) {
    const nomeUsuario = localStorage.getItem('cifrei_username') || '?';
    setDoc(doc(fbDb, 'salas_shared', salaId), {
      ultimoEvento: Date.now(), eventoTipo: 'saida', eventoNome: nomeUsuario
    }, { merge: true }).catch(() => {});
  }
  _atualizarFabSala(!!minhaSalaRef);
  if (mostrarToast && nome) showToast(`Saiu da sala com ${nome}`);
}

let _salasAtivas = {};
async function escutarSalasAtivas() {
  if (!fbDb) return;
  onSnapshot(collection(fbDb, 'salas'), (snap) => {
    _salasAtivas = {};
    snap.forEach(d => { const data = d.data(); if (data.ativo) _salasAtivas[d.id] = data; });
    renderPresence(_presenceUsers || []);
  });
  // Dono também escuta salas_shared: quando alguém entrar, inicia listener bidirecional
  onSnapshot(collection(fbDb, 'salas_shared'), (snap) => {
    snap.forEach(d => {
      const data = d.data();
      if (!data.ativo) return;
      const partic = data.participantes || [];
      if (!partic.includes(fbUser?.uid)) return;
      // Sou participante desta sala — iniciar listener se ainda não estiver escutando
      if (_salaAtualId === d.id) return; // já estou escutando
      if (minhaSalaRef && !S.observandoSala) {
        // Sou o dono (tenho minhaSalaRef mas não estou observando ninguém)
        _iniciarListenerSalaShared(d.id);
      }
    });
  });
}
let _presenceUsers = [];

function _criarAvatarDiv(u, opções = {}) {
  const { euMesmo, temSala, obsEle, salaBloqueada, naSalaComigo } = opções;
  const div = document.createElement('div');
  div.className = 'presence-avatar';

  // Visual do avatar (foto / Davi / inicial)
  const isDavi = u.name.trim().toLowerCase() === 'davi';
  if (isDavi) {
    div.style.backgroundColor = '#000';
    div.style.border = '2px solid #d4af37';
    div.style.boxShadow = '0 0 8px rgba(212,175,55,.7)';
    div.style.fontSize = '16px';
    div.textContent = '😎';
  } else if (!_aplicarAvatarCustom(div, u.name)) {
    div.style.backgroundColor = avatarColors[u.name.length % avatarColors.length];
    div.textContent = u.name.charAt(0);
  }

  // Estado: pulsação e borda
  if (euMesmo) {
    div.title = `${u.name} — toque para editar seu perfil`;
    div.style.cursor = 'pointer';
    div.addEventListener('click', () => abrirModalPerfil());
    if (temSala) {
      if (salaBloqueada) div.classList.add('em-sala-bloqueada');
      else div.classList.add('em-sala');
    }
  } else if (naSalaComigo) {
    // Está na sala comigo (no reader)
    div.classList.add('em-sala');
    div.title = `${u.name} — na sala com você 🎵`;
  } else if (temSala) {
    if (obsEle) {
      div.classList.add('em-sala');
      div.title = `${u.name} — sincronizado ✓`;
    } else if (salaBloqueada) {
      div.classList.add('em-sala-bloqueada');
      div.title = `${u.name} está tocando — sala bloqueada 🔒`;
    } else {
      div.classList.add('em-sala');
      div.title = `${u.name} está tocando — toque para entrar`;
    }
  } else {
    div.title = u.name;
  }

  return div;
}

function renderPresence(users) {
  _presenceUsers = users;
  const sortedUsers = users.slice().sort((a, b) => {
    if (a.id === fbUser?.uid) return -1;
    if (b.id === fbUser?.uid) return 1;
    return a.lastActive - b.lastActive;
  });

  // ── READER: só eu + quem está na minha sala ────────────────────────────────
  const readerEl = document.getElementById('presence-avatars-reader');
  if (readerEl) {
    readerEl.innerHTML = '';
    sortedUsers.forEach(u => {
      const euMesmo = u.id === fbUser?.uid;
      const temSala = !!_salasAtivas[u.id];
      const salaBloqueada = _salasAtivas[u.id]?.bloqueada !== false;
      let naSalaComigo = false;
      if (!euMesmo && _salaAtualId) {
        const salaId = _getSalaId(fbUser.uid, u.id);
        naSalaComigo = salaId === _salaAtualId && (temSala || S.observandoSala === u.id);
      }
      // No reader: mostra só eu + quem está na minha sala
      if (!euMesmo && !naSalaComigo) return;
      const div = _criarAvatarDiv(u, {
        euMesmo, temSala: euMesmo && !!minhaSalaRef, salaBloqueada: euMesmo && S.salaBloqueada,
        naSalaComigo
      });
      readerEl.appendChild(div);
    });
  }

  // ── SETLIST, BANCO, SONO: todos online com estado de sala ─────────────────
  ['presence-avatars', 'presence-avatars-banco'].forEach(cid => {
    const c = document.getElementById(cid); if (!c) return;
    c.innerHTML = '';
    sortedUsers.forEach(u => {
      const euMesmo = u.id === fbUser?.uid;
      const temSala = euMesmo ? !!minhaSalaRef : !!_salasAtivas[u.id];
      const salaBloqueada = euMesmo ? S.salaBloqueada : (_salasAtivas[u.id]?.bloqueada !== false);
      const obsEle = S.observandoSala === u.id;
      const div = _criarAvatarDiv(u, { euMesmo, temSala, obsEle, salaBloqueada });
      // Clique para entrar na sala (visitante)
      if (!euMesmo && temSala && !obsEle && !salaBloqueada && !S.preview) {
        div.style.cursor = 'pointer';
        div.addEventListener('click', () => entrarNaSala(u.id, u.name));
      } else if (!euMesmo && obsEle) {
        div.style.cursor = 'pointer';
        div.addEventListener('click', () => sairDaSala());
      }
      c.appendChild(div);
    });
  });

  if (typeof _atualizarSonoPresence === 'function') _atualizarSonoPresence(users);
}

document.addEventListener('DOMContentLoaded', () => {
   const savedName = localStorage.getItem('cifrei_username');
   if (!savedName) {
     document.getElementById('name-modal').style.display = 'flex';
   } else {
     const welcomeEl = document.getElementById('splash-welcome');
     welcomeEl.textContent = getSaudacao(savedName);
     welcomeEl.style.display = 'block';
     _fbInitPromise = initFirebase();
   }
});

function getSaudacao(nome) {
  const h = new Date().getHours();
  let periodo;
  if (h >= 5 && h < 12) periodo = 'Bom dia';
  else if (h >= 12 && h < 18) periodo = 'Boa tarde';
  else periodo = 'Boa noite';
  return `${periodo}, ${nome}!`;
}

function saveName() {
   const inp = document.getElementById('user-name-input');
   const val = inp.value.trim();
   if(val.length < 2) return showToast('Digite um nome válido!');
   localStorage.setItem('cifrei_username', val);
   document.getElementById('name-modal').style.display = 'none';
   const welcomeEl = document.getElementById('splash-welcome');
   welcomeEl.textContent = getSaudacao(val);
   welcomeEl.style.display = 'block';
   showToast(`Bem-vindo, ${val}!`);
   _fbInitPromise = initFirebase();
}
document.getElementById('user-name-input').addEventListener('keyup', (e) => {
  if (e.key === 'Enter') saveName();
});

// ── LÓGICA DO APP ──
const S={songs:[],banco:[],bancoFiltrado:[],idx:-1,preview:null,tp:0,speed:3,scrolling:false,fontM:1,spacingM:1,color:'#ff7700',fabOpen:false,raf:null,lt:null,bancoCarregado:false,observandoSala:null,observandoNome:null,salaBloqueada:true};

// ── INDICADOR DE CONEXÃO ──────────────────────────────────────────────────────
function _setConnStatus(status) {
  const el = document.getElementById('conn-indicator');
  const txt = document.getElementById('conn-txt');
  if (!el || !txt) return;
  el.className = `conn-indicator ${status}`;
  if (status === 'online')  { txt.textContent = 'Online'; }
  if (status === 'offline') { txt.textContent = 'Offline'; }
  if (status === 'syncing') { txt.textContent = 'Sincronizando'; }
}
window.addEventListener('online',  () => _setConnStatus('online'));
window.addEventListener('offline', () => _setConnStatus('offline'));
// Estado inicial
if (!navigator.onLine) _setConnStatus('offline');
const SCALE=['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
const F2S={Db:'C#',Eb:'D#',Gb:'F#',Ab:'G#',Bb:'A#'};
const CH_P = "[A-G][b#]?(?:m|min|M|maj|dim|aug|sus|add)?\\d*(?:m|min|M|maj|dim|aug|sus|add|b|#|-|\\+)?\\d*(?:\\([^)]+\\))?(?:\\/[A-G][b#]?)?";
const CRE = new RegExp("^(?:" + CH_P + ")+$", "i");
const COLORS=[{v:'#ff7700'},{v:'#34d399'},{v:'#38bdf8'},{v:'#fbbf24'},{v:'#fb7185'},{v:'#c084fc'},{v:'#ffffff'}];
let isEditing = false;
let wakeLock = null;

// ── CONTROLE DE TEMPO POR TURNO ──
const turnoTimers = { ebd: { start: null, elapsed: 0 }, culto: { start: null, elapsed: 0 } };
let currentTurnoAtivo = null;

function getTurnoInfo() {
  // Regra de divisão por turno:
  // EBD tem normalmente 3 músicas.
  // Se a música 1 OU a música 2 (índices 0 e 1) tiver "/" no título (medley),
  // isso significa que já há 2 músicas em 1 slot, então EBD fica com apenas 2 itens.
  // Caso contrário, as 3 primeiras são EBD e o restante é Culto.
  const temBarraNasPrimeiras = S.songs.slice(0, 2).some(s => s.title.includes('/'));
  const limiteEBD = temBarraNasPrimeiras ? 2 : 3;
  const totalSongs = S.songs.length;
  const ebdSongs = S.songs.slice(0, limiteEBD);
  const cultoSongs = S.songs.slice(limiteEBD);
  return { temBarraNasPrimeiras, limiteEBD, totalSongs, ebdSongs, cultoSongs };
}

function getTurnoDoIdx(idx) {
  if (S.preview) return null;
  const { limiteEBD } = getTurnoInfo();
  return idx < limiteEBD ? 'ebd' : 'culto';
}

function isUltimaDoTurno(idx) {
  if (S.preview) return false;
  const { limiteEBD, totalSongs } = getTurnoInfo();
  // Última da EBD
  if (idx === limiteEBD - 1) return 'ebd';
  // Última do Culto
  if (idx === totalSongs - 1 && totalSongs > limiteEBD) return 'culto';
  return false;
}

function iniciarTurnoTimer(turno) {
  if (currentTurnoAtivo === turno) return;
  // Pausa o anterior se houver
  if (currentTurnoAtivo && turnoTimers[currentTurnoAtivo].start) {
    turnoTimers[currentTurnoAtivo].elapsed += Date.now() - turnoTimers[currentTurnoAtivo].start;
    turnoTimers[currentTurnoAtivo].start = null;
  }
  currentTurnoAtivo = turno;
  if (turnoTimers[turno].start === null) {
    turnoTimers[turno].start = Date.now();
  }
}

function pausarTimers() {
  if (currentTurnoAtivo && turnoTimers[currentTurnoAtivo].start) {
    turnoTimers[currentTurnoAtivo].elapsed += Date.now() - turnoTimers[currentTurnoAtivo].start;
    turnoTimers[currentTurnoAtivo].start = null;
  }
}

function getElapsedTurno(turno) {
  let total = turnoTimers[turno].elapsed;
  if (currentTurnoAtivo === turno && turnoTimers[turno].start) {
    total += Date.now() - turnoTimers[turno].start;
  }
  return total;
}

function formatarTempo(ms) {
  const totalSec = Math.floor(ms / 1000);
  const min = Math.floor(totalSec / 60).toString().padStart(2, '0');
  const sec = (totalSec % 60).toString().padStart(2, '0');
  return `${min}:${sec}`;
}

function finalizarLouvor() {
  const turno = isUltimaDoTurno(S.idx);
  if (!turno) return;
  pausarTimers();
  const elapsed = getElapsedTurno(turno);
  const { ebdSongs, cultoSongs } = getTurnoInfo();
  const isEBD = turno === 'ebd';
  const songs = isEBD ? ebdSongs : cultoSongs;
  const overlay = document.getElementById('resumo-modal-overlay');
  const header = document.getElementById('resumo-modal-header');
  const icon = document.getElementById('resumo-modal-icon');
  const title = document.getElementById('resumo-modal-title');
  const subtitle = document.getElementById('resumo-modal-subtitle');
  const body = document.getElementById('resumo-modal-body');
  const okBtn = document.getElementById('resumo-ok-btn');
  header.className = 'resumo-modal-header ' + turno;
  icon.className = 'resumo-modal-icon ' + turno;
  icon.textContent = isEBD ? '☀️' : '🌙';
  title.textContent = isEBD ? 'EBD Finalizada!' : 'Culto Finalizado!';
  subtitle.textContent = isEBD ? 'Resumo do Louvor da EBD' : 'Resumo do Louvor do Culto';
  okBtn.className = 'resumo-ok-btn ' + turno;
  const tempo = formatarTempo(elapsed);
  body.innerHTML = `
    <div class="resumo-stat">
      <div class="resumo-stat-label">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Duração do Louvor
      </div>
