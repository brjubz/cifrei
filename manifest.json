function filtrarBancoParaSetlist(q) {
  const lista = document.getElementById('add-setlist-lista');
  if (!lista) return;
  const q2 = q.toLowerCase().trim();
  const banco = S.banco || [];
  const noSetlist = new Set(S.songs.map(s => s.title.toLowerCase()));
  const filtradas = banco.filter(s => !noSetlist.has(s.title.toLowerCase()) &&
    (!q2 || s.title.toLowerCase().includes(q2))).slice(0, 50);
  lista.innerHTML = '';
  if (!filtradas.length) {
    lista.innerHTML = `<div style="color:var(--faint);font-size:13px;text-align:center;padding:20px;">${q2 ? 'Nenhuma música encontrada' : 'Todas as músicas já estão no setlist'}</div>`;
    return;
  }
  filtradas.forEach(s => {
    const item = document.createElement('div');
    item.style.cssText = 'display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--bg);border:1px solid var(--bg3);border-radius:10px;cursor:pointer;transition:border-color .15s;';
    item.innerHTML = `
      <div style="flex:1;min-width:0;">
        <div style="font-size:14px;font-weight:700;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(s.title)}${s.verified?VERIFIED_SVG:''}</div>
        <div style="font-size:11px;color:var(--faint);">Tom: ${esc(s.key)}</div>
      </div>
      <div style="background:var(--green);border-radius:7px;padding:5px 11px;color:#000;font-weight:800;font-size:12px;white-space:nowrap;">+ Add</div>`;
    item.addEventListener('mouseenter', () => item.style.borderColor = 'rgba(52,211,153,.4)');
    item.addEventListener('mouseleave', () => item.style.borderColor = 'var(--bg3)');
    item.addEventListener('click', () => {
      adicionarAoSetlist(s.title);
      fecharModalAddSetlist();
      showToast(`"${s.title}" adicionada ao setlist ✓`);
    });
    lista.appendChild(item);
  });
}

// ── MODAL MUDAR TOM NO SETLIST ────────────────────────────────────────────────
let _tomModalIdx = -1;
let _tomModalDelta = 0;
const _SCALE_TOM = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];

// Calcula o tom resultante após transpor N semitons
function _transporTom(tom, semitons) {
  if (!tom || !semitons) return tom;
  const base = tom.replace(/m$|maj.*|min.*|dim.*|aug.*|sus.*|add.*|\d.*/,'').trim();
  const sufixo = tom.slice(base.length);
  const i = _SCALE_TOM.indexOf(base);
  if (i < 0) return tom;
  return _SCALE_TOM[((i + semitons) % 12 + 12) % 12] + sufixo;
}
const _F2S_TOM = {Db:'C#',Eb:'D#',Gb:'F#',Ab:'G#',Bb:'A#'};

function abrirModalTom(idx) {
  _tomModalIdx = idx;
  const s = S.songs[idx];
  if (!s) return;
  _tomModalDelta = s.tp || 0;
  document.getElementById('modal-tom-titulo').textContent = esc(s.title);
  document.getElementById('modal-tom-original').textContent = s.key;
  _atualizarExibicaoTom();
  document.getElementById('modal-tom-setlist').style.display = 'flex';
}

function fecharModalTom() {
  document.getElementById('modal-tom-setlist').style.display = 'none';
  _tomModalIdx = -1;
}

function ajustarTomSetlist(delta) {
  _tomModalDelta = ((_tomModalDelta + delta) % 12 + 12) % 12;
  _atualizarExibicaoTom();
}

function _atualizarExibicaoTom() {
  const s = _tomModalIdx >= 0 ? S.songs[_tomModalIdx] : null;
  if (!s) return;
  // Separa nota base do sufixo (ex: 'Dm' → nota='D', sufixo='m')
  const match = (s.key || 'G').match(/^([A-G][b#]?)(.*)/);
  const notaBase = match ? match[1] : s.key;
  const sufixo   = match ? match[2] : '';
  const nota = _F2S_TOM[notaBase] || notaBase;
  const i = _SCALE_TOM.indexOf(nota);
  const tomResultante = i >= 0
    ? _SCALE_TOM[((i + _tomModalDelta) % 12 + 12) % 12] + sufixo
    : s.key;
  document.getElementById('modal-tom-valor').textContent = tomResultante;
  const st = _tomModalDelta === 0 ? 'Original' : `${_tomModalDelta > 0 ? '+' : ''}${_tomModalDelta} semitons`;
  document.getElementById('modal-tom-semitom').textContent = st;
}

function confirmarTomSetlist() {
  if (_tomModalIdx < 0) return;
  const s = S.songs[_tomModalIdx];
  if (!s) return;
  s.tp = _tomModalDelta;
  fecharModalTom();
  renderList();
  _publicarMudancaSetlist();
  const match2 = (s.key || 'G').match(/^([A-G][b#]?)(.*)/);
  const notaBase2 = match2 ? match2[1] : s.key;
  const sufixo2   = match2 ? match2[2] : '';
  const nota2 = _F2S_TOM[notaBase2] || notaBase2;
  const i = _SCALE_TOM.indexOf(nota2);
  const tomFinal = i >= 0 ? _SCALE_TOM[((i + _tomModalDelta) % 12 + 12) % 12] + sufixo2 : s.key;
  _registrarAtividadeSetlist(`mudou tom de "${s.title}" para ${tomFinal}`);
  // Salva no banco se houve transposição
  if (_tomModalDelta !== 0) {
    const sParaSalvar = { ...s, tp: _tomModalDelta };
    S.tp = _tomModalDelta;
    _salvarTomNoBanco(sParaSalvar);
  }
}

// ── REGISTRO DE ATIVIDADE DO SETLIST NO ADM ───────────────────────────────────
async function _registrarAtividadeSetlist(descricao) {
  const user = localStorage.getItem('cifrei_username') || 'Músico';
  const msg = `<strong>${esc(user)}</strong> ${descricao}`;
  // Grava no Firebase para aparecer no dashboard do ADM
  if (fbDb && window._fbSetDoc && window._fbDoc) {
    try {
      await window._fbSetDoc(window._fbDoc(fbDb, 'acessos_app', `setlist_${Date.now()}_${(user).replace(/\s/g,'_')}`), {
        ts: Date.now(), user, descricao, tipo: 'setlist',
        data: new Date().toISOString().slice(0,10),
        hora: new Date().getHours(), diaSemana: new Date().getDay()
      });
    } catch(e) {}
    // Sinaliza para o dashboard do ADM mostrar em "Atividade Recente"
    try {
      await window._fbSetDoc(window._fbDoc(fbDb, 'salas', 'setlist_atividade'), {
        msg, user, ts: Date.now()
      });
    } catch(e) {}
  }
  showToast(`Setlist atualizado ✓`);
}

function toggleEditMode() {
  const s = S.preview || S.songs[S.idx];
  if(!s) return;
  const btn = document.getElementById('btn-edit'), lbl = document.getElementById('edit-lbl');
  const ci = document.getElementById('cifra'), ta = document.getElementById('edit-area');
  const editWrap = document.getElementById('btn-edit-wrap');
  const editVocalWrap = document.getElementById('btn-edit-vocal-wrap');
  const salvarCifra = document.getElementById('btn-salvar-cancelar-cifra');
  const salvarVocal = document.getElementById('btn-salvar-cancelar-vocal');

  if (isEditing) {
    // SALVAR
    if (_modoVocal) {
      s.letra = ta.value;
      ta.style.display = 'none'; ci.style.display = 'block';
      isEditing = false; renderLetra(s.letra);
      _salvarLetraPermanente(s);
      if (!S.preview) _publicarMudancaSetlist();
      if (_salaAtualId || minhaSalaRef) atualizarSalaComLetra(S.idx, s.letra);
    } else {
      s.content = ta.value;
      s.key = firstChord(s.content) || '-';
      ta.style.display = 'none'; ci.style.display = 'block';
      isEditing = false; renderReader();
      _salvarCifraPermanente(s);
      if (!S.preview) _publicarMudancaSetlist();
      if (_salaAtualId || minhaSalaRef) atualizarSala(S.idx, S.tp, s.content);
    }
    // Volta ao estado normal: mostra Editar, esconde Salvar/Cancelar
    if (editWrap) editWrap.style.display = '';
    if (editVocalWrap) editVocalWrap.style.display = '';
    if (salvarCifra) salvarCifra.style.display = 'none';
    if (salvarVocal) salvarVocal.style.display = 'none';
    const lblVocal = document.getElementById('edit-lbl-vocal');
    if (lblVocal) lblVocal.textContent = 'Editar';
    if (lbl) lbl.textContent = 'Editar';
  } else {
    // ENTRAR EM MODO EDIÇÃO
    _editOriginalContent = _modoVocal ? (s.letra || '') : s.content;

    if (!_modoVocal && S.tp !== 0) {
      const contentTransposto = s.content.split('\n').map(line => {
        if (!isChord(line)) return line;
        return line.replace(/[A-G][b#]?/g, m => transpNote(m, S.tp));
      }).join('\n');
      ci.style.display = 'none';
      ta.value = contentTransposto;
      S.tp = 0;
      document.getElementById('tp-val').textContent = '0';
      if (!S.preview) S.songs[S.idx].tp = 0;
      showToast('Editando no tom transposto ✓');
    } else {
      ci.style.display = 'none';
      ta.value = _modoVocal ? (s.letra || '') : s.content;
    }
    ta.placeholder = _modoVocal ? 'Digite a letra completa aqui...\n\n[Refrão]\nLinha do refrão...' : 'Edite a cifra aqui...';
    ta.style.display = 'block';
    isEditing = true;

    // Esconde Editar, mostra Salvar/Cancelar no modo correto
    if (_modoVocal) {
      if (editVocalWrap) editVocalWrap.style.display = 'none';
      if (salvarVocal) salvarVocal.style.display = 'flex';
    } else {
      if (editWrap) editWrap.style.display = 'none';
      if (salvarCifra) salvarCifra.style.display = 'flex';
    }
  }
}

// Conteúdo original salvo ao entrar em modo edição (para cancelar)
let _editOriginalContent = '';

function cancelarEdicaoCifra() {
  const s = S.preview || S.songs[S.idx];
  if (!s || !isEditing) return;
  const ci = document.getElementById('cifra'), ta = document.getElementById('edit-area');
  s.content = _editOriginalContent;
  ta.style.display = 'none'; ci.style.display = 'block';
  isEditing = false;
  renderReader();
  const editWrap = document.getElementById('btn-edit-wrap');
  const salvarCifra = document.getElementById('btn-salvar-cancelar-cifra');
  if (editWrap) editWrap.style.display = '';
  if (salvarCifra) salvarCifra.style.display = 'none';
  showToast('Edição cancelada');
}

function cancelarEdicaoVocal() {
  const s = S.preview || S.songs[S.idx];
  if (!s || !isEditing) return;
  const ci = document.getElementById('cifra'), ta = document.getElementById('edit-area');
  s.letra = _editOriginalContent;
  ta.style.display = 'none'; ci.style.display = 'block';
  isEditing = false;
  renderLetra(s.letra);
  const editVocalWrap = document.getElementById('btn-edit-vocal-wrap');
  const salvarVocal = document.getElementById('btn-salvar-cancelar-vocal');
  if (editVocalWrap) editVocalWrap.style.display = '';
  if (salvarVocal) salvarVocal.style.display = 'none';
  showToast('Edição cancelada');
}

// Sincroniza mudança de letra com participantes vocais da sala
async function atualizarSalaComLetra(songIdx, letra) {
  if (!fbDb || !fbUser || !_salaAtualId) return;
  try {
    _ignorarProxUpdate = true;
    await setDoc(doc(fbDb, 'salas_shared', _salaAtualId), {
      songIdx, tp: S.tp, conteudoLetra: letra, ts: Date.now(), autor: fbUser.uid
    }, { merge: true });
    setTimeout(() => { _ignorarProxUpdate = false; }, 400);
  } catch(e) { _ignorarProxUpdate = false; }
}

// Serializa o banco completo — usa conteúdo carregado ou extrai do raw original
// Atualiza cirurgicamente uma música no S._bancoRaw sem reprocessar tudo
function _atualizarBancoRaw(titulo, content, letra, key, verified) {
  if (!S._bancoRaw) return;
  const blocks = S._bancoRaw.split('--END--');
  const novosBlocks = blocks.map(b => {
    const c = b.trim(); if (!c) return b;
    const primeiraLinha = c.split('\n').find(l => l.trim());
    if (!primeiraLinha) return b;
    const tituloBloco = primeiraLinha.trim().replace(/\s*\(verificado\)/i, '').trim();
    if (tituloBloco.toLowerCase() !== titulo.toLowerCase()) return b;

    // Extrai metadados existentes para preservar artista/links
    const artistMatch = c.match(/^\[ARTIST:(.*?)\]$/m);
    const ytMatch     = c.match(/^\[LINK_YT:(.*?)\]$/m);
    const spMatch     = c.match(/^\[LINK_SP:(.*?)\]$/m);
    const artist  = artistMatch ? artistMatch[1].trim() : '';
    const linkYT  = ytMatch     ? ytMatch[1].trim()     : '';
    const linkSP  = spMatch     ? spMatch[1].trim()     : '';

    // Reconstrói o bloco preservando todos os campos
    const titleStr   = verified ? `${titulo} (verificado)` : titulo;
    const metaTags   = [
      artist ? `[ARTIST:${artist}]` : '',
      linkYT ? `[LINK_YT:${linkYT}]` : '',
      linkSP ? `[LINK_SP:${linkSP}]` : '',
    ].filter(Boolean).join('\n');
    const metaBlock  = metaTags ? `\n${metaTags}` : '';
    const letraBlock = letra?.trim() ? `\n\n[LETRA]\n${letra.trim()}\n[/LETRA]` : '';
    return `\n\n${titleStr}${metaBlock}\n\n${content}${letraBlock}\n\n`;
  });
  S._bancoRaw = novosBlocks.join('--END--');
}

function _bancotoRaw() {
  // Se temos o raw completo, usa ele como base (mais seguro — contém todos os conteúdos)
  if (S._bancoRaw) return S._bancoRaw;
  // Fallback: reconstrói do S.banco (só funciona se todos tiverem content)
  return S.banco.map(s => {
    const title = s.verified ? `${s.title} (verificado)` : s.title;
    if (!s.content) return null;
    const letraBlock = s.letra?.trim() ? `\n\n[LETRA]\n${s.letra.trim()}\n[/LETRA]` : '';
    return `${title}\n\n${s.content}${letraBlock}`;
  }).filter(Boolean).join('\n\n--END--\n\n') + '\n\n--END--\n';
}

// Grava o banco inteiro no Gist
async function _gravarBancoNoGist() {
  const token = _getGistToken();
  if (!token) { console.error('[banco] Token não disponível'); return false; }
  try {
    const raw = _bancotoRaw();
    if (!raw || raw.trim().length < 10) {
      console.warn('[banco] _bancotoRaw vazio — abortando gravação para não apagar dados');
      return false;
    }
    console.log(`[banco] Gravando ${S.banco.length} músicas no Gist (${Math.round(raw.length/1024)}KB)...`);

    // Descobre nome do arquivo
    const meta = await fetch(`https://api.github.com/gists/${GIST_ID_BANCO}`,
      { headers: { Authorization: `token ${token}` } });
    if (!meta.ok) throw new Error(`GET Gist falhou: HTTP ${meta.status}`);
    const data = await meta.json();
    const filename = Object.keys(data.files || {})[0] || 'banco.txt';

    // Grava
    const patch = await fetch(`https://api.github.com/gists/${GIST_ID_BANCO}`, {
      method: 'PATCH',
      headers: { Authorization: `token ${token}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ files: { [filename]: { content: raw } } })
    });
    if (!patch.ok) {
      const errBody = await patch.text().catch(() => '');
      throw new Error(`PATCH falhou: HTTP ${patch.status} — ${errBody.slice(0,100)}`);
    }
    console.log('[banco] ✅ Banco gravado no Gist com sucesso');
    return true;
  } catch(e) {
    console.error('[banco] ❌ Erro ao gravar banco no Gist:', e.message);
    return false;
  }
}

async function _salvarCifraPermanente(s) {
  // Sempre busca o raw mais recente antes de gravar
  try { S._bancoRaw = await fetchTxt(GIST_ID_BANCO); } catch(e) {}
  if (!S._bancoRaw) { showToast('⚠️ Não foi possível carregar o banco'); return; }

  if (!S.bancoCarregado) {
    S.banco = parseSongs(S._bancoRaw);
    S.bancoCarregado = true;
  }
  const tomBase = firstChord(s.content) || s.key || '-';
  const tomReal = S.tp && S.tp !== 0 ? _transporTom(tomBase, S.tp) : tomBase;

  // 1. Atualiza S.banco em memória
  const orig = S.banco.find(b => b.title.toLowerCase() === s.title.toLowerCase());
  if (orig) {
    orig.content = s.content; orig.key = tomReal;
    orig.letra = orig.letra || s.letra || '';
  } else {
    S.banco.push({ title: s.title, content: s.content, key: tomReal, letra: s.letra || '', verified: s.verified || false });
    S.banco.sort((a,b) => a.title.localeCompare(b.title,'pt'));
    S.bancoFiltrado = S.banco;
  }

  // 2. Sincroniza S.songs
  S.songs.forEach(song => {
    if (song.title.toLowerCase() === s.title.toLowerCase()) {
      song.content = s.content; song.key = tomReal;
    }
  });

  // 3. Atualiza S._bancoRaw cirurgicamente
  const letraAtual = orig?.letra || s.letra || '';
  _atualizarBancoRaw(s.title, s.content, letraAtual, tomReal, s.verified || orig?.verified || false);

  // 4. Grava no Gist
  const ok = await _gravarBancoNoGist();
  showToast(ok ? 'Cifra salva ✓' : '⚠️ Erro ao salvar — tente novamente');
  _registrarAtividadeSetlist && _registrarAtividadeSetlist(`editou a cifra de "${s.title}"`);
}

async function _salvarLetraPermanente(s) {
  // Sempre busca o raw mais recente antes de gravar (evita sobrescrever edições de outros)
  try { S._bancoRaw = await fetchTxt(GIST_ID_BANCO); } catch(e) {}
  if (!S._bancoRaw) { showToast('⚠️ Não foi possível carregar o banco'); return; }

  // Parseia para garantir S.banco atualizado
  if (!S.bancoCarregado) {
    S.banco = parseSongs(S._bancoRaw);
    S.bancoCarregado = true;
  }

  // 1. Atualiza S.banco em memória
  const orig = S.banco.find(b => b.title.toLowerCase() === s.title.toLowerCase());
  if (orig) {
    orig.letra = s.letra;
  } else {
    S.banco.push({ title: s.title, content: s.content || '', key: s.key || '-', letra: s.letra, verified: s.verified || false });
    S.banco.sort((a,b) => a.title.localeCompare(b.title,'pt'));
    S.bancoFiltrado = S.banco;
  }

  // 2. Sincroniza S.songs
  S.songs.forEach(song => {
    if (song.title.toLowerCase() === s.title.toLowerCase()) song.letra = s.letra;
  });

  // 3. Atualiza S._bancoRaw cirurgicamente
  const contentAtual = orig?.content || s.content || '';
  const keyAtual = orig?.key || s.key || '-';
  _atualizarBancoRaw(s.title, contentAtual, s.letra, keyAtual, s.verified || orig?.verified || false);

  // 4. Grava no Gist
  const ok = await _gravarBancoNoGist();
  showToast(ok ? 'Letra salva ✓' : '⚠️ Erro ao salvar — tente novamente');
  _registrarAtividadeSetlist && _registrarAtividadeSetlist(`editou a letra de "${s.title}"`);
}

async function openSong(i){
  S.preview=null; stopScroll(); S.idx=i;
  const songAtual = S.songs[i];

  // O setlist já tem o content editado — só complementa com letra/verified do banco
  // NUNCA sobrescreve content do setlist com o do banco (banco pode estar desatualizado)
  if (songAtual && S.bancoCarregado) {
    const orig = S.banco.find(b => b.title.toLowerCase() === songAtual.title.toLowerCase());
    if (orig) {
      // Só pega letra do banco se o setlist não tem
      if (!songAtual.letra && orig.letra) songAtual.letra = orig.letra;
      // Só pega key do banco se o setlist não tem
      if (!songAtual.key || songAtual.key === '-') songAtual.key = orig.key;
      // Só pega verified do banco se o setlist não tem (setlist tem prioridade)
      if (!songAtual.verified && orig.verified) songAtual.verified = true;
    }
  }

  // Lazy load: se não tem content nem no setlist nem no banco, extrai do raw
  if (!songAtual.content && S._bancoRaw) {
    const dados = _extrairConteudoMusica(S._bancoRaw, songAtual.title);
    if (dados) { songAtual.content = dados.content; if (!songAtual.letra) songAtual.letra = dados.letra; }
  }
  S.tp = songAtual.tp || 0;
  document.getElementById('tp-val').textContent = S.tp >= 0 ? '+'+S.tp : S.tp;
  // Sempre começa em modo Cifra ao abrir uma música
  if (_modoVocal) {
    _modoVocal = false;
    localStorage.setItem('cifrei_modo', 'musico');
  }
  const turno = getTurnoDoIdx(i);
  if(turno) iniciarTurnoTimer(turno);
  renderReader();
  showView('reader');
  if (!S.observandoSala) {
    if (minhaSalaRef) {
      // Sala já existe — atualiza posição diretamente em salas/{uid}
      setDoc(minhaSalaRef, { songIdx: i, tp: S.tp, ativo: true, ts: Date.now() }, { merge: true }).catch(()=>{});
      if (_salaAtualId) atualizarSala(i, S.tp);
    } else {
      // Primeira vez — cria a sala (await para garantir que está gravado antes do visitante entrar)
      await abrirSala(i, S.tp);
    }
    _atualizarFabSala(true);
  } else {
    _atualizarFabSala(false);
  }
}

function leaveReader(){
  if(isEditing) toggleEditMode();
  stopScroll();
  pausarTimers();
  document.getElementById('finalizar-louvor-bar').classList.remove('visible');
  _atualizarFabSala(false);
  // Fecha a sala — a sala só existe enquanto está visualizando uma música
  fecharMinhaSala();
  sairDaSala(false);
  const backTxt = document.getElementById('reader-back-txt')?.textContent;
  if (backTxt === 'Sonoplastia') { showView('sono'); return; }
  if(S.preview) { S.preview = null; showView('banco'); } else { showView('list'); renderList(); }
}

function getActiveSongContent() { return S.preview ? S.preview.content : S.songs[S.idx].content; }

// ── BARRA PROGRESSO NO READER ──
function atualizarProgressoReader(idx) {
  const section = document.getElementById('reader-progress-section');
  const fill = document.getElementById('reader-progress-fill');
  const label = document.getElementById('reader-progress-label');
  if (S.preview || S.songs.length === 0) {
    section.style.display = 'none';
    return;
  }
  section.style.display = 'block';
  const { limiteEBD, totalSongs } = getTurnoInfo();
  const turno = getTurnoDoIdx(idx);
  let pct = 0;
  const SUN_SVG = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="10" height="10"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`;
  const MOON_SVG = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="10" height="10"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`;
  if (turno === 'ebd') {
    // posição dentro da EBD: idx 0..limiteEBD-1 → 0→pct pequeno, limiteEBD-1→100%
    const posNoTurno = idx + 1; // 1-based
    pct = limiteEBD > 1 ? Math.round((posNoTurno / limiteEBD) * 100) : 100;
    fill.className = 'reader-progress-fill ebd';
    label.className = 'reader-progress-turno-label ebd';
    label.innerHTML = SUN_SVG + ' EBD';
  } else {
    const cultoStart = limiteEBD;
    const cultoCount = totalSongs - cultoStart;
    const posNoCulto = idx - cultoStart + 1;
    pct = cultoCount > 1 ? Math.round((posNoCulto / cultoCount) * 100) : 100;
    fill.className = 'reader-progress-fill culto';
    label.className = 'reader-progress-turno-label culto';
    label.innerHTML = MOON_SVG + ' Culto';
  }
  fill.style.width = pct + '%';
}

// ── BARRA FINALIZAR LOUVOR ──
function atualizarFinalizarBar(idx) {
  const bar = document.getElementById('finalizar-louvor-bar');
  const btn = document.getElementById('finalizar-louvor-btn');
  const turnoFinal = isUltimaDoTurno(idx);
  if (S.preview || !turnoFinal) {
    bar.classList.remove('visible');
    return;
  }
  bar.classList.add('visible');
  const isEBD = turnoFinal === 'ebd';
  btn.className = 'finalizar-louvor-btn ' + turnoFinal;
  const iconeEBD = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`;
  const iconeCulto = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`;
  btn.innerHTML = (isEBD ? iconeEBD : iconeCulto) + ` Finalizar Louvor ${isEBD ? 'EBD' : 'Culto'}`;
}

function renderReader(){
  const s = S.preview || S.songs[S.idx];
  if(!s)return;
  if(S.preview) {
    document.getElementById('r-counter').textContent = 'PREVIEW';
    document.getElementById('reader-back-txt').textContent = 'Banco';
    document.getElementById('nav-songs-float').style.display = 'none';
    document.getElementById('reader-progress-section').style.display = 'none';
    document.getElementById('finalizar-louvor-bar').classList.remove('visible');
    const btn = document.getElementById('preview-add-fab');
    btn.style.display = 'flex';
    const jaNoSetlist = S.songs.some(x => x.title === S.preview.title);
    if (jaNoSetlist) {
      btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="20" height="20"><polyline points="20 6 9 17 4 12"/></svg>';
      btn.style.background = 'var(--green)'; btn.style.color = '#000';
    } else {
      btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="20" height="20"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>';
      btn.style.background = 'var(--blue)'; btn.style.color = '#fff';
    }
  } else {
    document.getElementById('r-counter').textContent=(S.idx+1)+' / '+S.songs.length;
    document.getElementById('reader-back-txt').textContent = 'Setlist';
    document.getElementById('nav-songs-float').style.display = 'flex';
    document.getElementById('preview-add-fab').style.display = 'none';
    document.getElementById('btn-prev').disabled=S.idx===0;
    document.getElementById('btn-next').disabled=S.idx===S.songs.length-1;
    atualizarProgressoReader(S.idx);
    atualizarFinalizarBar(S.idx);
  }
  document.getElementById('r-key').textContent=s.key;
  const titleEl = document.getElementById('r-title');
  const isVerified = s.verified || S.banco.find(b => b.title.toLowerCase() === s.title.toLowerCase())?.verified;
  titleEl.innerHTML = esc(s.title) + (isVerified ? ' ' + VERIFIED_SVG : '');
  _atualizarBtnModo();
  if (!isEditing) {
    const sAtual = S.preview || S.songs[S.idx];
    // Lazy load: extrai content do raw se ainda não carregado
    if (sAtual && !sAtual.content && S._bancoRaw) {
      const dados = _extrairConteudoMusica(S._bancoRaw, sAtual.title);
      if (dados) { sAtual.content = dados.content; if (!sAtual.letra) sAtual.letra = dados.letra; }
    }
    if (_modoVocal) renderLetra(sAtual?.letra || sAtual?.content || '');
    else renderCifra(sAtual?.content || '');
  }
}

function renderCifra(content){
  // Proteção contra content undefined/null
  if (!content || content === 'undefined') {
    const c = document.getElementById('cifra');
    if (c) c.innerHTML = '<div style="color:var(--faint);padding:20px;text-align:center;">⏳ Carregando cifra...</div>';
    return;
  }
  const c=document.getElementById('cifra');c.innerHTML='';c.style.fontSize=S.fontM+'em';
  content.split('\n').forEach((line,i)=>{
    const d=document.createElement('div');
    if(isChord(line)){
      d.className='chord-line';d.style.color=S.color;
      d.style.lineHeight=(1.05*S.spacingM)+'';
      if(i>0)d.style.marginTop=(0.15*S.spacingM)+'em';
      line.split(/(\s+)/).forEach(p=>{
        const sp=document.createElement('span');
        if(!p.trim()){sp.textContent=p;}
        else{
          const cl=p.replace(/^[|()[\]\-,.:*%]+|[|()[\]\-,.:*%]+$/g,'');
          if(CRE.test(cl)&&cl){sp.textContent=p.replace(cl,transpChord(cl,S.tp));}
          else{sp.style.color='#52525b';sp.textContent=p;}
        }
        d.appendChild(sp);
      });
    }else{
      d.className='lyric-line';d.style.lineHeight=(1.15*S.spacingM)+'';
      d.style.marginTop='0';
      if(!line.trim())d.style.minHeight=(0.8*S.spacingM)+'em';
      d.textContent=line||'\u00A0';
    }
    c.appendChild(d);
  });
}

function navSong(d){
  if(S.preview) return;
  if(isEditing) toggleEditMode();
  const n=S.idx+d;if(n<0||n>=S.songs.length)return;
  stopScroll();S.idx=n;
  S.tp = S.songs[n].tp || 0;
  document.getElementById('tp-val').textContent = S.tp >= 0 ? '+'+S.tp : S.tp;
  const turno = getTurnoDoIdx(n);
  if(turno) iniciarTurnoTimer(turno);
  _animarTrocaMúsica(d);
  renderReader();
  window.scrollTo({top:0,behavior:'smooth'});
  // Grava posição diretamente em salas/{uid} (fonte que o visitante lê ao entrar)
  if (minhaSalaRef) setDoc(minhaSalaRef, { songIdx: n, tp: S.tp, ts: Date.now() }, { merge: true }).catch(()=>{});
  atualizarSala(n, S.tp);
}

function _animarTrocaMúsica(d) {
  const el = document.getElementById('cifra');
  if (!el) return;
  const entrando = d > 0 ? 'slide-in-right' : 'slide-in-left';
  el.classList.remove('slide-in-right','slide-in-left');
  void el.offsetWidth;
  el.classList.add(entrando);
  setTimeout(() => el.classList.remove('slide-in-right','slide-in-left'), 320);
}
function adjTranspose(d){
  if(isEditing) return showToast('Salve a edição primeiro');
  S.tp+=d; document.getElementById('tp-val').textContent=S.tp>=0?'+'+S.tp:S.tp;
  if(!S.preview && S.idx >= 0) S.songs[S.idx].tp = S.tp;
  renderCifra(getActiveSongContent());
  atualizarSala(S.idx, S.tp);
  _publicarMudancaSetlist();
  // Mostra/esconde botão de salvar tom
  const btnSalvar = document.getElementById('btn-salvar-tom');
  if (btnSalvar && !S.preview) btnSalvar.style.display = S.tp !== 0 ? '' : 'none';
}

function salvarTomAtual() {
  const s = S.songs[S.idx];
  if (!s || S.preview) return;
  if (S.tp === 0) { showToast('Tom já está no original'); return; }
  const btnSalvar = document.getElementById('btn-salvar-tom');
  if (btnSalvar) { btnSalvar.disabled = true; btnSalvar.textContent = '⏳'; }
  _salvarTomNoBanco(s).finally(() => {
    if (btnSalvar) { btnSalvar.disabled = false; btnSalvar.style.display = 'none'; btnSalvar.textContent = 'Salvar Tom'; }
  });
}

async function _salvarTomNoBanco(s) {
  if (S.tp === 0) return; // sem transposição, nada a fazer
  if (!S.bancoCarregado) await _carregarBancoSilencioso();
  try { S._bancoRaw = await fetchTxt(GIST_ID_BANCO); } catch(e) { console.warn('[tom] Erro ao buscar banco:', e.message); }
  if (!S._bancoRaw) { console.warn('[tom] Banco raw vazio'); return; }

  const orig = S.banco.find(b => b.title.toLowerCase() === s.title.toLowerCase());
  if (!orig) { console.warn('[tom] Música não encontrada no banco:', s.title); return; }

  // Transpõe cada linha da cifra
  const contentTransposto = (orig.content || s.content || '')
    .split('\n')
    .map(line => {
      if (!isChord(line)) return line;
      return line.split(/(\s+)/).map(part => {
        const cl = part.replace(/^[|()[\]\-,.:*%]+|[|()[\]\-,.:*%]+$/g, '');
        if (CRE.test(cl) && cl) return part.replace(cl, transpChord(cl, S.tp));
        return part;
      }).join('');
    })
    .join('\n');

  const tomReal = _transporTom(firstChord(orig.content || s.content) || s.key || 'G', S.tp);
  console.log(`[tom] Transpondo "${s.title}" de ${s.key} para ${tomReal} (${S.tp > 0 ? '+' : ''}${S.tp} semitons)`);

  // Atualiza em memória
  orig.content = contentTransposto;
  orig.key     = tomReal;
  s.content    = contentTransposto;
  s.key        = tomReal;
  s.tp         = 0; // reseta tp pois a cifra já está no novo tom

  // Atualiza o raw e grava
  _atualizarBancoRaw(s.title, contentTransposto, orig.letra || s.letra || '', tomReal, orig.verified || s.verified || false);
  const ok = await _gravarBancoNoGist();
  console.log(`[tom] Banco: ${ok ? '✅ salvo em ' + tomReal : '❌ erro ao salvar'}`);

  if (ok) {
    // Atualiza exibição com tp=0 (cifra já transposta)
    S.tp = 0;
    document.getElementById('tp-val').textContent = '+0';
    renderCifra(contentTransposto);
    showToast(`Tom salvo: ${tomReal} ✓`);
    _registrarAtividadeSetlist && _registrarAtividadeSetlist(`alterou tom de "${s.title}" para ${tomReal}`);
    // Invalida cache do banco para outros músicos pegarem na hora
    try { localStorage.removeItem(BANCO_CACHE_KEY); localStorage.removeItem(BANCO_CACHE_TS); } catch(e) {}
  }
}
function adjFont(d){
  S.fontM=Math.max(.5,Math.min(2.5,S.fontM+d));
  if(!isEditing) {
    if (_modoVocal) renderLetra((S.preview||S.songs[S.idx])?.letra || (S.preview||S.songs[S.idx])?.content || '');
    else renderCifra(getActiveSongContent());
  }
}
function adjSpacing(d){
  S.spacingM=Math.max(.5,Math.min(3,S.spacingM+d));
  if(!isEditing) {
    if (_modoVocal) renderLetra((S.preview||S.songs[S.idx])?.letra || (S.preview||S.songs[S.idx])?.content || '');
    else renderCifra(getActiveSongContent());
  }
}
function adjSpeed(d){S.speed=Math.max(1,Math.min(10,S.speed+d));document.getElementById('spd-val').textContent=S.speed;}

function toggleScroll(){S.scrolling?stopScroll():startScroll();}
function startScroll(){
  S.scrolling=true; document.getElementById('scroll-btn').classList.add('active');
  document.getElementById('scroll-ico').innerHTML='<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>';
  S.lt=null;
  function loop(ts){if(!S.scrolling)return;if(S.lt!==null)window.scrollBy({top:S.speed*4*((ts-S.lt)/1000),left:0});S.lt=ts;S.raf=requestAnimationFrame(loop);}
  S.raf=requestAnimationFrame(loop);
}
function stopScroll(){
  S.scrolling=false;if(S.raf){cancelAnimationFrame(S.raf);S.raf=null;}
  const b=document.getElementById('scroll-btn');if(!b)return;
  b.classList.remove('active');
  document.getElementById('scroll-ico').innerHTML='<polygon points="5 3 19 12 5 21 5 3"/>';
}
