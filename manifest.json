function buildSongItem(s, globalIdx) {
  const el=document.createElement('div');el.className='song-item';
  const tomDisplay = (() => {
    const SCALE=['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
    const F2S={Db:'C#',Eb:'D#',Gb:'F#',Ab:'G#',Bb:'A#'};
    const base = F2S[s.key]||s.key;
    const i = SCALE.indexOf(base);
    if (i < 0) return s.key;
    return SCALE[((i+(s.tp||0))%12+12)%12];
  })();
  el.innerHTML=`
    <div class="song-arrows">
      <button class="arr-btn" onclick="moveSong(${globalIdx},-1)" ${globalIdx===0?'disabled':''}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg></button>
      <button class="arr-btn" onclick="moveSong(${globalIdx},1)" ${globalIdx===S.songs.length-1?'disabled':''}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></button>
    </div>
    <div class="song-body" onclick="openSong(${globalIdx})">
      <div style="display:flex;align-items:center;flex:1;min-width:0;">
        <div class="song-num">${globalIdx+1}</div>
        <div class="song-info">
          <div class="song-title">${esc(s.title)}${(s.verified || S.banco.find(b=>b.title.toLowerCase()===s.title.toLowerCase())?.verified) ? VERIFIED_SVG : ''}</div>
          ${s.artist ? `<div style="font-size:11px;color:var(--faint);margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:280px;">${esc(s.artist)}</div>` : ''}
          <div class="song-key" style="display:flex;align-items:center;gap:6px;">
            <span>Tom: ${tomDisplay}${s.tp&&s.tp!==0?` <span style="color:var(--faint);font-size:10px;">(${s.tp>0?'+':''}${s.tp})</span>`:''}</span>
            
          </div>
        </div>
      </div>
      <div class="play-icon"><svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
    </div>
    <button class="del-btn" onclick="removeSong(${globalIdx})" title="Remover do setlist">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
    </button>`;
  return el;
}

function moveSong(i, d){
  const t = i + d;
  if(t < 0 || t >= S.songs.length) return;

  // Captura as posições de TODOS os song-items antes do swap
  const listEl = document.getElementById('song-list');
  const itemsBefore = Array.from(listEl.querySelectorAll('.song-item'));
  const rectsBefore = itemsBefore.map(el => el.getBoundingClientRect());

  // Faz o swap no array
  [S.songs[t], S.songs[i]] = [S.songs[i], S.songs[t]];

  renderList();
  _publicarMudancaSetlist();

  // Pega os novos song-items
  const itemsAfter = Array.from(listEl.querySelectorAll('.song-item'));
  const rectsAfter = itemsAfter.map(el => el.getBoundingClientRect());

  // FLIP: calcula delta e aplica inversão instantânea, depois anima para 0
  // Precisamos mapear old→new. Como apenas 2 itens trocaram, os índices globais batem
  // com a ordem em itemsBefore (ignoramos dividers).
  itemsAfter.forEach((el, newIdx) => {
    if(newIdx >= rectsBefore.length) return;
    // Tenta encontrar a posição antiga pelo índice na lista de song-items
    const oldIdx = newIdx === i ? t : (newIdx === t ? i : newIdx);
    if(oldIdx >= rectsBefore.length) return;
    const dy = rectsBefore[oldIdx].top - rectsAfter[newIdx].top;
    if(dy === 0) return;
    // Aplica a posição "antes" sem transição
    el.style.transition = 'none';
    el.style.transform = `translateY(${dy}px)`;
    // Força reflow
    el.getBoundingClientRect();
    // Anima suavemente de volta para a posição real
    el.style.transition = 'transform 0.48s cubic-bezier(0.22, 1, 0.36, 1)';
    el.style.transform = 'translateY(0)';
    // Limpa depois da animação
    el.addEventListener('transitionend', () => {
      el.style.transition = '';
      el.style.transform = '';
    }, { once: true });
  });
}

function removeSong(i){
  const nome = S.songs[i]?.title || '';
  S.songs.splice(i,1);
  renderList();
  document.getElementById('nav-cnt').textContent=S.songs.length;
  _publicarMudancaSetlist();
  _registrarAtividadeSetlist(`removeu "${nome}" do setlist`);
}


