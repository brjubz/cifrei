          <svg viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.8" width="18" height="18"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        </div>
