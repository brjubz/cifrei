// ── SISTEMA DE NOTIFICAÇÕES DO FIREBASE ────────────────────────────────────────
async function _carregarEExibirNotificacoes() {
  if (!fbDb) return;
  try {
    const snap = await getDocs(collection(fbDb, 'notificacoes_config'));
    const notifs = [];
    snap.forEach(d => notifs.push({ id: d.id, ...d.data() }));
    const ativas = notifs.filter(n => n.ativo !== false);
    ativas.sort((a,b) => (a.criadoEm||0) - (b.criadoEm||0));
    for (const n of ativas) {
      if (await _notifDeveExibir(n)) {
        await _exibirNotificacao(n);
        break; // Mostra uma por vez
      }
    }
  } catch(e) {}
}

async function _notifDeveExibir(n) {
  const user = localStorage.getItem('cifrei_username') || 'anon';
  const storageKey = `notif_visto_${n.id}_${user}`;
  const acessoKey = `cifrei_acesso_count_${user}`;
  // Incrementa contador de acessos
  const acessoAtual = parseInt(localStorage.getItem(acessoKey) || '0') + 1;
  localStorage.setItem(acessoKey, String(acessoAtual));
  const agora = new Date();
  switch (n.regra) {
    case 'primeiro_acesso':
      if (localStorage.getItem(storageKey)) return false;
      return true;
    case 'acesso_n':
      if (localStorage.getItem(storageKey)) return false;
      return acessoAtual === (n.acesso_n || 1);
    case 'sempre':
      return true;
    case 'janela_horario': {
      const [hIni, mIni] = (n.hora_inicio||'00:00').split(':').map(Number);
      const [hFim, mFim] = (n.hora_fim||'23:59').split(':').map(Number);
      const minAtual = agora.getHours() * 60 + agora.getMinutes();
      const minIni = hIni * 60 + mIni;
      const minFim = hFim * 60 + mFim;
      return minAtual >= minIni && minAtual <= minFim;
    }
    case 'data_especifica': {
      const hoje = agora.toISOString().slice(0,10);
      if (n.data_inicio && hoje < n.data_inicio) return false;
      if (n.data_fim && hoje > n.data_fim) return false;
      if (!n.data_fim && n.data_inicio && hoje !== n.data_inicio) return false;
      return true;
    }
    case 'dia_semana':
      return agora.getDay() === (n.dia_semana ?? -1);
    default:
      return false;
  }
}

async function _exibirNotificacao(n) {
  const user = localStorage.getItem('cifrei_username') || 'anon';
  const storageKey = `notif_visto_${n.id}_${user}`;
  if (n.tipo === 'tutorial' && n.slides?.length) {
    // Substitui os slides do onboarding pelos do Firebase
    window._ONB_NOTIF_STEPS = n.slides;
    window._ONB_NOTIF_ID = n.id;
    mostrarOnboardingNotif();
  } else if (n.tipo === 'push') {
    _exibirPushModal(n);
  } else if (n.tipo === 'banner') {
    _exibirBanner(n);
  }
  // Marca como visto (para regras que só mostram uma vez)
  if (n.regra === 'primeiro_acesso' || n.regra === 'acesso_n') {
    localStorage.setItem(storageKey, '1');
  }
}

function mostrarOnboardingNotif() {
  const steps = window._ONB_NOTIF_STEPS || ONB_CIFREI_STEPS;
  let step = 0;
  const el = document.getElementById('onboarding-cifrei');
  if (!el) return;
  function render() {
    const s = steps[step];
    document.getElementById('onb-cifrei-content').innerHTML = `
      <div style="font-size:48px;margin-bottom:14px;">${s.icon||s.icone||'🎵'}</div>
      <div style="font-size:19px;font-weight:800;color:#fff;margin-bottom:10px;font-family:var(--font-chord);letter-spacing:-.3px;">${s.titulo}</div>
      <div style="font-size:13px;color:var(--muted);line-height:1.65;">${s.texto}</div>`;
    document.getElementById('onb-cifrei-next').textContent = step === steps.length-1 ? 'Começar ✓' : 'Próximo →';
    document.getElementById('onb-cifrei-dots').innerHTML = steps.map((_,i) =>
      `<div style="width:7px;height:7px;border-radius:50%;background:${i===step?'var(--green)':'var(--bg3)'};transition:background .2s;"></div>`).join('');
    document.getElementById('onb-cifrei-next').onclick = () => {
      if (step < steps.length-1) { step++; render(); }
      else { el.style.display='none'; }
    };
  }
  el.querySelector('[onclick="fecharOnboardingCifrei()"]')?.setAttribute('onclick', `document.getElementById('onboarding-cifrei').style.display='none'`);
  step = 0; render();
  el.style.display = 'flex';
}

function _exibirPushModal(n) {
  const el = document.getElementById('onboarding-cifrei');
  if (!el) return;
  document.getElementById('onb-cifrei-content').innerHTML = `
    <div style="font-size:52px;margin-bottom:14px;">${n.icone||'🔔'}</div>
    <div style="font-size:19px;font-weight:800;color:#fff;margin-bottom:10px;font-family:var(--font-chord);">${esc(n.titulo)}</div>
    <div style="font-size:13px;color:var(--muted);line-height:1.65;">${esc(n.conteudo||'')}</div>`;
  document.getElementById('onb-cifrei-next').textContent = 'Entendido ✓';
  document.getElementById('onb-cifrei-next').onclick = () => { el.style.display='none'; };
  document.getElementById('onb-cifrei-dots').innerHTML = '';
  el.style.display = 'flex';
}

function _exibirBanner(n) {
  const banner = document.createElement('div');
  banner.style.cssText = 'position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:99998;background:var(--bg2);border:1px solid rgba(52,211,153,.3);border-radius:14px;padding:12px 18px;display:flex;align-items:center;gap:10px;box-shadow:0 8px 32px rgba(0,0,0,.5);max-width:340px;width:90%;animation:fadeInDown .3s;';
  banner.innerHTML = `<span style="font-size:22px;">${n.icone||'🔔'}</span><div style="flex:1;"><div style="font-size:13px;font-weight:700;color:#fff;">${esc(n.titulo)}</div><div style="font-size:11px;color:var(--muted);">${esc(n.conteudo||'')}</div></div><button onclick="this.parentElement.remove()" style="background:none;border:none;color:var(--faint);cursor:pointer;font-size:16px;padding:4px;">✕</button>`;
  document.body.appendChild(banner);
  setTimeout(() => banner.remove(), 8000);
}


function getVotos() {
  try { return JSON.parse(localStorage.getItem('cifrei_votos') || '{}'); } catch(e) { return {}; }
}

// ── MODO VOCAL ────────────────────────────────────────────────────────────────
let _modoVocal = localStorage.getItem('cifrei_modo') === 'vocal'; // padrão: false (músico)

function _atualizarBtnModo() {
  const ico = document.getElementById('modo-toggle-ico');
  const txt = document.getElementById('modo-toggle-txt');
  const btn = document.getElementById('btn-modo-toggle');
  const ctrlCifra = document.getElementById('fab-ctrl-cifra');
  const ctrlVocal = document.getElementById('fab-ctrl-vocal');
  if (!ico) return;
  if (_modoVocal) {
    ico.textContent = '🎸'; txt.textContent = 'Cifra';  // clicando volta para cifra
    btn.style.background = 'rgba(139,92,246,.2)';
    btn.style.borderColor = 'rgba(139,92,246,.4)';
    btn.style.color = '#c4b5fd';
    if (ctrlCifra) ctrlCifra.style.display = 'none';
    if (ctrlVocal) ctrlVocal.style.display = 'flex';
  } else {
    ico.textContent = '🎤'; txt.textContent = 'Vocal';  // clicando vai para vocal
    btn.style.background = 'var(--bg3)';
    btn.style.borderColor = 'var(--bg4)';
    btn.style.color = '#fff';
    if (ctrlCifra) ctrlCifra.style.display = 'flex';
    if (ctrlVocal) ctrlVocal.style.display = 'none';
  }
}

function toggleModoVocal() {
  _modoVocal = !_modoVocal;
  localStorage.setItem('cifrei_modo', _modoVocal ? 'vocal' : 'musico');
  _atualizarBtnModo();
  // Re-renderiza o conteúdo atual
  const s = S.preview || S.songs[S.idx];
  if (s) {
    if (_modoVocal) renderLetra(s.letra || s.content);
    else renderCifra(s.content);
  }
  showToast(_modoVocal ? '🎤 Modo Vocal ativado' : '🎸 Modo Músico ativado');
}

function renderLetra(texto) {
  const c = document.getElementById('cifra');
  c.innerHTML = '';
  c.style.fontSize = S.fontM + 'em';
  if (!texto?.trim()) {
    // Sem letra cadastrada — mostra aviso e fallback para cifra
    const aviso = document.createElement('div');
    aviso.style.cssText = 'color:var(--faint);font-size:12px;text-align:center;padding:20px 0 10px;';
    aviso.textContent = 'Letra não cadastrada — exibindo cifra';
    c.appendChild(aviso);
    renderCifra((S.preview || S.songs[S.idx])?.content || '');
    return;
  }
  // Renderiza letra: sem acordes, formatação limpa
  texto.split('\n').forEach(line => {
    const d = document.createElement('div');
    const trimmed = line.trim();
    if (!trimmed) {
      d.style.minHeight = (0.8 * S.spacingM) + 'em';
    } else if (/^\[.+\]$/.test(trimmed)) {
      // Seção: [Verso 1], [Refrão], etc.
      d.style.cssText = `color:var(--green);font-weight:700;font-size:0.85em;text-transform:uppercase;letter-spacing:1.5px;margin-top:${0.6*S.spacingM}em;margin-bottom:2px;`;
      d.textContent = trimmed.slice(1,-1);
    } else {
      d.className = 'lyric-line';
      d.style.lineHeight = (1.2 * S.spacingM) + '';
      d.textContent = line;
    }
    c.appendChild(d);
  });
}


// ── PERFIL DO MÚSICO ─────────────────────────────────────────────────────────
let _perfilNovaFotoBase64 = null;

async function _sincronizarPerfil(nome, foto) {
  if (!fbDb || !nome) return;
  try {
    const chave = nome.toLowerCase().trim().replace(/\s+/g, '_');
    const ref = doc(fbDb, 'avatars_musicos', chave);
    const payload = { nome, updatedAt: Date.now() };
    if (foto !== undefined) payload.foto = foto;
    await setDoc(ref, payload, { merge: true });
    _avatarsCache[nome.toLowerCase().trim()] = { ..._avatarsCache[nome.toLowerCase().trim()], ...payload };
  } catch(e) {}
}

async function _criarPerfilSeNaoExiste(nome) {
  if (!fbDb || !nome) return;
  try {
    const chave = nome.toLowerCase().trim().replace(/\s+/g, '_');
    const ref = doc(fbDb, 'avatars_musicos', chave);
    const snap = await getDoc(ref);
    if (!snap.exists()) {
      await setDoc(ref, { nome, createdAt: Date.now(), updatedAt: Date.now() });
      _avatarsCache[nome.toLowerCase().trim()] = { nome };
    }
  } catch(e) {}
}

function perfilSelecionarFoto(input) {
  const file = input.files?.[0];
  if (!file) return;
  if (file.size > 2 * 1024 * 1024) { showToast('Foto muito grande. Máximo 2MB.'); return; }
  const reader = new FileReader();
  reader.onload = (e) => {
    _perfilNovaFotoBase64 = e.target.result;
    const wrap = document.getElementById('perfil-avatar-wrap');
    if (wrap) {
      wrap.style.backgroundImage = `url(${_perfilNovaFotoBase64})`;
      wrap.style.backgroundSize = 'cover';
      wrap.style.backgroundPosition = 'center';
      wrap.textContent = '';
    }
    const preview = document.getElementById('perfil-foto-preview');
    if (preview) preview.style.display = 'block';
  };
  reader.readAsDataURL(file);
}

function abrirModalPerfil() {
  _perfilNovaFotoBase64 = null;
  const nomeAtual = localStorage.getItem('cifrei_username') || '';
  const modal = document.getElementById('modal-perfil');
  const nomeEl = document.getElementById('perfil-nome-atual');
  const input = document.getElementById('perfil-novo-nome');
  const avatarWrap = document.getElementById('perfil-avatar-wrap');
  const erroEl = document.getElementById('perfil-erro');
  const preview = document.getElementById('perfil-foto-preview');
  if (nomeEl) nomeEl.textContent = nomeAtual;
  if (input) input.value = nomeAtual;
  if (erroEl) erroEl.style.display = 'none';
  if (preview) preview.style.display = 'none';
  if (avatarWrap) {
    const av = _avatarsCache[(nomeAtual||'').toLowerCase().trim()];
    const isDavi = nomeAtual.trim().toLowerCase() === 'davi';
    if (isDavi) {
      avatarWrap.style.cssText = 'width:80px;height:80px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:#000;border:3px solid #d4af37;font-size:36px;';
      avatarWrap.textContent = '\u{1F60E}';
    } else if (av?.foto) {
      avatarWrap.style.cssText = `width:80px;height:80px;border-radius:50%;border:3px solid var(--green);background-image:url(${av.foto});background-size:cover;background-position:center;`;
      avatarWrap.textContent = '';
    } else {
      const cor = avatarColors[(nomeAtual||'').length % avatarColors.length];
      avatarWrap.style.cssText = `width:80px;height:80px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:${cor};font-size:36px;font-weight:900;color:#000;border:3px solid var(--green);`;
      avatarWrap.textContent = (nomeAtual||'?').charAt(0).toUpperCase();
    }
  }
  if (modal) modal.style.display = 'flex';
  setTimeout(() => input?.focus(), 100);
}

function fecharModalPerfil() {
  const modal = document.getElementById('modal-perfil');
  if (modal) modal.style.display = 'none';
  _perfilNovaFotoBase64 = null;
}

async function salvarNomePerfil() {
  const input = document.getElementById('perfil-novo-nome');
  const erroEl = document.getElementById('perfil-erro');
  const btn = document.getElementById('perfil-salvar-btn');
  const novoNome = (input?.value || '').trim();
  if (!novoNome || novoNome.length < 2) {
    if (erroEl) { erroEl.textContent = novoNome ? 'Nome muito curto' : 'Digite um nome'; erroEl.style.display = 'block'; }
    input?.focus(); return;
  }
  const nomeAntigo = localStorage.getItem('cifrei_username') || '';
  const mudouNome = novoNome !== nomeAntigo;
  const temNovaFoto = !!_perfilNovaFotoBase64;
  if (!mudouNome && !temNovaFoto) { fecharModalPerfil(); return; }
  if (btn) { btn.textContent = '\u23F3'; btn.disabled = true; }
  localStorage.setItem('cifrei_username', novoNome);
  if (fbDb && fbUser) {
    try {
      if (mudouNome) {
        const chaveAntiga = nomeAntigo.toLowerCase().trim().replace(/\s+/g, '_');
        if (chaveAntiga) await deleteDoc(doc(fbDb, 'artifacts', appId, 'public', 'data', 'presence', chaveAntiga));
      }
      const chaveNova = novoNome.toLowerCase().trim().replace(/\s+/g, '_');
      await setDoc(doc(fbDb, 'artifacts', appId, 'public', 'data', 'presence', chaveNova),
        { name: novoNome, lastActive: Date.now(), uid: fbUser.uid }, { merge: true });
    } catch(e) {}
    if (minhaSalaRef) { try { await setDoc(minhaSalaRef, { nome: novoNome }, { merge: true }); } catch(e) {} }
  }
  await _sincronizarPerfil(novoNome, temNovaFoto ? _perfilNovaFotoBase64 : undefined);
  if (mudouNome && nomeAntigo && fbDb) {
    try {
      const chaveAntiga = nomeAntigo.toLowerCase().trim().replace(/\s+/g, '_');
      const av = _avatarsCache[nomeAntigo.toLowerCase().trim()];
      if (!av?.foto) await deleteDoc(doc(fbDb, 'avatars_musicos', chaveAntiga));
    } catch(e) {}
  }
  const welcomeEl = document.getElementById('splash-welcome');
  if (welcomeEl && welcomeEl.style.display !== 'none') {
    const hora = new Date().getHours();
    const saud = hora < 12 ? 'Bom dia' : hora < 18 ? 'Boa tarde' : 'Boa noite';
    welcomeEl.textContent = `${saud}, ${novoNome}! \u{1F44B}`;
  }
  if (typeof startOnlinePresence === 'function') startOnlinePresence();
  showToast(temNovaFoto ? 'Perfil atualizado \u2713' : `Nome alterado para "${novoNome}" \u2713`);
  fecharModalPerfil();
  if (btn) { btn.textContent = 'Salvar'; btn.disabled = false; }
}


function toggleVoto(title) {
  const votos = getVotos();
  if (votos[title]) delete votos[title];
  else votos[title] = Date.now();
  localStorage.setItem('cifrei_votos', JSON.stringify(votos));
  const curtiu = !!votos[title];

  // Atualiza o botão visualmente sem re-renderizar o banco inteiro
  document.querySelectorAll('.vote-btn').forEach(btn => {
    const onc = btn.getAttribute('onclick') || '';
    // Compara o título escapado no onclick
    if (onc.includes('toggleVoto')) {
      // Extrai o título do onclick
      const m = onc.match(/toggleVoto\('(.+?)'\)/);
      if (!m) return;
      const btnTitle = m[1].replace(/\\'/g, "'");
      if (btnTitle !== title) return;
      btn.innerHTML = curtiu ? '❤️' : '🤍';
      btn.classList.toggle('voted', curtiu);
      btn.title = curtiu ? 'Remover curtida' : 'Curtir música';
    }
  });

  // Salva no Firebase para o ADM ver
  if (fbDb && window._fbSetDoc && window._fbDoc) {
    const user = localStorage.getItem('cifrei_username') || 'anon';
    const ref = window._fbDoc(fbDb, 'votos_musicas', encodeURIComponent(title));
    window._fbGetDoc && window._fbGetDoc(ref).then(snap => {
      const cur = snap.exists() ? (snap.data().usuarios || {}) : {};
      if (curtiu) cur[user] = Date.now();
      else delete cur[user];
      window._fbSetDoc(ref, { titulo: title, usuarios: cur, total: Object.keys(cur).length });
    }).catch(() => {});
  }
}

// ── HISTÓRICO DE SETLISTS NO BANCO ───────────────────────────────────────────
async function carregarHistoricoBanco() {
  const section = document.getElementById('historico-section');
  const list    = document.getElementById('historico-list');
  const badge   = document.getElementById('historico-count-badge');
  if (!section || !list) return;
  // Evita recarregar se já carregou
  if (window._historicoCarregado) return;
  if (!fbDb || !window._fbCollection || !window._fbGetDocs) return;
  try {
    window._historicoCarregado = true;
    const { query, orderBy, limit } = await import('https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js');
    const q = query(window._fbCollection(fbDb, 'historico_setlists'), orderBy('timestamp','desc'), limit(8));
    const snap = await window._fbGetDocs(q);
    if (snap.empty) return;
    section.style.display = 'block';
    const items = [];
    snap.forEach(d => items.push(d.data()));
    if (badge) badge.textContent = items.length + ' domingo' + (items.length !== 1 ? 's' : '');
    window._historicoItems = items;
    _renderHistoricoFiltros(items);
    _renderHistoricoCards(items);
  } catch(e) {
    window._historicoCarregado = false; // permite tentar de novo se falhou
    console.warn('Histórico banco:', e.message);
  }
}

function _toggleHistorico() {
  const body    = document.getElementById('historico-body');
  const chevron = document.getElementById('historico-chevron');
  const aberto  = body.style.display !== 'none';
  body.style.display    = aberto ? 'none' : 'block';
  chevron.style.transform = aberto ? 'rotate(0deg)' : 'rotate(180deg)';
}

function _renderHistoricoFiltros(items) {
  const container = document.getElementById('historico-filtros');
  if (!container) return;
  // Extrai meses únicos
  const meses = [...new Set(items.map(h => {
    const d = new Date((h.data || '') + 'T12:00:00');
    return d.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });
  }))];
  const pillBase = 'flex-shrink:0;padding:5px 12px;border-radius:99px;font-size:11px;font-weight:700;cursor:pointer;border:1px solid;transition:all .15s;white-space:nowrap;';
  container.innerHTML = `
    <button style="${pillBase}background:var(--green);border-color:var(--green);color:#000;" onclick="_filtrarHistorico('todos',this)">Todos</button>
    ${meses.map(m => `<button style="${pillBase}background:transparent;border-color:var(--bg3);color:var(--muted);" onclick="_filtrarHistorico('${m}',this)">${m}</button>`).join('')}
  `;
}

function _filtrarHistorico(filtro, btn) {
  // Atualiza estilo dos pills
  document.querySelectorAll('#historico-filtros button').forEach(b => {
    b.style.background   = 'transparent';
    b.style.borderColor  = 'var(--bg3)';
    b.style.color        = 'var(--muted)';
  });
  btn.style.background  = 'var(--green)';
  btn.style.borderColor = 'var(--green)';
  btn.style.color       = '#000';

  const items = window._historicoItems || [];
  const filtrados = filtro === 'todos' ? items : items.filter(h => {
    const d = new Date((h.data || '') + 'T12:00:00');
    return d.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' }) === filtro;
  });
  _renderHistoricoCards(filtrados);
}

function _renderHistoricoCards(items) {
  const list = document.getElementById('historico-list');
  if (!list) return;
  if (!items.length) {
    list.innerHTML = '<div style="text-align:center;padding:20px;color:var(--faint);font-size:13px;">Nenhum setlist neste período</div>';
    return;
  }
  list.innerHTML = items.map(h => {
    const d = new Date((h.data || '') + 'T12:00:00');
    const diaSemana  = d.toLocaleDateString('pt-BR', { weekday: 'long' });
    const dataFull   = d.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' });
    const musicas    = h.musicas || [];
    return `
      <div style="background:rgba(24,24,27,.7);border:1px solid var(--bg3);border-radius:14px;overflow:hidden;">
        <!-- Header do card -->
        <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-bottom:1px solid rgba(63,63,70,.3);">
          <div style="background:var(--gdim);border:1px solid rgba(52,211,153,.2);border-radius:8px;padding:6px 10px;text-align:center;min-width:44px;">
            <div style="font-size:18px;font-weight:900;color:var(--green);line-height:1;">${d.getDate()}</div>
            <div style="font-size:9px;font-weight:700;color:var(--green);opacity:.7;text-transform:uppercase;letter-spacing:.5px;">${d.toLocaleDateString('pt-BR',{month:'short'}).replace('.','')}</div>
          </div>
          <div style="flex:1;min-width:0;">
            <div style="font-size:13px;font-weight:700;color:#fff;text-transform:capitalize;">${diaSemana}</div>
            <div style="font-size:11px;color:var(--faint);">${dataFull} · ${musicas.length} música${musicas.length!==1?'s':''}</div>
          </div>
        </div>
        <!-- Músicas -->
        <div style="padding:10px 16px 12px;display:flex;flex-direction:column;gap:6px;">
          ${musicas.map((m, i) => `
            <div style="display:flex;align-items:center;gap:10px;">
              <span style="font-size:10px;font-weight:700;color:var(--faint);min-width:16px;text-align:right;">${i+1}</span>
              <div style="flex:1;min-width:0;">
                <div style="font-size:13px;color:#e4e4e7;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(m.title||'')}</div>
                ${m.key && m.key !== '-' ? `<div style="font-size:10px;color:var(--faint);">Tom: ${esc(m.key)}</div>` : ''}
              </div>
            </div>`).join('')}
        </div>
      </div>`;
  }).join('');
}

// Expõe as funções para os onclicks do HTML
// ── ESCALA ────────────────────────────────────────────────────────────────────
let _escalasCache = null;

async function _garantirFirebase() {
  if (fbDb) return true;
  return await initFirebase();
}

async function _carregarEscalas() {
  console.log('[escala] iniciando. cache:', _escalasCache?.length, 'fbDb:', !!fbDb);
  if (_escalasCache?.length) return _escalasCache;
  const ok = await _garantirFirebase();
  console.log('[escala] Firebase ok:', ok, 'fbDb:', !!fbDb);
  if (!ok) return [];
  try {
    console.log('[escala] buscando no Firestore...');
    const snap = await Promise.race([
      getDocs(collection(fbDb, 'escalas')),
      new Promise((_, rej) => setTimeout(() => rej(new Error('Timeout Firestore 8s')), 8000))
    ]);
    const lista = [];
    snap.forEach(d => lista.push({ id: d.id, ...d.data() }));
    lista.sort((a, b) => (a.data || '').localeCompare(b.data || ''));
    console.log('[escala] encontradas:', lista.length);
    _escalasCache = lista;
    return lista;
  } catch(e) {
    console.error('[escala] ERRO:', e.message);
    return [];
  }
}
function _proximaDomingoEscala(escalas) {
  const hoje = new Date().toISOString().slice(0, 10);
  return escalas.find(e => e.data >= hoje) || escalas[escalas.length - 1] || null;
}

async function abrirEscala() {
  if(!localStorage.getItem('cifrei_username')) {
    document.getElementById('name-modal').style.display = 'flex'; return;
  }
  const splash = document.getElementById('splash');
  splash.style.animation = 'fadeOut 0.3s ease forwards';
  setTimeout(async () => {
    splash.style.display = 'none'; splash.style.animation = '';
    performEntranceAnimations();
    showView('escala');
    requestWakeLock();
    startOnlinePresence();
    const el = document.getElementById('escala-view-content');
    if (!el) return;
    el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--faint);">⏳ Carregando...</div>';
    const escalas = await _carregarEscalas();
    if (!escalas.length) {
      el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--faint);font-size:13px;">Nenhuma escala cadastrada ainda.<br>Consulte o líder do louvor.</div>';
      return;
    }
    _renderEscalaView(escalas);
  }, 300);
}

function _renderEscalaView(escalas) {
  const el = document.getElementById('escala-view-content');
  if (!el) return;

  // Calcula segunda-feira da semana atual — escalas antes disso somem
  const hoje = new Date();
  const diaSemana = hoje.getDay(); // 0=dom, 1=seg...
  const diasParaSeg = diaSemana === 0 ? 1 : (diaSemana === 1 ? 0 : -(diaSemana - 1));
  const segunda = new Date(hoje);
  segunda.setDate(hoje.getDate() + diasParaSeg);
  const limiteData = second => segunda.toISOString().slice(0, 10);
  const dataCorte = segunda.toISOString().slice(0, 10);
  const hojeISO = hoje.toISOString().slice(0, 10);

  // Filtra só escalas a partir de hoje (inclui o domingo atual)
  const visiveis = escalas.filter(e => (e.data || '') >= hojeISO);
  const proxima = _proximaDomingoEscala(visiveis);

  if (!visiveis.length) {
    el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--faint);font-size:13px;">Nenhuma escala programada.<br>Consulte o líder do louvor.</div>';
    return;
  }

  // Agrupa por mês
  const porMes = {};
  visiveis.forEach(e => {
    const mes = e.data?.slice(0, 7) || 'sem-data';
    if (!porMes[mes]) porMes[mes] = [];
    porMes[mes].push(e);
  });

  let html = '';
  Object.entries(porMes).forEach(([mes, lista]) => {
    const [ano, m] = mes.split('-');
    const nomeMes = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'][parseInt(m)-1] || mes;
    html += `<div style="margin-bottom:28px;">
      <div style="font-size:11px;font-weight:800;color:var(--green);letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;">${nomeMes} ${ano}</div>
      <div style="display:flex;flex-direction:column;gap:12px;">`;
    lista.forEach(e => {
      const isProx = e.id === proxima?.id;
      const dataFmt = _formatarDataEscala(e.data);
      html += _renderEscalaCard(e, dataFmt, isProx);
    });
    html += `</div></div>`;
  });
  el.innerHTML = html;
}

function _formatarDataEscala(data) {
  if (!data) return '—';
  const d = new Date(data + 'T12:00:00');
  return d.toLocaleDateString('pt-BR', { weekday:'long', day:'numeric', month:'long' });
}

function _formatarDataCurta(data) {
  if (!data) return '—';
  const d = new Date(data + 'T12:00:00');
  return d.toLocaleDateString('pt-BR', { day:'2-digit', month:'2-digit' });
}

// Ícones SVG por função
function _iconeEscala(funcao) {
  const f = (funcao || '').toLowerCase();
  if (f.includes('ministração') || f.includes('ministraçao'))
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`;
  if (f.includes('voz') || f.includes('vocal'))
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`;
  if (f.includes('violão') || f.includes('violao'))
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>`;
  if (f.includes('guitarra'))
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>`;
  if (f.includes('baixo'))
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="9" y1="18" x2="9" y2="6"/><line x1="15" y1="18" x2="15" y2="6"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
  if (f.includes('bateria') || f.includes('percussão') || f.includes('percussao'))
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><ellipse cx="12" cy="12" rx="10" ry="5"/><path d="M2 12v6c0 2.76 4.48 5 10 5s10-2.24 10-5v-6"/><path d="M2 6v6"/><path d="M22 6v6"/></svg>`;
  if (f.includes('teclado') || f.includes('piano') || f.includes('teclas'))
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="6" y1="5" x2="6" y2="19"/><line x1="10" y1="5" x2="10" y2="19"/><line x1="14" y1="5" x2="14" y2="19"/><line x1="18" y1="5" x2="18" y2="19"/><rect x="4" y="5" width="2" height="8" rx="1" fill="currentColor" stroke="none"/><rect x="8" y="5" width="2" height="8" rx="1" fill="currentColor" stroke="none"/><rect x="12" y="5" width="2" height="8" rx="1" fill="currentColor" stroke="none"/><rect x="16" y="5" width="2" height="8" rx="1" fill="currentColor" stroke="none"/></svg>`;
  if (f.includes('flauta') || f.includes('sopro'))
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M3 12h18M3 12c0-1.1.9-2 2-2h14a2 2 0 0 1 0 4H5a2 2 0 0 1-2-2z"/><circle cx="7" cy="12" r="1" fill="currentColor"/><circle cx="11" cy="12" r="1" fill="currentColor"/><circle cx="15" cy="12" r="1" fill="currentColor"/></svg>`;
  // genérico: nota musical
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`;
}

function _isMinistro(funcao) {
  return (funcao || '').toLowerCase().includes('ministração') || (funcao || '').toLowerCase().includes('ministraçao');
}

function _renderEscalaCard(escala, dataFmt, destaque) {
  const funcoes = escala.funcoes || [];
  const obs = escala.obs || '';
  const borda = destaque ? 'border-color:rgba(52,211,153,.4);box-shadow:0 0 0 1px rgba(52,211,153,.15);' : '';
  const tag = destaque ? `<span style="background:rgba(52,211,153,.15);border:1px solid rgba(52,211,153,.3);color:var(--green);font-size:9px;font-weight:800;letter-spacing:1px;text-transform:uppercase;border-radius:99px;padding:2px 8px;">próximo</span>` : '';

  const membrosHtml = funcoes.map(f => {
    const ministro = _isMinistro(f.funcao);
    const avatarSize = ministro ? 42 : 34;
    const avatarHtml = _avatarMiniEscala(f.nome, avatarSize);
    const icone = _iconeEscala(f.funcao);
    if (ministro) {
      // Linha de destaque para o ministro
      return `<div style="display:flex;align-items:center;gap:12px;padding:10px 12px;margin:4px 0;background:rgba(52,211,153,.07);border:1px solid rgba(52,211,153,.2);border-radius:12px;">
        ${avatarHtml}
        <div style="flex:1;min-width:0;">
          <div style="font-size:15px;font-weight:900;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(f.nome || '—')}</div>
          <div style="display:flex;align-items:center;gap:5px;margin-top:2px;">
            <span style="color:var(--green);">${icone}</span>
            <span style="font-size:11px;font-weight:700;color:var(--green);">${esc(f.funcao || '')}</span>
          </div>
        </div>
        <span style="font-size:18px;">🎤</span>
      </div>`;
    }
    return `<div style="display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid rgba(63,63,70,.15);">
      ${avatarHtml}
      <div style="flex:1;min-width:0;">
        <div style="font-size:13px;font-weight:700;color:#e4e4e7;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(f.nome || '—')}</div>
        <div style="display:flex;align-items:center;gap:5px;margin-top:1px;">
          <span style="color:var(--faint);opacity:.7;">${icone}</span>
          <span style="font-size:11px;color:var(--faint);">${esc(f.funcao || '')}</span>
        </div>
      </div>
    </div>`;
  }).join('');

  const obsHtml = obs ? `<div style="margin-top:10px;padding:8px 12px;background:rgba(251,191,36,.07);border:1px solid rgba(251,191,36,.2);border-radius:8px;font-size:11px;color:#fbbf24;">⭐ ${esc(obs)}</div>` : '';

  return `<div style="background:rgba(24,24,27,.7);border:1px solid rgba(63,63,70,.5);border-radius:16px;padding:16px;backdrop-filter:blur(8px);${borda}">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div style="font-size:15px;font-weight:800;color:#fff;">${esc(dataFmt)}</div>
      ${tag}
    </div>
    ${membrosHtml}
    ${obsHtml}
  </div>`;
}

function _avatarMiniEscala(nome, size) {
  size = size || 34;
  if (!nome) return `<div style="width:${size}px;height:${size}px;border-radius:50%;background:var(--bg3);flex-shrink:0;"></div>`;
  const av = _avatarsCache?.[(nome).toLowerCase().trim()];
  const cor = ['#34d399','#60a5fa','#fbbf24','#f87171','#c084fc','#fb923c'][nome.length % 6];
  if (av?.foto) {
    return `<div style="width:${size}px;height:${size}px;border-radius:50%;background-image:url(${av.foto});background-size:cover;background-position:center;flex-shrink:0;border:2px solid rgba(52,211,153,.3);"></div>`;
  }
  return `<div style="width:${size}px;height:${size}px;border-radius:50%;background:${cor};display:flex;align-items:center;justify-content:center;font-size:${size>36?16:13}px;font-weight:900;color:#000;flex-shrink:0;">${nome.charAt(0).toUpperCase()}</div>`;
}

async function _renderEscalaSono() {
  const el = document.getElementById('sono-escala-lista');
  if (!el) return;
  const escalas = _escalasCache || await _carregarEscalas();
  const proxima = _proximaDomingoEscala(escalas);
  if (!proxima) {
    el.innerHTML = '<div style="color:var(--faint);font-size:12px;text-align:center;padding:8px;">Nenhuma escala definida</div>';
    return;
  }
  const funcoes = proxima.funcoes || [];
  el.innerHTML = `<div style="font-size:11px;color:var(--faint);margin-bottom:10px;">${_formatarDataEscala(proxima.data)}</div>` +
    funcoes.map(f => {
      const ministro = _isMinistro(f.funcao);
      const av = _avatarMiniEscala(f.nome, ministro ? 40 : 32);
      const icone = _iconeEscala(f.funcao);
      if (ministro) {
        return `<div style="display:flex;align-items:center;gap:10px;padding:8px 10px;margin-bottom:6px;background:rgba(52,211,153,.07);border:1px solid rgba(52,211,153,.2);border-radius:10px;">
          ${av}
          <div style="flex:1;min-width:0;">
            <div style="font-size:14px;font-weight:900;color:#fff;">${esc(f.nome || '—')}</div>
            <div style="display:flex;align-items:center;gap:4px;margin-top:1px;">
              <span style="color:var(--green);">${icone}</span>
              <span style="font-size:10px;font-weight:700;color:var(--green);">${esc(f.funcao || '')}</span>
            </div>
          </div>
          <span style="font-size:16px;">🎤</span>
        </div>`;
      }
      return `<div style="display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(63,63,70,.15);">
        ${av}
        <div style="flex:1;min-width:0;">
          <div style="font-size:12px;font-weight:700;color:#e4e4e7;">${esc(f.nome || '—')}</div>
          <div style="display:flex;align-items:center;gap:4px;">
            <span style="color:var(--faint);opacity:.7;">${icone}</span>
            <span style="font-size:10px;color:var(--faint);">${esc(f.funcao || '')}</span>
          </div>
        </div>
      </div>`;
    }).join('') + (proxima.obs ? `<div style="margin-top:8px;font-size:11px;color:#fbbf24;">⭐ ${esc(proxima.obs)}</div>` : '');
}

Object.assign(window, {
  iniciar, abrirBanco, handleRefresh, voltarLista, voltarHome, moveSong, openSong, removeSong,
  toggleEditMode, leaveReader, navSong, adjTranspose, adjFont, adjSpacing, adjSpeed,
  toggleScroll, toggleFS, toggleFab, toggleColorPopover, showToast, abrirPreview,
  cancelarEdicaoCifra, cancelarEdicaoVocal,
  adicionarAoSetlist, addPreviewToSetlist, showView, filtrarBanco, saveName,
  finalizarLouvor, fecharResumoModal, baixarCifrasSetlist, fecharDownloadModal,
  toggleVoto, onbCifreiNext, fecharOnboardingCifrei, sairDaSala, toggleSalaBloqueio,
  abrirModalPerfil, fecharModalPerfil, salvarNomePerfil, perfilSelecionarFoto,
  abrirModalAdicionarSetlist, fecharModalAddSetlist, filtrarBancoParaSetlist,
  abrirModalTom, fecharModalTom, ajustarTomSetlist, confirmarTomSetlist, salvarTomAtual,
  toggleModoVocal, atualizarSalaComLetra, abrirEscala,
  abrirSonoplastia, abrirPopupChamados, fecharPopupChamados, enviarChamado, atenderChamado, abrirCifraDaSono, abrirSonoCifra, fecharSonoCifra, copiarLetraSono,
  _toggleHistorico, _filtrarHistorico,
});
</script>
