      <!-- Glow de fundo -->
      <div id="af-glow" style="position:absolute;inset:0;border-radius:20px;background:radial-gradient(ellipse at 50% 60%,rgba(52,211,153,.0) 0%,transparent 70%);transition:background .3s;pointer-events:none;"></div>

      <!-- Nota principal -->
