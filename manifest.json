const CHAMADOS_PADRAO = [
  { id:'cabo',   texto:'Preciso de cabo',               cor:'#f87171', icone:'🔌' },
  { id:'bateria',texto:'Bateria para instrumento',       cor:'#fbbf24', icone:'🔋' },
  { id:'pilha',  texto:'Pilha para microfone',           cor:'#fbbf24', icone:'🎤' },
  { id:'cortar', texto:'Corte meu instrumento',          cor:'#f97316', icone:'🔇' },
  { id:'ligar',  texto:'Ligue meu instrumento',          cor:'#34d399', icone:'🔊' },
];
let _chamadosConfig = null;
let _chamadosUnsub = null;

async function getChamadosConfig() {
  if (_chamadosConfig) return _chamadosConfig;
  if (fbDb && window._fbDoc && window._fbGetDoc) {
    try {
      const snap = await window._fbGetDoc(window._fbDoc(fbDb, 'chamados_config', 'lista'));
      if (snap.exists()) { _chamadosConfig = snap.data().itens || CHAMADOS_PADRAO; return _chamadosConfig; }
    } catch(e) {}
  }
  _chamadosConfig = CHAMADOS_PADRAO;
  return _chamadosConfig;
}

async function abrirSonoplastia() {
  if (!localStorage.getItem('cifrei_username')) {
    document.getElementById('name-modal').style.display = 'flex'; return;
  }
  const splash = document.getElementById('splash');
  splash.style.animation = 'fadeOut 0.3s ease forwards';
  setTimeout(async () => {
    splash.style.display = 'none'; splash.style.animation = '';
    performEntranceAnimations();
    showView('sono');
    requestWakeLock();
    if (!S.bancoCarregado) await carregarBanco();
    startOnlinePresence();
    _iniciarSono();
    _renderEscalaSono(); // carrega escala do próximo domingo
  }, 300);
}

function _iniciarSono() {
  const nome = localStorage.getItem('cifrei_username') || 'Equipe';
  const h = new Date().getHours();
  let saud, periodo;
  if (h >= 5 && h < 12)      { saud = 'Bom dia';    periodo = 'dia'; }
  else if (h >= 12 && h < 18){ saud = 'Boa tarde';  periodo = 'tarde'; }
  else if (h >= 18 && h < 20){ saud = 'Boa tarde';  periodo = 'tardinha'; }
  else                        { saud = 'Boa noite';  periodo = 'noite'; }
  const lbl = document.getElementById('sono-saudacao-label');
  const nomeEl = document.getElementById('sono-nome');
  if (lbl) lbl.textContent = saud + ',';
  if (nomeEl) nomeEl.textContent = nome;
  _construirCeuSono(periodo);
  _renderSonoSetlist();
  _sonoIdsConhecidos = null; // reseta para primeira carga silenciosa
  _escutarChamadosSono();
}

function _construirCeuSono(periodo) {
  const scene = document.getElementById('sono-sky-scene');
  const card  = document.getElementById('sono-sky-card');
  if (!scene || !card) return;
  scene.innerHTML = '';

  const nuvem = (x, y, scale, dur, delay, opacity=0.85) =>
    `<g transform="translate(${x},${y}) scale(${scale})" style="opacity:${opacity};animation:floatCloud ${dur}s ${delay}s linear infinite;">
      <ellipse cx="30" cy="20" rx="30" ry="12" fill="white"/>
      <ellipse cx="50" cy="16" rx="22" ry="14" fill="white"/>
      <ellipse cx="70" cy="20" rx="20" ry="10" fill="white"/>
      <ellipse cx="15" cy="22" rx="15" ry="9" fill="white"/>
    </g>`;

  if (periodo === 'dia') {
    card.style.background = 'linear-gradient(160deg,#1e3a5f 0%,#2563a8 40%,#38bdf8 100%)';
    scene.innerHTML = `<svg viewBox="0 0 800 160" xmlns="http://www.w3.org/2000/svg" style="position:absolute;inset:0;width:100%;height:100%;">
      <g transform="translate(680,40)">
        <circle cx="0" cy="0" r="28" fill="#fde68a" opacity="0.95"/>
        <g style="animation:spinSun 18s linear infinite;transform-origin:0px 0px;">
          ${Array.from({length:12},(_,i)=>{const a=i*30*Math.PI/180;return `<line x1="${Math.cos(a)*32}" y1="${Math.sin(a)*32}" x2="${Math.cos(a)*42}" y2="${Math.sin(a)*42}" stroke="#fde68a" stroke-width="3" stroke-linecap="round"/>`;}).join('')}
        </g>
        <circle cx="0" cy="0" r="22" fill="#fbbf24"/>
      </g>
      ${nuvem(-100, 20, 1.1, 38, 0)}${nuvem(-100, 60, 0.7, 52, -15, 0.7)}${nuvem(-100, 10, 0.9, 45, -25)}${nuvem(-100, 80, 0.6, 60, -40, 0.6)}
    </svg>`;

  } else if (periodo === 'tarde') {
    card.style.background = 'linear-gradient(160deg,#1e3a5f 0%,#3b82f6 40%,#7dd3fc 100%)';
    scene.innerHTML = `<svg viewBox="0 0 800 160" xmlns="http://www.w3.org/2000/svg" style="position:absolute;inset:0;width:100%;height:100%;">
      <g transform="translate(660,50)">
        <circle cx="0" cy="0" r="24" fill="#fde68a" opacity="0.9"/>
        <g style="animation:spinSun 25s linear infinite;transform-origin:0px 0px;">
          ${Array.from({length:10},(_,i)=>{const a=i*36*Math.PI/180;return `<line x1="${Math.cos(a)*28}" y1="${Math.sin(a)*28}" x2="${Math.cos(a)*36}" y2="${Math.sin(a)*36}" stroke="#fde68a" stroke-width="2.5" stroke-linecap="round"/>`;}).join('')}
        </g>
        <circle cx="0" cy="0" r="19" fill="#fbbf24"/>
      </g>
      ${nuvem(-100, 30, 0.8, 44, 0)}${nuvem(-100, 70, 0.5, 58, -20, 0.6)}
    </svg>`;

  } else if (periodo === 'tardinha') {
    card.style.background = 'linear-gradient(160deg,#1e1b4b 0%,#7c3aed 35%,#f97316 70%,#fbbf24 100%)';
    scene.innerHTML = `<svg viewBox="0 0 800 160" xmlns="http://www.w3.org/2000/svg" style="position:absolute;inset:0;width:100%;height:100%;">
      <g transform="translate(650,90)" style="animation:sunsetPulse 4s ease-in-out infinite;">
        <circle cx="0" cy="0" r="36" fill="#f97316" opacity="0.85"/>
        <circle cx="0" cy="0" r="28" fill="#fb923c"/>
        <circle cx="0" cy="0" r="20" fill="#fbbf24"/>
      </g>
      ${nuvem(-100, 10, 1.0, 50, 0, 0.5)}${nuvem(-100, 50, 0.7, 65, -18, 0.4)}
    </svg>`;

  } else {
    card.style.background = 'linear-gradient(160deg,#0a0a1a 0%,#0f172a 50%,#1e1b4b 100%)';
    const estrelas = Array.from({length:25},(_,i)=>
      `<circle cx="${Math.random()*800}" cy="${Math.random()*100}" r="${0.8+Math.random()*1.2}" fill="white" style="animation:twinkle ${2+Math.random()*3}s ${Math.random()*3}s ease-in-out infinite;opacity:${0.3+Math.random()*0.7}"/>`
    ).join('');
    scene.innerHTML = `<svg viewBox="0 0 800 160" xmlns="http://www.w3.org/2000/svg" style="position:absolute;inset:0;width:100%;height:100%;">
      ${estrelas}
      <g transform="translate(680,38)" style="animation:moonGlow 4s ease-in-out infinite;">
        <circle cx="0" cy="0" r="22" fill="#fef9c3"/>
        <circle cx="7" cy="-5" r="18" fill="#0f172a"/>
      </g>
      ${nuvem(-100, 40, 0.9, 55, 0, 0.25)}${nuvem(-100, 80, 0.6, 70, -25, 0.18)}
    </svg>`;
  }
}

function _renderSonoSetlist() {
  const el = document.getElementById('sono-setlist-lista');
  if (!S.songs.length) {
    if (el) el.innerHTML = '<div style="color:var(--faint);font-size:12px;text-align:center;padding:12px;">Setlist vazio</div>';
    return;
  }
  const { limiteEBD } = (typeof getTurnoInfo === 'function') ? getTurnoInfo() : { limiteEBD: S.songs.length };
  if (el) {
    el.innerHTML = S.songs.map((s,i) => `
      <div class="sono-music-row" onclick="abrirSonoCifra(${i})">
        <span style="font-size:11px;color:var(--faint);width:18px;text-align:right;flex-shrink:0;">${i+1}</span>
        <span class="sono-music-tag ${i < limiteEBD ? 'ebd' : 'culto'}">${i < limiteEBD ? 'EBD' : 'CULTO'}</span>
        <div style="flex:1;min-width:0;">
          <div class="sono-music-nome">${esc(s.title)}</div>
          ${s.artist ? `<div style="font-size:11px;color:var(--faint);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(s.artist)}</div>` : ''}
        </div>
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--faint)" stroke-width="2" width="13" height="13" style="flex-shrink:0;"><polyline points="9 18 15 12 9 6"/></svg>
      </div>`).join('');
  }
}

function abrirSonoCifra(idx) {
  const song = S.songs[idx];
  if (!song) return;
  const drawer  = document.getElementById('sono-cifra-drawer');
  const title   = document.getElementById('sono-cifra-title');
  const artist  = document.getElementById('sono-cifra-artist');
  const cont    = document.getElementById('sono-cifra-content');
  if (!drawer || !cont) return;

  title.textContent  = song.title;
  artist.textContent = song.artist || '';

  // Mostra letra se disponível, senão cifra sem acordes
  const letra = song.letra?.trim();
  if (letra) {
    cont.textContent = letra;
  } else if (song.content) {
    // Extrai letra da cifra removendo linhas de acordes
    const linhasLetra = song.content.split('\n').filter(l => {
      const t = l.trim();
      if (!t) return true;
      return !/^([A-G][b#]?(?:m|maj|min|dim|aug|sus|add)?\d*(?:\/[A-G][b#]?)?\s*)+$/.test(t);
    });
    cont.textContent = linhasLetra.join('\n').replace(/\n{3,}/g,'\n\n').trim();
  } else {
    cont.textContent = '(letra não disponível)';
  }

  // Guarda dados para o botão copiar
  drawer._song = song;
  drawer.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function fecharSonoCifra() {
  const drawer = document.getElementById('sono-cifra-drawer');
  if (drawer) drawer.style.display = 'none';
  document.body.style.overflow = '';
}

function copiarLetraSono() {
  const drawer = document.getElementById('sono-cifra-drawer');
  const song   = drawer?._song;
  if (!song) return;

  const letra = song.letra?.trim() || document.getElementById('sono-cifra-content')?.textContent || '';
  const artista = song.artist ? `${song.artist}\n` : '';
  const texto = `${song.title}\n${artista}\n${letra}`;

  navigator.clipboard?.writeText(texto).then(() => {
    const btn = document.getElementById('btn-copiar-sono');
    if (btn) {
      btn.innerHTML = '✅ Copiado!';
      setTimeout(() => {
        btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copiar Letra';
      }, 2000);
    }
  }).catch(() => {
    // Fallback para navegadores sem clipboard API
    const ta = document.createElement('textarea');
    ta.value = texto;
    ta.style.position = 'fixed'; ta.style.opacity = '0';
    document.body.appendChild(ta);
    ta.select(); document.execCommand('copy');
    document.body.removeChild(ta);
    showToast('Letra copiada!');
  });
}

function _escutarChamadosSono() {
  if (!fbDb) return;
  if (_chamadosUnsub) { _chamadosUnsub(); _chamadosUnsub = null; }
  const col = collection(fbDb, 'chamados_ativos');
  _chamadosUnsub = onSnapshot(col, (snap) => {
    const chamados = [];
    snap.forEach(d => chamados.push({ id: d.id, ...d.data() }));
    chamados.sort((a,b) => (b.ts||0) - (a.ts||0));
    _renderChamadosSono(chamados);
    _atualizarSonoPresence(_presenceUsers || []);
  });
}

// ── ALERTA SONORO SONOPLASTIA ─────────────────────────────────────────────────
let _sonoIdsConhecidos = null; // null = primeira carga, não toca
let _sonoAudioCtx = null;

function _tocarAlertaSono() {
  try {
    if (!_sonoAudioCtx) _sonoAudioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const ctx = _sonoAudioCtx;
    if (ctx.state === 'suspended') ctx.resume();
    // Sequência: três bipes curtos ascendentes
    const notas = [880, 1100, 1320];
    notas.forEach((freq, i) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.type = 'sine';
      osc.frequency.value = freq;
      const t = ctx.currentTime + i * 0.18;
      gain.gain.setValueAtTime(0, t);
      gain.gain.linearRampToValueAtTime(0.4, t + 0.02);
      gain.gain.exponentialRampToValueAtTime(0.001, t + 0.16);
      osc.start(t);
      osc.stop(t + 0.18);
    });
  } catch(e) {}
}

function _renderChamadosSono(chamados) {
  const lista = document.getElementById('sono-chamados-lista');
  const badge = document.getElementById('sono-chamados-badge');
  const hist = document.getElementById('sono-historico-lista');
  if (!lista) return;
  const ativos = chamados.filter(c => !c.atendido);
  const historico = chamados.filter(c => c.atendido);

  // Detecta chamados novos e toca alerta sonoro
  if (_sonoIdsConhecidos === null) {
    // Primeira carga: registra os existentes sem tocar
    _sonoIdsConhecidos = new Set(ativos.map(c => c.id));
  } else {
    const novos = ativos.filter(c => !_sonoIdsConhecidos.has(c.id));
    if (novos.length > 0) {
      _tocarAlertaSono();
      novos.forEach(c => _sonoIdsConhecidos.add(c.id));
    }
    // Remove atendidos do set para que, se reenviados, toquem de novo
    ativos.forEach(c => _sonoIdsConhecidos.add(c.id));
  }
  const card = document.getElementById('sono-chamados-card');
  if (card) card.classList.toggle('sono-alerta-card', ativos.length > 0);
  if (badge) {
    badge.style.display = ativos.length ? 'block' : 'none';
    badge.textContent = ativos.length;
  }
  // Atualiza contador "Chamados hoje"
  const hoje = new Date(); hoje.setHours(0,0,0,0);
  const totalHoje = chamados.filter(c => c.ts >= hoje.getTime()).length;
  const numEl = document.getElementById('sono-chamados-hoje-num');
  if (numEl) numEl.textContent = totalHoje;
  lista.innerHTML = ativos.length
    ? ativos.map(c => `
        <div class="sono-chamado-item">
          <div style="font-size:34px;flex-shrink:0;">${c.icone||'📣'}</div>
          <div style="flex:1;min-width:0;">
            <div style="font-size:16px;font-weight:800;color:#fff;line-height:1.2;">${esc(c.texto)}</div>
            <div style="font-size:11px;color:rgba(255,255,255,.45);margin-top:4px;">por <strong>${esc(c.remetente)}</strong> · ${_formatarHoraChamado(c.ts)}</div>
          </div>
          <button class="sono-chamado-ok" onclick="atenderChamado('${c.id}')">OK ✓</button>
        </div>`)
      .join('')
    : `<div style="text-align:center;padding:28px 0;">
        <div style="font-size:32px;margin-bottom:8px;">✅</div>
        <div style="font-size:14px;font-weight:700;color:var(--muted);">Tudo certo por aqui</div>
        <div style="font-size:12px;color:var(--faint);margin-top:3px;">Nenhum chamado no momento</div>
       </div>`;
  if (hist) {
    const inicioHoje = new Date(); inicioHoje.setHours(0,0,0,0);
    const historicoHoje = historico.filter(c => (c.ts || 0) >= inicioHoje.getTime());
    hist.innerHTML = historicoHoje.length
      ? historicoHoje.map(c => `
          <div class="sono-hist-row">
            <span style="font-size:20px;">${c.icone||'📣'}</span>
            <div style="flex:1;min-width:0;">
              <div style="font-size:12px;font-weight:600;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(c.texto)}</div>
              <div style="font-size:10px;color:var(--faint);">${esc(c.remetente)} · ${_formatarHoraChamado(c.ts)}</div>
            </div>
            <div style="font-size:10px;color:var(--green);font-weight:700;flex-shrink:0;white-space:nowrap;">✓ ${esc(c.atendidoPor||'')}</div>
          </div>`)
        .join('')
      : '<div style="color:var(--faint);font-size:12px;text-align:center;padding:12px;">Nenhum chamado hoje</div>';
  }
}

function _formatarHoraChamado(ts) {
  if (!ts) return '';
  return new Date(ts).toLocaleTimeString('pt-BR', { hour:'2-digit', minute:'2-digit' });
}

async function atenderChamado(id) {
  if (!fbDb || !window._fbDoc || !window._fbSetDoc) return;
  const nome = localStorage.getItem('cifrei_username') || 'Sonoplasta';
  try {
    await window._fbSetDoc(window._fbDoc(fbDb, 'chamados_ativos', id), {
      atendido: true, atendidoPor: nome, atendidoTs: Date.now()
    }, { merge: true });
    showToast('Chamado atendido ✓');
    // Notifica o músico via sala
    if (fbDb && window._fbDoc && window._fbSetDoc) {
      await window._fbSetDoc(window._fbDoc(fbDb, 'chamados_resposta', id), {
        id, atendidoPor: nome, ts: Date.now()
      });
    }
  } catch(e) {}
}

async function abrirPopupChamados() {
  const popup = document.getElementById('popup-chamados');
  const lista = document.getElementById('popup-chamados-lista');
  if (!popup || !lista) return;
  const config = await getChamadosConfig();
  lista.innerHTML = config.map(c => `
    <button onclick="enviarChamado('${c.id}')" style="display:flex;align-items:center;gap:14px;padding:16px;background:${c.cor}22;border:1.5px solid ${c.cor}55;border-radius:14px;cursor:pointer;text-align:left;width:100%;transition:all .15s;" onmouseenter="this.style.background='${c.cor}44'" onmouseleave="this.style.background='${c.cor}22'">
      <span style="font-size:28px;flex-shrink:0;">${c.icone}</span>
      <span style="font-size:15px;font-weight:700;color:#fff;">${esc(c.texto)}</span>
    </button>`).join('');
  popup.style.display = 'flex';
}

function fecharPopupChamados() {
  const p = document.getElementById('popup-chamados');
  if (p) p.style.display = 'none';
}

async function enviarChamado(id) {
  if (!fbDb || !window._fbDoc || !window._fbSetDoc) return;
  const config = await getChamadosConfig();
  const item = config.find(c => c.id === id);
  if (!item) return;
  const nome = localStorage.getItem('cifrei_username') || '?';
  try {
    const docId = `${id}_${Date.now()}`;
    await window._fbSetDoc(window._fbDoc(fbDb, 'chamados_ativos', docId), {
      id: docId, itemId: id, texto: item.texto, icone: item.icone,
      cor: item.cor, remetente: nome, ts: Date.now(), atendido: false
    });
    fecharPopupChamados();
    showToast('Chamado enviado! Aguarde o sonoplasta 🎚️');
    // Escuta resposta
    _escutarRespostaChamado(docId, item.texto);
  } catch(e) { showToast('Erro ao enviar chamado', 'error'); }
}

function _escutarRespostaChamado(docId, texto) {
  if (!fbDb) return;
  const ref = window._fbDoc(fbDb, 'chamados_resposta', docId);
  const unsub = onSnapshot(ref, (snap) => {
    if (!snap.exists()) return;
    const d = snap.data();
    if (d.atendidoPor) {
      showToast(`✅ "${texto}" atendido por ${d.atendidoPor}`);
      unsub();
    }
  });
  // Auto-limpar após 30min
  setTimeout(unsub, 30 * 60 * 1000);
}

function _atualizarSonoPresence(users) {
  const el = document.getElementById('sono-presence-lista');
  const cnt = document.getElementById('sono-online-cnt');
  if (cnt) cnt.textContent = users.length ? `${users.length} online` : '';
  if (!el) return;
  el.innerHTML = '';
  if (!users.length) {
    el.innerHTML = '<div style="color:var(--faint);font-size:12px;text-align:center;padding:8px 0;">Ninguém online ainda</div>';
    return;
  }
  users.forEach(u => {
    const temSala = !!_salasAtivas[u.id];
    const isDavi  = u.name.trim().toLowerCase() === 'davi';
    const av = _avatarsCache[(u.name||'').toLowerCase().trim()];
    const row = document.createElement('div');
    row.className = 'sono-presence-row';
    const avatarEl = document.createElement('div');
    avatarEl.className = 'sono-avatar';
    if (isDavi) {
      avatarEl.style.cssText = `background:#000;border:2px solid #d4af37;box-shadow:${temSala?'0 0 0 2.5px #34d399,0 0 8px rgba(52,211,153,.4),':''}0 0 8px rgba(212,175,55,.7);font-size:20px;`;
      avatarEl.textContent = '😎';
    } else if (av?.foto) {
      avatarEl.style.cssText = `background:transparent;background-image:url(${av.foto});background-size:cover;background-position:center;${temSala?'box-shadow:0 0 0 2.5px #34d399,0 0 8px rgba(52,211,153,.4);':''}`;
    } else {
      avatarEl.style.cssText = `background:${avatarColors[u.name.length % avatarColors.length]};${temSala?'box-shadow:0 0 0 2.5px #34d399,0 0 8px rgba(52,211,153,.4);':''}`;
      avatarEl.textContent = u.name.charAt(0).toUpperCase();
    }
    row.innerHTML = `<div style="flex:1;min-width:0;">
      <div style="font-size:13px;font-weight:700;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(u.name)}</div>
      ${temSala ? '<div style="font-size:10px;color:#34d399;font-weight:700;margin-top:1px;">● tocando agora</div>' : '<div style="font-size:10px;color:var(--faint);margin-top:1px;">● online</div>'}
    </div>`;
    row.insertBefore(avatarEl, row.firstChild);
    el.appendChild(row);
  });
}

