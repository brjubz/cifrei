async function iniciar(){
  if(!localStorage.getItem('cifrei_username')) {
     document.getElementById('name-modal').style.display = 'flex';
     return;
  }
  const btn=document.getElementById('start-btn');
  document.getElementById('splash-err').style.display='none';
  btn.innerHTML='<div class="btn-spinner"></div> Carregando...';
  btn.disabled=true;
  try{
    // Garante que o Firebase está pronto (espera até 4s)
    let tentFb = 0;
    while ((!fbDb || !fbUser) && tentFb < 8) {
      await new Promise(r => setTimeout(r, 500));
      tentFb++;
    }

    let songs = null;
    // Lê a ordem persistida pelos músicos no Firebase
    if (fbDb && fbUser && window._fbDoc && window._fbGetDoc) {
      try {
        const fbSnap = await window._fbGetDoc(window._fbDoc(fbDb, 'salas', 'setlist_musico'));
        if (fbSnap.exists() && fbSnap.data().setlistContent) {
          const parsed = parseSongs(fbSnap.data().setlistContent);
          if (parsed.length) songs = parsed;
        }
      } catch(e) { console.warn('Leitura setlist_musico:', e.message); }
    }

    // Fallback: carrega do Gist (não bloqueia se falhar)
    if (!songs || !songs.length) {
      try {
        const txt = await fetchTxt(GIST_ID_SETLIST);
        songs = parseSongs(txt);
      } catch(e) {
        console.warn('Gist indisponível, entrando com setlist vazio:', e.message);
        songs = [];
      }
    }
    if(!songs) songs = [];
    S.songs = songs;
    renderList();
    document.getElementById('nav-cnt').textContent = S.songs.length;
    // Carrega banco silenciosamente em background para ter letras disponíveis no modo vocal
    _carregarBancoSilencioso();
    const splash = document.getElementById('splash');
    splash.style.animation = 'fadeOut 0.3s ease forwards';
    setTimeout(() => {
      splash.style.display='none';
      splash.style.animation = '';
      performEntranceAnimations();
      showView('list');
      requestWakeLock();
      startOnlinePresence();
      // Cria perfil automaticamente se ainda não existe
      const _nomeAtual = localStorage.getItem('cifrei_username');
      if (_nomeAtual) _criarPerfilSeNaoExiste(_nomeAtual);
      btn.innerHTML='<svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg> Iniciar';
      btn.disabled=false;
      // Exibe notificações configuradas pelo ADM (inclui tutorial/onboarding)
      setTimeout(_carregarEExibirNotificacoes, 1200);
    }, 300);
  }catch(e){
    const err=document.getElementById('splash-err');
    document.getElementById('splash-err-txt').textContent=e.message;
    err.style.display='flex';
    btn.innerHTML='<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><polygon points="5 3 19 12 5 21 5 3"/></svg> Tentar novamente';
    btn.disabled=false;
  }
}

