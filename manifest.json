      <div style="position:relative;margin:18px auto 0;width:280px;height:100px;overflow:visible;">
        <!-- SVG do arco -->
        <svg id="af-arco-svg" viewBox="0 0 280 110" style="width:100%;overflow:visible;">
          <!-- Arco de fundo -->
          <path d="M 20 100 A 120 120 0 0 1 260 100" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="3" stroke-linecap="round"/>
          <!-- Zona afinada (centro) -->
          <path d="M 115 30 A 120 120 0 0 1 165 30" fill="none" stroke="rgba(52,211,153,.25)" stroke-width="6" stroke-linecap="round"/>
          <!-- Arco colorido (preenchimento) -->
          <path id="af-arco-fill" d="M 140 100 A 120 120 0 0 1 140 100" fill="none" stroke="rgba(255,255,255,.15)" stroke-width="3" stroke-linecap="round"/>
          <!-- Marcas de escala -->
          <line x1="20" y1="100" x2="26" y2="97" stroke="rgba(255,255,255,.2)" stroke-width="1.5"/>
          <line x1="50" y1="54" x2="55" y2="57" stroke="rgba(255,255,255,.15)" stroke-width="1"/>
          <line x1="140" y1="20" x2="140" y2="27" stroke="rgba(52,211,153,.6)" stroke-width="2"/>
          <line x1="230" y1="54" x2="225" y2="57" stroke="rgba(255,255,255,.15)" stroke-width="1"/>
          <line x1="260" y1="100" x2="254" y2="97" stroke="rgba(255,255,255,.2)" stroke-width="1.5"/>
          <!-- Labels -->
          <text x="12" y="115" fill="rgba(248,113,113,.6)" font-size="9" font-family="monospace">−50</text>
          <text x="128" y="14" fill="rgba(52,211,153,.7)" font-size="9" font-family="monospace" text-anchor="middle">0</text>
          <text x="256" y="115" fill="rgba(248,113,113,.6)" font-size="9" font-family="monospace" text-anchor="end">+50</text>
          <!-- Ponteiro -->
          <g id="af-ponteiro-g" style="transform-origin:140px 100px;transform:rotate(0deg);transition:transform .12s cubic-bezier(.22,1,.36,1);">
            <line x1="140" y1="100" x2="140" y2="22" stroke="rgba(255,255,255,.9)" stroke-width="2" stroke-linecap="round"/>
            <circle cx="140" cy="100" r="5" fill="#fff"/>
            <circle cx="140" cy="24" r="3" id="af-ponta" fill="#fff"/>
          </g>
        </svg>
      </div>

      <!-- Cents e status -->
      <div style="text-align:center;margin-top:4px;position:relative;z-index:1;">
        <div id="afinador-cents" style="font-size:12px;color:rgba(255,255,255,.3);font-family:monospace;min-height:18px;"></div>
        <div id="afinador-status" style="font-size:14px;font-weight:700;color:rgba(255,255,255,.4);margin-top:4px;min-height:22px;transition:color .2s;">Aguardando microfone...</div>
      </div>

      <!-- Frequência -->
      <div id="afinador-freq" style="text-align:center;font-size:11px;color:rgba(255,255,255,.2);margin-top:6px;font-family:monospace;min-height:16px;position:relative;z-index:1;"></div>
    </div>

    <!-- Botão mic -->
    <div style="padding:14px 20px 28px;">
      <button id="btn-afinador-toggle" onclick="toggleAfinador()"
        style="width:100%;padding:15px;background:linear-gradient(135deg,#34d399,#10b981);border:none;border-radius:14px;color:#000;font-size:15px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:all .2s;letter-spacing:-.2px;box-shadow:0 4px 20px rgba(52,211,153,.25);">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        Ligar Microfone
      </button>
    </div>

  </div>
</div>

<style>
.af-inst {
  display: flex; align-items: center; gap: 6px;
  padding: 7px 13px; background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08); color: rgba(255,255,255,.45);
  border-radius: 99px; font-size: 12px; font-weight: 700;
  cursor: pointer; white-space: nowrap; transition: all .15s;
  flex-shrink: 0;
}
.af-inst.active {
  background: rgba(52,211,153,.1); border-color: rgba(52,211,153,.4);
  color: #34d399;
}
.af-corda {
  padding: 7px 16px; background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.1); color: rgba(255,255,255,.7);
  border-radius: 99px; font-size: 14px; font-weight: 800;
  cursor: pointer; font-family: var(--font-chord);
  transition: all .15s; min-width: 50px; text-align: center;
}
.af-corda.sel { border-color: rgba(52,211,153,.5); color: #34d399; background: rgba(52,211,153,.08); }
.af-corda.ok  { border-color: #34d399; color: #34d399; background: rgba(52,211,153,.15); box-shadow: 0 0 10px rgba(52,211,153,.2); }
.af-corda.off { border-color: rgba(248,113,113,.5); color: #f87171; background: rgba(248,113,113,.08); }
</style>

<script>
// ═══ AFINADOR ════════════════════════════════════════════════════════════════
const _AF_INST = {
  guitarra: ['E2','A2','D3','G3','B3','E4'],
  violao:   ['E2','A2','D3','G3','B3','E4'],
  baixo:    ['E1','A1','D2','G2'],
  ukulele:  ['G4','C4','E4','A4'],
};
const _AF_NOMES = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];

function _afFreqParaNota(freq) {
  if (!freq || freq < 20 || freq > 5000) return null;
  const n = 12 * Math.log2(freq / 440) + 69;
  const r = Math.round(n);
  const cents = (n - r) * 100;
  return {
    nomeCurto: _AF_NOMES[((r % 12) + 12) % 12],
    nota: _AF_NOMES[((r % 12) + 12) % 12] + (Math.floor(r / 12) - 1),
    oitava: Math.floor(r / 12) - 1,
    cents, freq
  };
}

function _afRMS(buf) {
  let s = 0; for (let i = 0; i < buf.length; i++) s += buf[i]*buf[i];
  return Math.sqrt(s / buf.length);
}

function _afAutocorr(buf, taxa) {
  const n = buf.length, c = new Float32Array(n);
  for (let i = 0; i < n; i++) for (let j = 0; j < n-i; j++) c[i] += buf[j]*buf[j+i];
  let d = 0; while (d < n && c[d] > c[d+1]) d++;
  let mx = -1, mp = -1;
  for (let i = d; i < n; i++) if (c[i] > mx) { mx = c[i]; mp = i; }
  if (mp < 1) return -1;
  const y1=c[mp-1]||0,y2=c[mp],y3=c[mp+1]||0;
  const a=(y1+y3-2*y2)/2, b=(y3-y1)/2;
  return taxa / (mp + (a ? -b/(2*a) : 0));
}

// Ângulo do ponteiro: -90° (esquerda) a +90° (direita), 0 = centro afinado
function _afCentsParaAngulo(cents) {
  return Math.max(-90, Math.min(90, cents * 1.8));
}

let _afCtx=null,_afStream=null,_afAnalyser=null,_afAtivo=false;
let _afInst='guitarra',_afCorda=null,_afRAF=null;

function abrirAfinador() {
  const m = document.getElementById('modal-afinador');
  m.style.display = 'flex';
  selecionarInstrumento(_afInst, document.querySelector(`.af-inst[data-inst="${_afInst}"]`));
}

function fecharAfinador() {
  pararAfinador();
  document.getElementById('modal-afinador').style.display = 'none';
}

function selecionarInstrumento(inst, btn) {
  _afInst = inst;
  document.querySelectorAll('.af-inst').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  const cordas = _AF_INST[inst];
  const wrap = document.getElementById('afinador-cordas');
  const labels = {guitarra:['E','A','D','G','B','E'],violao:['E','A','D','G','B','E'],baixo:['E','A','D','G'],ukulele:['G','C','E','A']};
  const nums = cordas.map((_,i) => i+1);
  wrap.innerHTML = cordas.map((c,i) => `
    <button class="af-corda${i===0?' sel':''}" data-corda="${c}" onclick="selecionarCorda('${c}',this)">
      ${(labels[inst]||[])[i]||c.replace(/\d/,'')}
      <sub style="font-size:9px;opacity:.5;">${nums[i]}</sub>
    </button>`).join('');
  _afCorda = cordas[0];
}

function selecionarCorda(c, btn) {
  _afCorda = c;
  document.querySelectorAll('.af-corda').forEach(b => b.classList.remove('sel','ok','off'));
  if (btn) btn.classList.add('sel');
}

async function toggleAfinador() {
  if (_afAtivo) { pararAfinador(); return; }
  await iniciarAfinador();
}

async function iniciarAfinador() {
  try {
    _afStream = await navigator.mediaDevices.getUserMedia({ audio:{ echoCancellation:false, noiseSuppression:false, autoGainControl:false }, video:false });
    _afCtx = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: 44100 });
    _afAnalyser = _afCtx.createAnalyser();
    _afAnalyser.fftSize = 8192;
    _afAnalyser.smoothingTimeConstant = 0.6;
    _afCtx.createMediaStreamSource(_afStream).connect(_afAnalyser);
    _afAtivo = true;
    const btn = document.getElementById('btn-afinador-toggle');
    btn.style.background = 'linear-gradient(135deg,#f87171,#ef4444)';
    btn.style.boxShadow = '0 4px 20px rgba(248,113,113,.3)';
    btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg> Desligar`;
    document.getElementById('afinador-status').textContent = '🎙️ Toque uma nota...';
    _afLoop();
  } catch(e) {
    document.getElementById('afinador-status').textContent = '⚠️ Permita o microfone nas configurações';
    document.getElementById('afinador-status').style.color = '#f87171';
  }
}

function pararAfinador() {
  _afAtivo = false;
  if (_afRAF) cancelAnimationFrame(_afRAF);
  if (_afStream) _afStream.getTracks().forEach(t => t.stop());
  if (_afCtx) _afCtx.close().catch(()=>{});
  _afCtx=_afStream=_afAnalyser=_afRAF=null;
  const btn = document.getElementById('btn-afinador-toggle');
  btn.style.background = 'linear-gradient(135deg,#34d399,#10b981)';
  btn.style.boxShadow = '0 4px 20px rgba(52,211,153,.25)';
  btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg> Ligar Microfone`;
  _afReset();
}

function _afReset() {
  document.getElementById('afinador-nota').textContent = '—';
  document.getElementById('afinador-nota').style.color = '#fff';
  document.getElementById('afinador-nota').style.textShadow = 'none';
  document.getElementById('afinador-oitava').textContent = '';
  document.getElementById('afinador-freq').textContent = '';
  document.getElementById('afinador-cents').textContent = '';
  document.getElementById('afinador-status').textContent = 'Aguardando microfone...';
  document.getElementById('afinador-status').style.color = 'rgba(255,255,255,.4)';
  document.getElementById('af-glow').style.background = 'radial-gradient(ellipse at 50% 60%,rgba(52,211,153,.0) 0%,transparent 70%)';
  document.getElementById('af-ponteiro-g').style.transform = 'rotate(0deg)';
  document.getElementById('af-ponta').setAttribute('fill','#fff');
}

function _afLoop() {
  if (!_afAtivo) return;
  _afRAF = requestAnimationFrame(_afLoop);
  const buf = new Float32Array(_afAnalyser.fftSize);
  _afAnalyser.getFloatTimeDomainData(buf);
  if (_afRMS(buf) < 0.008) {
    document.getElementById('afinador-status').textContent = '🎙️ Toque uma nota...';
    document.getElementById('af-ponteiro-g').style.transform = 'rotate(0deg)';
    return;
  }
  const freq = _afAutocorr(buf, _afCtx.sampleRate);
  if (!freq || freq < 20 || freq > 2000) return;
  const det = _afFreqParaNota(freq);
  if (!det) return;

  const cents = det.cents;
  const angulo = _afCentsParaAngulo(cents);
  const abs = Math.abs(cents);

  // Cores
  let cor, glow, statusTxt;
  if (abs < 5)       { cor='#34d399'; glow='rgba(52,211,153,.18)';  statusTxt='✅  Afinado!'; }
  else if (abs < 15) { cor='#fbbf24'; glow='rgba(251,191,36,.12)';  statusTxt=cents<0?'▲  Apertar um pouco':'▼  Afrouxar um pouco'; }
  else               { cor='#f87171'; glow='rgba(248,113,113,.12)'; statusTxt=cents<0?'▲▲  Apertar bastante':'▼▼  Afrouxar bastante'; }

  // Atualiza UI
  const notaEl = document.getElementById('afinador-nota');
  notaEl.textContent = det.nomeCurto;
  notaEl.style.color = cor;
  notaEl.style.textShadow = `0 0 40px ${cor}80`;

  document.getElementById('afinador-oitava').textContent = `Oitava ${det.oitava}`;
  document.getElementById('afinador-freq').textContent = `${freq.toFixed(1)} Hz`;
  document.getElementById('afinador-cents').textContent = `${cents >= 0 ? '+' : ''}${cents.toFixed(1)} cents`;
  document.getElementById('afinador-status').textContent = statusTxt;
  document.getElementById('afinador-status').style.color = cor;
  document.getElementById('af-glow').style.background = `radial-gradient(ellipse at 50% 80%,${glow} 0%,transparent 70%)`;

  // Ponteiro
  document.getElementById('af-ponteiro-g').style.transform = `rotate(${angulo}deg)`;
  document.getElementById('af-ponta').setAttribute('fill', cor);

  // Corda selecionada
  if (_afCorda) {
    const notaCorda = _afCorda.replace(/\d/,'');
    const btn = document.querySelector(`.af-corda[data-corda="${_afCorda}"]`);
    if (btn && det.nomeCurto === notaCorda) {
      btn.classList.remove('ok','off','sel');
      btn.classList.add(abs < 10 ? 'ok' : 'off');
    } else if (btn) {
      btn.classList.remove('ok','off');
      btn.classList.add('sel');
    }
  }
}

window.abrirAfinador = abrirAfinador;
window.fecharAfinador = fecharAfinador;
window.toggleAfinador = toggleAfinador;
window.selecionarInstrumento = selecionarInstrumento;
window.selecionarCorda = selecionarCorda;
</script>

<!-- ═══ PAD ══════════════════════════════════════════════════════════════════ -->
<div id="modal-pad" style="display:none;position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,.95);backdrop-filter:blur(20px);align-items:flex-end;justify-content:center;" onclick="if(event.target===this)fecharPad()">
  <div style="width:100%;max-width:480px;padding-bottom:env(safe-area-inset-bottom,0);animation:slideUp .35s cubic-bezier(.22,1,.36,1);">

    <!-- Handle -->
    <div style="display:flex;justify-content:center;padding:10px 0 0;">
      <div style="width:36px;height:4px;background:rgba(255,255,255,.15);border-radius:2px;"></div>
    </div>

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px 0;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;background:linear-gradient(135deg,#1a0a2e,#16082e);border:1px solid rgba(139,92,246,.3);border-radius:10px;display:flex;align-items:center;justify-content:center;">
          <svg viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.8" width="18" height="18"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <div>
          <div style="font-size:15px;font-weight:800;color:#fff;letter-spacing:-.3px;">Pad</div>
          <div style="font-size:10px;color:rgba(255,255,255,.35);letter-spacing:1px;text-transform:uppercase;">Worship Synth</div>
        </div>
      </div>
      <button onclick="fecharPad()" style="width:32px;height:32px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08);border-radius:50%;color:rgba(255,255,255,.4);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;">✕</button>
    </div>

    <!-- Display central -->
    <div style="margin:16px 20px 0;background:linear-gradient(180deg,#0a0510 0%,#0d0818 100%);border:1px solid rgba(255,255,255,.06);border-radius:20px;padding:22px 20px 18px;position:relative;overflow:hidden;">
      <div id="pad-glow" style="position:absolute;inset:0;border-radius:20px;background:radial-gradient(ellipse at 50% 80%,rgba(139,92,246,.0) 0%,transparent 70%);transition:background .5s;pointer-events:none;"></div>

      <!-- Nota tocando -->
      <div style="text-align:center;position:relative;z-index:1;margin-bottom:16px;">
        <div id="pad-nota-display" style="font-size:64px;font-weight:900;font-family:var(--font-chord);color:rgba(255,255,255,.15);line-height:1;transition:color .3s,text-shadow .3s;letter-spacing:-2px;">—</div>
        <div id="pad-modo-display" style="font-size:12px;color:rgba(255,255,255,.2);margin-top:2px;transition:color .3s;letter-spacing:1px;text-transform:uppercase;min-height:16px;"></div>
      </div>

      <!-- Visualizador de ondas -->
      <canvas id="pad-canvas" width="400" height="48" style="width:100%;height:48px;border-radius:8px;opacity:.7;display:block;margin-bottom:14px;"></canvas>

      <!-- Volume e reverb -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div>
          <div style="font-size:10px;color:rgba(255,255,255,.3);letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;">Volume</div>
          <input type="range" id="pad-volume" min="0" max="100" value="70" oninput="setPadVolume(this.value)"
            style="width:100%;accent-color:#a78bfa;cursor:pointer;">
        </div>
        <div>
          <div style="font-size:10px;color:rgba(255,255,255,.3);letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;">Reverb</div>
          <input type="range" id="pad-reverb" min="0" max="100" value="60" oninput="setPadReverb(this.value)"
            style="width:100%;accent-color:#a78bfa;cursor:pointer;">
        </div>
      </div>
    </div>

    <!-- Seletor de modo -->
    <div style="padding:12px 20px 0;">
      <div style="font-size:10px;color:rgba(255,255,255,.3);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;">Modo</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;">
        <button class="pad-modo active" data-modo="major" onclick="selecionarModoPad('major',this)">Maior</button>
        <button class="pad-modo" data-modo="minor" onclick="selecionarModoPad('minor',this)">Menor</button>
        <button class="pad-modo" data-modo="sus2" onclick="selecionarModoPad('sus2',this)">Sus2</button>
        <button class="pad-modo" data-modo="sus4" onclick="selecionarModoPad('sus4',this)">Sus4</button>
        <button class="pad-modo" data-modo="maj7" onclick="selecionarModoPad('maj7',this)">Maj7</button>
        <button class="pad-modo" data-modo="min7" onclick="selecionarModoPad('min7',this)">Min7</button>
      </div>
    </div>

    <!-- Teclado de notas -->
    <div style="padding:12px 20px 0;">
      <div id="pad-notas-label" style="font-size:10px;color:rgba(255,255,255,.3);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;">Carregando...</div>
      <div id="pad-notas-grid" style="display:grid;grid-template-columns:repeat(6,1fr);gap:6px;">
        <!-- Preenchido dinamicamente via JS -->
      </div>
    </div>

    <!-- Botão parar -->
    <div style="padding:14px 20px 28px;">
      <button id="btn-pad-parar" onclick="pararPad()" disabled
        style="width:100%;padding:15px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:14px;color:rgba(255,255,255,.3);font-size:15px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:all .3s;letter-spacing:-.2px;">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
        Parar
      </button>
    </div>

  </div>
</div>

<style>
.pad-modo {
  padding: 6px 14px; background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08); color: rgba(255,255,255,.4);
  border-radius: 99px; font-size: 12px; font-weight: 700;
  cursor: pointer; transition: all .15s; white-space: nowrap;
}
.pad-modo.active {
  background: rgba(139,92,246,.15); border-color: rgba(139,92,246,.4); color: #a78bfa;
}
.pad-key {
  padding: 12px 4px; background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08); color: rgba(255,255,255,.6);
  border-radius: 10px; font-size: 13px; font-weight: 800;
  cursor: pointer; font-family: var(--font-chord);
  transition: all .15s; text-align: center;
}
.pad-key:active { transform: scale(.94); }
.pad-key.tocando {
  background: rgba(139,92,246,.2); border-color: rgba(139,92,246,.6);
  color: #c4b5fd; box-shadow: 0 0 16px rgba(139,92,246,.25);
}
</style>

<script>
// ═══ PAD WORSHIP SYNTH ═══════════════════════════════════════════════════════
const PAD_NOTAS_BASE = {
  'C':0,'C#':1,'D':2,'D#':3,'E':4,'F':5,'F#':6,'G':7,'G#':8,'A':9,'A#':10,'B':11
};
// Intervalos em semitons para cada modo
const PAD_MODOS = {
  major: [0,4,7,12,16,19],
  minor: [0,3,7,12,15,19],
  sus2:  [0,2,7,12,14,19],
  sus4:  [0,5,7,12,17,19],
  maj7:  [0,4,7,11,12,16],
  min7:  [0,3,7,10,12,15],
};
const PAD_NOMES_MODO = {
  major:'Maior',minor:'Menor',sus2:'Sus 2',sus4:'Sus 4',maj7:'Maj 7',min7:'Min 7'
};

let _padCtx=null, _padOscs=[], _padGainNode=null, _padReverbNode=null, _padReverbGainMp3=null;
let _padModoAtual='major', _padNotaAtual=null, _padVolume=0.7, _padReverb=0.6;
let _padCanvasRAF=null;
let _padUrls = null;
let _padAudioEl = null;

async function _carregarUrlsPads() {
  if (_padUrls !== null) return _padUrls;
  try {
    const db = window._fbDb;
    if (!db || !window._fbGetDocs || !window._fbCollection) {
      _padUrls = {};
      return _padUrls;
    }
    const snap = await window._fbGetDocs(window._fbCollection(db, 'pads_config'));
    _padUrls = {};
    snap.forEach(d => { if (d.id === 'urls') Object.assign(_padUrls, d.data()); });
    // Filtra só campos de URL (ignora _nome, _size, _ts)
    const notas = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
    const urlsFiltradas = {};
    notas.forEach(n => { if (_padUrls[n]) urlsFiltradas[n] = _padUrls[n]; });
    _padUrls = urlsFiltradas;
  } catch(e) {
    console.warn('[pad] Erro ao carregar URLs:', e.message);
    _padUrls = {};
  }
  return _padUrls;
}

function _setPadDot(ativo) {
  const dot = document.getElementById('nav-pad-dot');
  const btn = document.getElementById('nav-pad-btn');
  if (dot) dot.style.display = ativo ? 'block' : 'none';
  if (btn) btn.style.color = ativo ? '#a78bfa' : '';
}

function togglePadNavBtn() {
  // Se pad está tocando → para e fecha
  if (_padNotaAtual) {
    pararPad();
    return;
  }
  // Se modal está aberto → fecha sem parar
  const modal = document.getElementById('modal-pad');
  if (modal && modal.style.display !== 'none') {
    modal.style.display = 'none';
    return;
  }
  // Abre o modal
  abrirPad();
}

function abrirPad() {
  document.getElementById('modal-pad').style.display = 'flex';
  _padUrls = null;
  _renderNotasPad();
}

async function _renderNotasPad() {
  const grid = document.getElementById('pad-notas-grid');
  const label = document.getElementById('pad-notas-label');
  if (!grid) return;

  label.textContent = 'Carregando...';
  grid.innerHTML = '<div style="color:rgba(255,255,255,.2);font-size:12px;grid-column:span 6;text-align:center;padding:8px;">⏳</div>';

  const urls = await _carregarUrlsPads();
  const TODAS = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
  const disponiveis = TODAS.filter(n => urls && urls[n]);

  if (!disponiveis.length) {
    label.textContent = 'Nenhum pad disponível';
    grid.innerHTML = '<div style="color:rgba(255,255,255,.25);font-size:12px;grid-column:span 6;text-align:center;padding:12px;">Nenhum pad enviado pelo admin ainda.</div>';
    return;
  }

  label.textContent = `Nota — ${disponiveis.length} tom${disponiveis.length !== 1 ? 's' : ''} disponível${disponiveis.length !== 1 ? 'is' : ''}`;
  // Ajusta colunas conforme quantidade
  const cols = disponiveis.length <= 4 ? disponiveis.length : disponiveis.length <= 6 ? 3 : 4;
  grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
  grid.innerHTML = disponiveis.map(n => `
    <button class="pad-key" data-nota="${n}" onclick="tocarPad('${n}',this)">${n}</button>
  `).join('');
}
function fecharPad() {
  // Só fecha o modal — o pad continua tocando em background
  document.getElementById('modal-pad').style.display = 'none';
}

function selecionarModoPad(modo, btn) {
  _padModoAtual = modo;
  document.querySelectorAll('.pad-modo').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  // Só reinicia se estiver no sintetizador (MP3 não usa modo)
  if (_padNotaAtual && !_padAudioEl) {
    tocarPad(_padNotaAtual, document.querySelector(`.pad-key[data-nota="${_padNotaAtual}"]`));
  }
}

function setPadVolume(v) {
  _padVolume = v / 100;
  // MP3
  if (_padAudioEl) _padAudioEl.volume = Math.min(1, _padVolume * 0.85);
  // Sintetizador
  if (_padGainNode && _padCtx) _padGainNode.gain.setTargetAtTime(_padVolume * 0.4, _padCtx.currentTime, 0.1);
}

function setPadReverb(v) {
  _padReverb = v / 100;
  // MP3 — reverb via Web Audio
  if (_padReverbGainMp3) _padReverbGainMp3.gain.setTargetAtTime(_padReverb * 0.7, _padCtx.currentTime, 0.1);
  // Sintetizador
  if (_padReverbNode && _padCtx) _padReverbNode.gain.setTargetAtTime(_padReverb, _padCtx.currentTime, 0.1);
}

// Cria impulso de reverb sintético (convolver)
function _criarReverb(ctx) {
  const duracao = 4, decay = 3, taxa = ctx.sampleRate;
  const tam = taxa * duracao;
  const buf = ctx.createBuffer(2, tam, taxa);
  for (let c = 0; c < 2; c++) {
    const data = buf.getChannelData(c);
    for (let i = 0; i < tam; i++) {
      data[i] = (Math.random()*2-1) * Math.pow(1 - i/tam, decay);
    }
  }
  const conv = ctx.createConvolver();
  conv.buffer = buf;
  return conv;
}

async function tocarPad(nota, btn) {
  // Para tudo que estiver tocando com crossfade
  if (_padOscs.length > 0 || _padAudioEl) {
    _fadeOutPad(1.5);
    await new Promise(r => setTimeout(r, 300));
  }

  _padNotaAtual = nota;
  _setPadDot(true); // acende indicador na navbar
  document.querySelectorAll('.pad-key').forEach(b => b.classList.remove('tocando'));
  if (btn) btn.classList.add('tocando');

  // Atualiza display
  const notaEl = document.getElementById('pad-nota-display');
  const modoEl = document.getElementById('pad-modo-display');
  notaEl.textContent = nota;
  notaEl.style.color = '#c4b5fd';
  notaEl.style.textShadow = '0 0 40px rgba(139,92,246,.6)';
  document.getElementById('pad-glow').style.background = 'radial-gradient(ellipse at 50% 80%,rgba(139,92,246,.2) 0%,transparent 70%)';
  const btnParar = document.getElementById('btn-pad-parar');
  btnParar.disabled = false;
  btnParar.style.background = 'rgba(139,92,246,.15)';
  btnParar.style.borderColor = 'rgba(139,92,246,.4)';
  btnParar.style.color = '#c4b5fd';

  // Verifica se tem MP3 gravado no Firebase
  const urls = await _carregarUrlsPads();
  const urlMp3 = urls && urls[nota];

  if (urlMp3) {
    // ── MODO MP3 ──────────────────────────────────────────────────────────────
    modoEl.textContent = '🎵 Pad gravado';
    modoEl.style.color = 'rgba(52,211,153,.8)';
    _tocarPadMp3(nota, urlMp3);
  } else {
    // ── MODO SINTETIZADOR (fallback) ──────────────────────────────────────────
    modoEl.textContent = PAD_NOMES_MODO[_padModoAtual] + ' · Sintetizador';
    modoEl.style.color = 'rgba(139,92,246,.8)';
    _tocarPadSintetizador(nota);
  }
}

async function _tocarPadMp3(nota, url) {
  // Para sintetizador se estava rodando
  if (_padOscs.length) {
    _padOscs.forEach(({ osc }) => { try { osc.stop(); } catch(e){} });
    _padOscs = [];
  }

  // Para áudio anterior
  if (_padAudioEl) {
    _padAudioEl.pause();
    _padAudioEl = null;
  }

  const audio = new Audio();
  audio.src = url;
  audio.loop = true;
  audio.volume = 0;
  audio.crossOrigin = 'anonymous';
  _padAudioEl = audio;

  try {
    await audio.play();
    // Fade in suave — 5 segundos
    const alvo = _padVolume * 0.85;
    const passos = 50, intervalo = 100;
    const increment = alvo / passos;
    let step = 0;
    const fadeIn = setInterval(() => {
      step++;
      audio.volume = Math.min(alvo, increment * step);
      if (step >= passos) clearInterval(fadeIn);
    }, intervalo);

    // Visualizador usando Web Audio conectado ao elemento
    if (!_padCtx || _padCtx.state === 'closed') {
      _padCtx = new (window.AudioContext || window.webkitAudioContext)();
    }
    if (_padCtx.state === 'suspended') await _padCtx.resume();
    const src = _padCtx.createMediaElementSource(audio);
    const va = _padCtx.createAnalyser();
    va.fftSize = 512;

    // Reverb para o MP3
    const reverb = _criarReverb(_padCtx);
    const reverbGain = _padCtx.createGain();
    reverbGain.gain.value = _padReverb * 0.7;
    _padReverbGainMp3 = reverbGain;

    // Grafo: src → analyser → dry out + reverb out
    src.connect(va);
    src.connect(_padCtx.destination);       // sinal seco
    src.connect(reverb);
    reverb.connect(reverbGain);
    reverbGain.connect(_padCtx.destination); // sinal com reverb

    _padCtx._visAnalyser = va;
    _padDesenharCanvas();

  } catch(e) {
    console.warn('[pad] Erro ao tocar MP3, usando sintetizador:', e.message);
    _padAudioEl = null;
    _tocarPadSintetizador(nota);
  }
}

async function _tocarPadSintetizador(nota) {
  if (!_padCtx || _padCtx.state === 'closed') {
    _padCtx = new (window.AudioContext || window.webkitAudioContext)();
  }
  if (_padCtx.state === 'suspended') await _padCtx.resume();

  const masterGain = _padCtx.createGain();
  masterGain.gain.setValueAtTime(0, _padCtx.currentTime);
  masterGain.gain.linearRampToValueAtTime(_padVolume * 0.35, _padCtx.currentTime + 6);
  _padGainNode = masterGain;

  const reverb = _criarReverb(_padCtx);
  const reverbGain = _padCtx.createGain();
  reverbGain.gain.value = _padReverb;
  _padReverbNode = reverbGain;

  const filtro = _padCtx.createBiquadFilter();
  filtro.type = 'lowpass';
  filtro.frequency.setValueAtTime(800, _padCtx.currentTime);
  filtro.frequency.linearRampToValueAtTime(2800, _padCtx.currentTime + 5);
  filtro.Q.value = 0.6;

  const comp = _padCtx.createDynamicsCompressor();
  comp.threshold.value = -18; comp.ratio.value = 4;
  comp.attack.value = 0.3; comp.release.value = 1.0;

  masterGain.connect(filtro);
  filtro.connect(comp);
  comp.connect(reverb);
  reverb.connect(reverbGain);
  reverbGain.connect(_padCtx.destination);
  comp.connect(_padCtx.destination);

  const semiBase = PAD_NOTAS_BASE[nota];
  const freqBase = 440 * Math.pow(2, (semiBase - 9) / 12) / 2;
  const oscs = [];

  PAD_MODOS[_padModoAtual].forEach(semitom => {
    [
      { oitava: 0, tipo: 'sine',     gain: 0.5 },
      { oitava: 0, tipo: 'triangle', gain: 0.18 },
      { oitava: 1, tipo: 'sine',     gain: 0.28 },
      { oitava:-1, tipo: 'sine',     gain: 0.12 },
    ].forEach(cam => {
      const osc = _padCtx.createOscillator();
      const oscGain = _padCtx.createGain();
      const delay = Math.random() * 1.5;
      oscGain.gain.setValueAtTime(0, _padCtx.currentTime + delay);
      oscGain.gain.linearRampToValueAtTime(cam.gain / PAD_MODOS[_padModoAtual].length, _padCtx.currentTime + delay + 4);
      osc.frequency.value = freqBase * Math.pow(2, (semitom + cam.oitava * 12) / 12);
      osc.detune.value = (Math.random() - 0.5) * 10;
      osc.type = cam.tipo;
      osc.connect(oscGain);
      oscGain.connect(masterGain);
      osc.start(_padCtx.currentTime + delay);
      oscs.push({ osc, gain: oscGain });
    });
  });

  _padOscs = oscs;
  _padDesenharCanvas();
}

async function _fadeOutPad(duracao = 3) {
  // Fade out do MP3
  if (_padAudioEl) {
    const audio = _padAudioEl;
    _padAudioEl = null;
    const vol = audio.volume;
    const passos = 30, intervalo = (duracao * 1000) / passos;
    const decrement = vol / passos;
    let step = 0;
    const fadeOut = setInterval(() => {
      step++;
      audio.volume = Math.max(0, vol - decrement * step);
      if (step >= passos) { clearInterval(fadeOut); audio.pause(); }
    }, intervalo);
  }
  // Fade out do sintetizador
  if (!_padGainNode || !_padCtx) return;
  _padGainNode.gain.setTargetAtTime(0, _padCtx.currentTime, duracao / 6);
  const oscsParaParar = [..._padOscs];
  _padOscs = [];
  setTimeout(() => {
    oscsParaParar.forEach(({ osc }) => { try { osc.stop(); } catch(e){} });
  }, duracao * 1000 + 500);
}

async function pararPad() {
  if (_padCanvasRAF) { cancelAnimationFrame(_padCanvasRAF); _padCanvasRAF = null; }

  // Para MP3
  if (_padAudioEl) {
    const audio = _padAudioEl;
    _padAudioEl = null;
    const vol = audio.volume;
    const passos = 40, intervalo = 100;
    const decrement = vol / passos;
    let step = 0;
    const fadeOut = setInterval(() => {
      step++;
      audio.volume = Math.max(0, vol - decrement * step);
      if (step >= passos) { clearInterval(fadeOut); audio.pause(); }
    }, intervalo);
  }

  // Para sintetizador
  if (_padGainNode && _padCtx) {
    _padGainNode.gain.setTargetAtTime(0, _padCtx.currentTime, 0.8);
    const oscsParaParar = [..._padOscs];
    _padOscs = [];
    setTimeout(() => {
      oscsParaParar.forEach(({ osc }) => { try { osc.stop(); } catch(e){} });
      if (_padCtx) _padCtx.close().catch(()=>{});
      _padCtx = null;
    }, 5000);
  }
  _padNotaAtual = null;
  _setPadDot(false); // apaga indicador na navbar
  document.querySelectorAll('.pad-key').forEach(b => b.classList.remove('tocando'));
  const notaEl = document.getElementById('pad-nota-display');
  notaEl.textContent = '—';
  notaEl.style.color = 'rgba(255,255,255,.15)';
  notaEl.style.textShadow = 'none';
  document.getElementById('pad-modo-display').textContent = '';
  document.getElementById('pad-glow').style.background = 'radial-gradient(ellipse at 50% 80%,rgba(139,92,246,.0) 0%,transparent 70%)';

  const btnParar = document.getElementById('btn-pad-parar');
  btnParar.disabled = true;
  btnParar.style.background = 'rgba(255,255,255,.05)';
  btnParar.style.borderColor = 'rgba(255,255,255,.1)';
  btnParar.style.color = 'rgba(255,255,255,.3)';

  // Limpa canvas
  const canvas = document.getElementById('pad-canvas');
  const ctx2d = canvas.getContext('2d');
  ctx2d.clearRect(0, 0, canvas.width, canvas.height);
}

function _padDesenharCanvas() {
  const canvas = document.getElementById('pad-canvas');
  if (!canvas || !_padCtx || !_padOscs.length) return;
  const ctx2d = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;

  // Cria analyser para visualização
  if (!_padCtx._visAnalyser) {
    const va = _padCtx.createAnalyser();
    va.fftSize = 512;
    if (_padGainNode) _padGainNode.connect(va);
    _padCtx._visAnalyser = va;
  }
  const va = _padCtx._visAnalyser;
  const buf = new Uint8Array(va.frequencyBinCount);

  function draw() {
    if (!_padOscs.length || !_padCtx) return;
    _padCanvasRAF = requestAnimationFrame(draw);
    va.getByteTimeDomainData(buf);

    ctx2d.clearRect(0, 0, W, H);
    ctx2d.beginPath();
    ctx2d.strokeStyle = 'rgba(167,139,250,.6)';
    ctx2d.lineWidth = 1.5;
    ctx2d.shadowColor = 'rgba(139,92,246,.4)';
    ctx2d.shadowBlur = 6;

    const sl = W / buf.length;
    let x = 0;
    for (let i = 0; i < buf.length; i++) {
      const v = buf[i] / 128;
      const y = v * H / 2;
      i === 0 ? ctx2d.moveTo(x, y) : ctx2d.lineTo(x, y);
      x += sl;
    }
    ctx2d.stroke();
  }
  draw();
}

window.abrirPad = abrirPad;
window.fecharPad = fecharPad;
window.togglePadNavBtn = togglePadNavBtn;
window.tocarPad = tocarPad;
window.pararPad = pararPad;
window.selecionarModoPad = selecionarModoPad;
window.setPadVolume = setPadVolume;
window.setPadReverb = setPadReverb;
</script>

</body>
</html>
