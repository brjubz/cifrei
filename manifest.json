function handleRefresh() {
  if (document.getElementById('view-banco').classList.contains('active')) {
    // Invalida cache para forçar busca da rede
    try { localStorage.removeItem(BANCO_CACHE_KEY); localStorage.removeItem(BANCO_CACHE_TS); } catch(e) {}
    S.bancoCarregado = false;
    S.banco = [];
    carregarBanco().then(() => showToast('Banco atualizado!'));
  } else {
    recarregar();
  }
}

async function recarregar(){
  try{
    const oldTp = {};
    S.songs.forEach(s => oldTp[s.title] = s.tp);
    const txt = await fetchTxt(GIST_ID_SETLIST);
    S.songs = parseSongs(txt);
    S.songs.forEach(s => { if(oldTp[s.title] !== undefined) s.tp = oldTp[s.title]; });
    // Invalida cache do banco para pegar dados frescos
    try { localStorage.removeItem(BANCO_CACHE_KEY); localStorage.removeItem(BANCO_CACHE_TS); } catch(e) {}
    S.bancoCarregado = false;
    S.banco = [];
    renderList();
    document.getElementById('nav-cnt').textContent = S.songs.length;
    showView('list');
    showToast('Repertório atualizado!');
    // Recarrega banco em background para enriquecer com artista/links
    _carregarBancoSilencioso();
  }catch(e){alert('Erro: '+e.message);}
}

// Cruza S.songs com S.banco para preencher s.letra, s.verified e s.artist quando o banco carregar
function _enriquecerSetlistComLetras() {
  if (!S.banco.length || !S.songs.length) return;
  let mudou = false;
  S.songs.forEach(s => {
    const orig = S.banco.find(b => b.title.toLowerCase() === s.title.toLowerCase());
    if (!orig) return;
    // Sempre sobrescreve com dados do banco — garante que edições no admin chegam aqui
    if (orig.content  && s.content  !== orig.content)  { s.content  = orig.content;  mudou = true; }
    if (orig.letra    && s.letra    !== orig.letra)    { s.letra    = orig.letra;    mudou = true; }
    if (orig.verified && !s.verified)                  { s.verified = true;          mudou = true; }
    if (orig.artist   && s.artist   !== orig.artist)   { s.artist   = orig.artist;   mudou = true; }
    if (orig.linkYT   && s.linkYT   !== orig.linkYT)   { s.linkYT   = orig.linkYT;   mudou = true; }
    if (orig.linkSP   && s.linkSP   !== orig.linkSP)   { s.linkSP   = orig.linkSP;   mudou = true; }
    // Atualiza tom se o banco tiver tom diferente
    if (orig.key && orig.key !== '-' && s.key !== orig.key && s.tp === 0) { s.key = orig.key; mudou = true; }
  });
  if (mudou || S.banco.length) {
    if (document.getElementById('view-list')?.classList.contains('active')) renderList();
    if (document.getElementById('view-reader')?.classList.contains('active')) renderReader();
    if (_modoVocal && S.idx >= 0 && S.songs[S.idx]?.letra) renderLetra(S.songs[S.idx].letra);
  }
}

// Carrega o banco em background só para ter as letras disponíveis (sem renderizar)
// ── CACHE DO BANCO ────────────────────────────────────────────────────────────
const BANCO_CACHE_KEY = 'cifrei_banco_raw';
const BANCO_CACHE_TS  = 'cifrei_banco_ts';
const BANCO_CACHE_TTL = 24 * 60 * 60 * 1000; // 24 horas

function _salvarCacheBanco(txt) {
  try {
    localStorage.setItem(BANCO_CACHE_KEY, txt);
    localStorage.setItem(BANCO_CACHE_TS, Date.now().toString());
  } catch(e) { /* localStorage cheio — ignora */ }
}

function _lerCacheBanco() {
  try {
    const txt = localStorage.getItem(BANCO_CACHE_KEY);
    const ts  = parseInt(localStorage.getItem(BANCO_CACHE_TS) || '0');
    if (!txt || !ts) return null;
    return { txt, ts, expirado: Date.now() - ts > BANCO_CACHE_TTL };
  } catch(e) { return null; }
}

function _aplicarBancoRaw(txt) {
  S._bancoRaw = txt;
  // Usa parseSongs completo (não parseSongsRapido) para ter cifra/content disponível
  const raw = parseSongs(txt);
  const vistos = new Set();
  S.banco = [];
  for (const s of raw) {
    const k = s.title.toLowerCase().trim();
    if (!vistos.has(k)) { vistos.add(k); S.banco.push(s); }
  }
  S.banco.sort((a,b) => a.title.localeCompare(b.title,'pt'));
  S.bancoFiltrado = S.banco;
  S.bancoCarregado = true;
}

async function _carregarBancoSilencioso() {
  if (S.bancoCarregado) { _enriquecerSetlistComLetras(); return; }

  // Tenta cache primeiro — se válido, aplica imediatamente sem network
  const cache = _lerCacheBanco();
  if (cache && !cache.expirado) {
    _aplicarBancoRaw(cache.txt);
    _enriquecerSetlistComLetras();
    if (document.getElementById('view-banco')?.classList.contains('active')) {
      const cntEl = document.getElementById('banco-cnt-txt');
      if (cntEl) cntEl.textContent = S.banco.length + ' músicas';
      renderBanco(S.bancoFiltrado, true);
    }
    return; // cache fresco — não precisa buscar da rede
  }

  // Cache expirado ou inexistente — busca da rede
  _setConnStatus('syncing');
  try {
    const txt = await Promise.race([
      fetchTxt(GIST_ID_BANCO),
      new Promise((_, rej) => setTimeout(() => rej(new Error('Timeout silencioso')), 10000))
    ]);
    _aplicarBancoRaw(txt);
    _salvarCacheBanco(txt);
    _enriquecerSetlistComLetras();
    if (document.getElementById('view-banco')?.classList.contains('active')) {
      const cntEl = document.getElementById('banco-cnt-txt');
      if (cntEl) cntEl.textContent = S.banco.length + ' músicas';
      renderBanco(S.bancoFiltrado, true);
    }
    _setConnStatus('online');
  } catch(e) {
    // Se falhou mas tem cache (mesmo expirado), usa ele
    if (cache?.txt) {
      _aplicarBancoRaw(cache.txt);
      _enriquecerSetlistComLetras();
      if (document.getElementById('view-banco')?.classList.contains('active')) {
        const cntEl = document.getElementById('banco-cnt-txt');
        if (cntEl) cntEl.textContent = S.banco.length + ' músicas (cache)';
        renderBanco(S.bancoFiltrado, true);
      }
    }
    if (!navigator.onLine) _setConnStatus('offline');
  }
}

async function carregarBanco(){
  const cntEl = document.getElementById('banco-cnt-txt');
  const listEl = document.getElementById('banco-list');

  // Histórico sempre carrega ao abrir o banco (independente de cache ou rede)
  carregarHistoricoBanco();

  // Se banco já em memória — usa direto
  if (S.bancoCarregado && S.banco.length) {
    S.bancoFiltrado = S.banco;
    if (cntEl) cntEl.textContent = S.banco.length + ' músicas';
    renderBanco(S.bancoFiltrado, true);
    return;
  }

  // Tenta cache — mostra imediatamente e busca atualização em background
  const cache = _lerCacheBanco();
  if (cache?.txt) {
    _aplicarBancoRaw(cache.txt);
    if (cntEl) cntEl.textContent = S.banco.length + ' músicas';
    renderBanco(S.bancoFiltrado, true);

    // Se cache fresco (< 24h), não precisa buscar da rede
    if (!cache.expirado) return;

    // Cache expirado — atualiza em background sem travar a UI
    if (cntEl) cntEl.textContent = S.banco.length + ' músicas · atualizando...';
    fetchTxt(GIST_ID_BANCO).then(txt => {
      _aplicarBancoRaw(txt);
      _salvarCacheBanco(txt);
      if (cntEl) cntEl.textContent = S.banco.length + ' músicas';
      renderBanco(S.bancoFiltrado, true);
      _enriquecerSetlistComLetras();
    }).catch(() => {
      if (cntEl) cntEl.textContent = S.banco.length + ' músicas (offline)';
    });
    return;
  }

  // Sem cache — carregamento normal com spinner
  if (cntEl) cntEl.textContent = 'Carregando...';
  if (listEl) listEl.innerHTML = `
    <div style="text-align:center;padding:40px 16px;color:var(--faint);font-size:13px;">
      <div style="margin-bottom:12px;">⏳ Baixando banco de músicas...</div>
      <div style="font-size:11px;opacity:.6;">Pode levar alguns segundos</div>
    </div>`;

  try {
    const txt = await Promise.race([
      fetchTxt(GIST_ID_BANCO),
      new Promise((_, rej) => setTimeout(() => rej(new Error('Conexão lenta. Tente novamente.')), 8000))
    ]);
    _aplicarBancoRaw(txt);
    _salvarCacheBanco(txt);
    if (cntEl) cntEl.textContent = S.banco.length + ' músicas';
    renderBanco(S.bancoFiltrado, true);
    _enriquecerSetlistComLetras();
    carregarHistoricoBanco();
  } catch(e) {
    console.error('carregarBanco falhou:', e.message);
    if (cntEl) cntEl.textContent = 'Erro ao carregar';
    if (listEl) listEl.innerHTML = `
      <div style="text-align:center;padding:32px 16px;display:flex;flex-direction:column;align-items:center;gap:12px;">
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--faint)" stroke-width="1.5" width="40" height="40"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div style="font-size:13px;color:var(--muted);">${e.message}</div>
        <button onclick="carregarBanco()" style="background:var(--green);color:#000;border:none;border-radius:10px;padding:10px 20px;font-size:13px;font-weight:800;cursor:pointer;">↻ Tentar novamente</button>
      </div>`;
  }
}

function filtrarBanco(){
  const q=document.getElementById('search-input').value.toLowerCase().trim();
  S.bancoFiltrado=q?S.banco.filter(s=>s.title.toLowerCase().includes(q)):S.banco;
  renderBanco(S.bancoFiltrado, true); // reset para página 1 ao filtrar
}

let _bancoPagina = 0;
const _BANCO_POR_PAGINA = 30;

function renderBanco(list, reset){
  if (reset) _bancoPagina = 0;
  const c=document.getElementById('banco-list');
  if (reset) c.innerHTML='';
  if(!list.length){c.innerHTML='<div class="banco-empty">Nenhuma música encontrada.</div>';return;}

  const inicio = _bancoPagina * _BANCO_POR_PAGINA;
  const fatia = list.slice(inicio, inicio + _BANCO_POR_PAGINA);
  const votos = getVotos();

  // Remove botão "Ver mais" anterior se existir
  const btnAnterior = c.querySelector('.banco-ver-mais');
  if (btnAnterior) btnAnterior.remove();

  fatia.forEach(s=>{
    const jaNoSetlist=S.songs.some(x=>x.title===s.title);
    const voted = !!votos[s.title];
    const el=document.createElement('div');el.className='banco-item';
    el.innerHTML=`
      <div class="banco-info" onclick="abrirPreview('${esc(s.title).replace(/'/g,"\\'")}')">
        <div class="banco-title">
          ${esc(s.title)}
          ${s.verified?VERIFIED_SVG:''}
        </div>
        <div class="banco-key">${s.artist ? esc(s.artist) : ''}</div>
      </div>
      <div class="banco-actions">
        <button class="vote-btn ${voted?'voted':''}" onclick="toggleVoto('${esc(s.title).replace(/'/g,"\\'")}');event.stopPropagation();" title="${voted?'Remover curtida':'Curtir música'}">
          ${voted?'❤️':'🤍'}
        </button>
        <button class="preview-btn" onclick="abrirPreview('${esc(s.title).replace(/'/g,"\\'")}')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          Ver
        </button>
        <button class="add-setlist-btn ${jaNoSetlist?'added':''}" onclick="adicionarAoSetlist('${esc(s.title).replace(/'/g,"\\'")}')">
          ${jaNoSetlist
            ?`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="13" height="13"><polyline points="20 6 9 17 4 12"/></svg> Add`
            :`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="13" height="13"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Add`
          }
        </button>
      </div>`;
    c.appendChild(el);
  });

  // Botão "Ver mais" se tiver próxima página
  const totalMostrado = inicio + fatia.length;
  if (totalMostrado < list.length) {
    const resto = list.length - totalMostrado;
    const btn = document.createElement('button');
    btn.className = 'banco-ver-mais';
    btn.style.cssText = 'width:100%;padding:12px;background:var(--bg3);border:1px solid var(--bg4);color:var(--muted);border-radius:12px;cursor:pointer;font-size:13px;font-weight:700;margin-top:4px;';
    btn.textContent = `Ver mais ${Math.min(resto, _BANCO_POR_PAGINA)} de ${resto} músicas`;
    btn.onclick = () => { _bancoPagina++; renderBanco(list, false); };
    c.appendChild(btn);
  } else if (list.length > _BANCO_POR_PAGINA) {
    // Mostra total quando carregou tudo
    const info = document.createElement('div');
    info.style.cssText = 'text-align:center;font-size:11px;color:var(--faint);padding:10px;';
    info.textContent = `✓ Todas as ${list.length} músicas carregadas`;
    c.appendChild(info);
  }
}

// Token ofuscado — mesma lógica do admin
function _getGistToken() {
  const salvo = localStorage.getItem('adm_token');
  if (salvo) return salvo;
  const t = [[103,104,112,95,121,76,77,72,84,52],[76,77,119,78,54,113,121,115,108,117],[57,48,69,54,70,55,55,97,87,121],[100,48,51,56,49,54,115,69,103,102]].map(p=>String.fromCharCode(...p)).join('');
  if (t) localStorage.setItem('adm_token', t);
  return t;
}
const _GIST_TOKEN   = _getGistToken();
const _GIST_SETLIST = '4ddc9a95ef4e523dcafff049a31caeb2';

async function _gravarNoGist(conteudo) {
  const token = _getGistToken();
  if (!token) { console.error('[setlist] Token não disponível'); return false; }
  try {
    const meta = await fetch(`https://api.github.com/gists/${_GIST_SETLIST}`,
      { headers: { Authorization: `token ${token}` } });
    const data = await meta.json();
    const filename = Object.keys(data.files || {})[0] || 'setlist.txt';
    const res = await fetch(`https://api.github.com/gists/${_GIST_SETLIST}`, {
      method: 'PATCH',
      headers: { Authorization: `token ${token}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ files: { [filename]: { content: conteudo } } })
    });
    return res.ok;
  } catch(e) { console.warn('Erro ao gravar Gist:', e.message); return false; }
}

async function _publicarMudancaSetlist() {
  if (!fbDb) {
    let t = 0;
    while (!fbDb && t++ < 6) await new Promise(r => setTimeout(r, 500));
    if (!fbDb) return;
  }
  const conteudo = S.songs.map(s => {
    const tpTag = s.tp && s.tp !== 0 ? `[tp:${s.tp}]\n` : '';

    // verified: usa o do objeto OU consulta o banco como fallback
    const isVerified = s.verified ||
      S.banco.find(b => b.title.toLowerCase() === s.title.toLowerCase())?.verified ||
      false;
    const title = isVerified ? `${s.title} (verificado)` : s.title;
    // Mantém verified no objeto para renderização imediata
    if (isVerified && !s.verified) s.verified = true;

    // Garante content — busca no banco ou no raw se não carregado ainda
    let content = s.content;
    if (!content) {
      const orig = S.banco.find(b => b.title.toLowerCase() === s.title.toLowerCase());
      if (orig?.content) content = orig.content;
    }
    if (!content && S._bancoRaw) {
      const dados = _extrairConteudoMusica(S._bancoRaw, s.title);
      if (dados?.content) { content = dados.content; s.content = content; }
    }
    if (!content) content = '(cifra pendente)';

    // Garante letra
    let letra = s.letra;
    if (!letra) {
      const orig = S.banco.find(b => b.title.toLowerCase() === s.title.toLowerCase());
      if (orig?.letra) letra = orig.letra;
    }

    const letraBlock = letra?.trim() ? `\n[LETRA]\n${letra.trim()}\n[/LETRA]` : '';
    return `${title}\n${tpTag}${content}${letraBlock}\n\n--END--`;
  }).join('\n');

  // 1. Firebase PRIMEIRO — mais rápido e é o que o F5 lê
  if (window._fbDoc && window._fbSetDoc) {
    try {
      await window._fbSetDoc(window._fbDoc(fbDb, 'salas', 'setlist_musico'), {
        setlistContent: conteudo, autor: fbUser?.uid, ts: Date.now()
      });
      await window._fbSetDoc(window._fbDoc(fbDb, 'salas', 'setlist_sync'), {
        setlistContent: conteudo, autor: fbUser?.uid, ts: Date.now()
      });
    } catch(e) { console.warn('Firebase setlist:', e.message); }
  }

  // 2. Gist em background — fonte permanente (não bloqueia o retorno)
  _gravarNoGist(conteudo);
}

async function adicionarAoSetlist(title){
  const song=S.banco.find(s=>s.title===title);
  if(!song)return;
  if(S.songs.some(s=>s.title===title)){showToast('Já está no setlist!');return;}

  // Garante content antes de adicionar
  if (!song.content) {
    if (S._bancoRaw) {
      const dados = _extrairConteudoMusica(S._bancoRaw, title);
      if (dados) { song.content = dados.content; song.letra = dados.letra; }
    }
    if (!song.content) {
      try {
        S._bancoRaw = await fetchTxt(GIST_ID_BANCO);
        const dados = _extrairConteudoMusica(S._bancoRaw, title);
        if (dados) { song.content = dados.content; song.letra = dados.letra; }
      } catch(e) {}
    }
    if (!song.content) song.content = '(cifra pendente)';
  }

  S.songs.push({...song});
  renderList();
  document.getElementById('nav-cnt').textContent=S.songs.length;
  renderBanco(S.bancoFiltrado);
  await _publicarMudancaSetlist();
  showToast('Adicionado ao setlist ✓');
}

async function abrirPreview(title) {
  const song = S.banco.find(s => s.title === title);
  if(!song) return;

  S.preview = song;
  stopScroll();
  S.tp = 0;
  document.getElementById('tp-val').textContent = '0';

  // Sempre extrai content antes de mostrar
  if (!song.content) {
    // Tenta do raw
    if (S._bancoRaw) {
      const dados = _extrairConteudoMusica(S._bancoRaw, title);
      if (dados) { song.content = dados.content; song.letra = dados.letra; }
    }
    // Força download se ainda sem content
    if (!song.content) {
      showView('reader');
      const cifraEl = document.getElementById('cifra');
      if (cifraEl) cifraEl.innerHTML = '<div style="color:var(--faint);padding:20px;text-align:center;">⏳ Carregando...</div>';
      try {
        S._bancoRaw = await fetchTxt(GIST_ID_BANCO);
        const dados = _extrairConteudoMusica(S._bancoRaw, title);
        if (dados) { song.content = dados.content; song.letra = dados.letra; }
      } catch(e) {
        if (cifraEl) cifraEl.innerHTML = '<div style="color:var(--faint);padding:20px;text-align:center;">Erro ao carregar cifra</div>';
        return;
      }
    }
  }

  console.log('[preview] title:', title, '| content length:', song.content?.length, '| primeira linha:', song.content?.split('\n')[0]);
  showView('reader');
  renderReader();
}

function addPreviewToSetlist() {
  if(!S.preview) return;
  const jaNoSetlist = S.songs.some(s => s.title === S.preview.title);
  if (jaNoSetlist) { showToast('Já está no setlist!'); return; }
  S.songs.push({...S.preview});
  renderList();
  document.getElementById('nav-cnt').textContent = S.songs.length;
  renderBanco(S.bancoFiltrado);
  showToast('Adicionado ao setlist ✓');
  const btn = document.getElementById('preview-add-fab');
  btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="20" height="20"><polyline points="20 6 9 17 4 12"/></svg>';
  btn.style.background = 'var(--green)';
  btn.style.color = '#000';
}

function showView(n){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById('view-'+n).classList.add('active');
  if(n!=='reader')stopScroll();
  if(n==='banco'&&!S.bancoCarregado)carregarBanco();
  if(n==='sono') _renderSonoSetlist();
  window.scrollTo({top:0,behavior:'smooth'});
  const isBanco = n === 'banco' || (n === 'reader' && S.preview);
  const isList = n === 'list' || (n === 'reader' && !S.preview);
  document.getElementById('nav-banco-btn').classList.toggle('active', isBanco);
  document.getElementById('nav-list-btn').classList.toggle('active', isList);
  if(n !== 'reader') {
    document.getElementById('finalizar-louvor-bar').classList.remove('visible');
    pausarTimers();
  }
  history.pushState({ view: n }, '');
}

window.addEventListener('popstate', (e) => {
  const view = e.state?.view;
  if (view === 'reader') { voltarLista(); return; }
  if (view === 'banco')  { voltarLista(); return; }
  if (view === 'list')   {
    const app = document.getElementById('app');
    if (app && app.style.display !== 'none') { voltarHome(); return; }
  }
  // Se não há estado conhecido, empurra um novo para não sair
  history.pushState({ view: 'list' }, '');
});

function voltarLista(){
  stopScroll();
  // Se estava no reader, fecha a sala
  if (document.getElementById('view-reader')?.classList.contains('active')) {
    fecharMinhaSala();
    sairDaSala(false);
    _atualizarFabSala(false);
  }
  showView('list');
  renderList();
}
function voltarHome(){
  stopScroll();
  releaseWakeLock();
  pausarTimers();
  const app = document.getElementById('app');
  const nav = document.getElementById('main-nav');
  app.style.animation = 'fadeOut 0.2s ease forwards';
  nav.style.animation = 'fadeOut 0.2s ease forwards';
  setTimeout(() => {
    app.style.display='none';
    app.style.animation = '';
    nav.classList.remove('show');
    nav.style.animation = '';
    document.getElementById('finalizar-louvor-bar').classList.remove('visible');
    const splash = document.getElementById('splash');
    splash.style.display='flex';
    splash.style.animation = 'fadeInUp 0.4s ease forwards';
  }, 200);
}

