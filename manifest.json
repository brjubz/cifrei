// ── SISTEMA DE GESTO "SWIPE" ──
let tsX = 0, tsY = 0;
document.addEventListener('DOMContentLoaded', () => {
  const gArea = document.getElementById('gesture-area');
  gArea.addEventListener('touchstart', e => {
    tsX = e.touches[0].clientX; tsY = e.touches[0].clientY;
  }, {passive: true});
  gArea.addEventListener('touchend', e => {
    if(isEditing) return;
    const teX = e.changedTouches[0].clientX; const teY = e.changedTouches[0].clientY;
    const diffX = teX - tsX; const diffY = teY - tsY;
    if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 70) {
      const dir = diffX < 0 ? 1 : -1;
      if (S.preview) {
         const list = S.bancoFiltrado;
         const idx = list.findIndex(x => x.title === S.preview.title);
         if(idx !== -1) {
             const nextIdx = idx + dir;
             if(nextIdx >= 0 && nextIdx < list.length) abrirPreview(list[nextIdx].title);
             else showToast(dir === 1 ? 'Fim da lista' : 'Início da lista');
         }
      } else {
         navSong(dir);
      }
    }
  }, {passive: true});
});

let toastTimer;
function showToast(msg){
  const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),2200);
}

// ── DOWNLOAD CIFRAS COMO IMAGEM ──
function fecharDownloadModal() {
  document.getElementById('download-modal-overlay').classList.remove('show');
}

async function baixarCifrasSetlist() {
  if (!S.songs.length) { showToast('Setlist vazia!'); return; }

  const overlay = document.getElementById('download-modal-overlay');
  const desc = document.getElementById('download-modal-desc');
  const fill = document.getElementById('download-progress-fill');
  const lbl = document.getElementById('download-progress-label');
  const closeBtn = document.getElementById('download-modal-close');

  overlay.classList.add('show');
  desc.textContent = 'Gerando imagens das cifras do repertório...';
  fill.style.width = '0%';
  lbl.textContent = `0 de ${S.songs.length}`;
  closeBtn.classList.remove('show');

  // Paleta de cores para acordes (respeita a escolha do usuário)
  const chordColor = S.color || '#ff7700';
  const W = 800;
  const PADDING = 48;
  const FONT_SIZE = Math.round(15 * S.fontM);
  const LINE_H = Math.round(FONT_SIZE * 1.22 * S.spacingM);
  const CHORD_H = Math.round(FONT_SIZE * 1.1 * S.spacingM);
  const FONT_FAMILY = 'ui-monospace, SFMono-Regular, Menlo, Consolas, monospace';

  // Pré-carrega a fonte para o canvas
  await document.fonts.ready;

  for (let si = 0; si < S.songs.length; si++) {
    const song = S.songs[si];
    const pct = Math.round(((si) / S.songs.length) * 100);
    fill.style.width = pct + '%';
    lbl.textContent = `${si} de ${S.songs.length}`;

    // Transpõe o conteúdo conforme tom do usuário
    const tp = song.tp || 0;
    const lines = song.content.split('\n');

    // Mede altura total necessária
    let totalH = PADDING + 20; // top padding
    totalH += 36; // título
    totalH += 18; // subtítulo (tom)
    totalH += 24; // separador
    for (const line of lines) {
      if (isChord(line)) totalH += CHORD_H + 2;
      else if (!line.trim()) totalH += Math.round(LINE_H * 0.55);
      else totalH += LINE_H;
    }
    totalH += PADDING + 36; // rodapé

    // Cria canvas offscreen
    const canvas = document.createElement('canvas');
    canvas.width = W;
    canvas.height = totalH;
    const ctx = canvas.getContext('2d');

    // Fundo escuro
    ctx.fillStyle = '#0f0f11';
    ctx.fillRect(0, 0, W, totalH);

    // Gradiente sutil no topo
    const grad = ctx.createLinearGradient(0, 0, 0, 120);
    grad.addColorStop(0, 'rgba(52,211,153,0.08)');
    grad.addColorStop(1, 'rgba(52,211,153,0)');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, W, 120);

    let y = PADDING + 16;

    // Título
    ctx.font = `900 ${Math.min(28, Math.round(22 * S.fontM))}px Raleway, ${FONT_FAMILY}`;
    ctx.fillStyle = '#ffffff';
    ctx.textBaseline = 'top';
    ctx.fillText(song.title, PADDING, y);
    y += 36;

    // Tom original
    ctx.font = `700 ${Math.round(11 * S.fontM)}px ${FONT_FAMILY}`;
    ctx.fillStyle = '#52525b';
    const keyLabel = `Tom original: ${song.key}${tp !== 0 ? `  (${tp > 0 ? '+' : ''}${tp})` : ''}`;
    ctx.fillText(keyLabel.toUpperCase(), PADDING, y);
    y += 18;

    // Linha separadora
    ctx.strokeStyle = 'rgba(52,211,153,0.25)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(PADDING, y + 4);
    ctx.lineTo(W - PADDING, y + 4);
    ctx.stroke();
    y += 20;

    // Linhas da cifra
    for (const line of lines) {
      if (isChord(line)) {
        ctx.font = `700 ${FONT_SIZE}px ${FONT_FAMILY}`;
        ctx.fillStyle = chordColor;
        // Transpõe acordes
        const transposed = line.replace(/[A-G][b#]?/g, m => transpNote(m, tp));
        ctx.fillText(transposed, PADDING, y);
        y += CHORD_H + 2;
      } else if (!line.trim()) {
        y += Math.round(LINE_H * 0.55);
      } else {
        ctx.font = `400 ${FONT_SIZE}px ${FONT_FAMILY}`;
        ctx.fillStyle = '#d4d4d8';
        ctx.fillText(line, PADDING, y);
        y += LINE_H;
      }
    }

    // Rodapé "by cifrei"
    const footerY = totalH - PADDING - 4;
    ctx.strokeStyle = 'rgba(63,63,70,0.5)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(PADDING, footerY - 14);
    ctx.lineTo(W - PADDING, footerY - 14);
    ctx.stroke();

    ctx.font = `700 11px ${FONT_FAMILY}`;
    ctx.fillStyle = '#3f3f46';
    ctx.fillText('by cifrei® · Ministério de Louvor da Sétima Presbiteriana', PADDING, footerY);

    // Número da música (canto superior direito)
    ctx.font = `900 13px ${FONT_FAMILY}`;
    ctx.fillStyle = 'rgba(52,211,153,0.4)';
    ctx.textAlign = 'right';
    ctx.fillText(`${si + 1}/${S.songs.length}`, W - PADDING, PADDING + 16);
    ctx.textAlign = 'left';

    // Converte e baixa
    await new Promise(resolve => {
      canvas.toBlob(blob => {
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        const safeName = song.title.replace(/[^a-zA-Z0-9\u00C0-\u017E\s]/g,'').replace(/\s+/g,'-').slice(0,40);
        a.download = `${si + 1}-${safeName}.jpg`;
        a.href = url;
        a.click();
        setTimeout(() => URL.revokeObjectURL(url), 1000);
        // Pequeno delay entre downloads para não travar o browser
        setTimeout(resolve, 400);
      }, 'image/jpeg', 0.92);
    });
  }

  fill.style.width = '100%';
  lbl.textContent = `${S.songs.length} de ${S.songs.length} — Concluído!`;
  desc.textContent = 'Todas as cifras foram salvas no seu dispositivo.';
  closeBtn.classList.add('show');
}


