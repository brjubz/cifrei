async function fetchTxt(gistId){
  const TIMEOUT = 10000; // 10s por tentativa
  const withTimeout = (promise) => Promise.race([
    promise,
    new Promise((_, rej) => setTimeout(() => rej(new Error('Timeout de rede')), TIMEOUT))
  ]);

  // Tenta URL direta do GitHub primeiro
  const url = `https://gist.githubusercontent.com/brjubz/${gistId}/raw?t=${Date.now()}`;
  try {
    const res = await withTimeout(fetch(url));
    if(!res.ok) throw new Error(`HTTP ${res.status}`);
    const content = await withTimeout(res.text());
    if(!content || content.trim().length < 3) throw new Error('Conteúdo vazio');
    return content;
  } catch (err) {
    console.warn(`fetchTxt URL direta falhou (${gistId}):`, err.message);
    // Fallback: API do GitHub
    try {
      const res2 = await withTimeout(fetch(`https://api.github.com/gists/${gistId}`,
        { headers: { Authorization: `token ${_GIST_TOKEN}` } }));
      if (!res2.ok) throw new Error(`API HTTP ${res2.status}`);
      const data = await withTimeout(res2.json());
      const filename = Object.keys(data.files || {})[0];
      const fileInfo = data.files[filename];
      if (!fileInfo) throw new Error('Arquivo não encontrado no Gist');
      if (fileInfo.truncated || !fileInfo.content) {
        const rawRes = await withTimeout(fetch(fileInfo.raw_url));
        if (!rawRes.ok) throw new Error(`raw_url HTTP ${rawRes.status}`);
        const content = await withTimeout(rawRes.text());
        if (!content || content.trim().length < 3) throw new Error('raw_url vazio');
        return content;
      }
      const content = fileInfo.content || '';
      if (!content || content.trim().length < 3) throw new Error('Conteúdo vazio na API');
      return content;
    } catch(err2) {
      console.warn('fetchTxt fallback API falhou:', err2.message);
      throw new Error('Falha na rede. Verifique sua conexão.');
    }
  }
}

function parseSongs(raw){
  if (!raw || raw.trim() === '' || raw.trim() === '___SETLIST_VAZIO___') return [];

  // Extrai links de playlist e guarda no estado global
  S.playlistYT = (raw.match(/\[PLAYLIST_YT:(.*?)\]/) || [])[1]?.trim() || '';
  S.playlistSP = (raw.match(/\[PLAYLIST_SP:(.*?)\]/) || [])[1]?.trim() || '';
  S.playlistMO = (raw.match(/\[PLAYLIST_MO:(.*?)\]/) || [])[1]?.trim() || '';

  // Remove as tags antes de parsear
  const rawLimpo = raw.replace(/\[PLAYLIST_YT:[^\]]*\]\n?/g,'')
                      .replace(/\[PLAYLIST_SP:[^\]]*\]\n?/g,'')
                      .replace(/\[PLAYLIST_MO:[^\]]*\]\n?/g,'');

  const blocks=rawLimpo.split('--END--');
  const res=[];
  for(const b of blocks){
    const c=b.trim();if(!c)continue;
    const ls=c.split('\n');let title='Sem título',body=c;
    for(let i=0;i<ls.length;i++){
      if(ls[i].trim()){title=ls[i].trim();body=ls.slice(i+1).join('\n').trim();break;}
    }
    // Metadados opcionais
    let artist='';
    const artistMatch=body.match(/^\[ARTIST:(.*?)\]\n?/m);
    if(artistMatch){artist=artistMatch[1].trim();body=body.replace(/\[ARTIST:[^\]]*\]\n?/g,'').trim();}
    let linkYT='';
    const ytMatch=body.match(/^\[LINK_YT:(.*?)\]\n?/m);
    if(ytMatch){linkYT=ytMatch[1].trim();body=body.replace(/\[LINK_YT:[^\]]*\]\n?/g,'').trim();}
    let linkSP='';
    const spMatch=body.match(/^\[LINK_SP:(.*?)\]\n?/m);
    if(spMatch){linkSP=spMatch[1].trim();body=body.replace(/\[LINK_SP:[^\]]*\]\n?/g,'').trim();}
    let tp = 0;
    const tpMatch = body.match(/^\[tp:(-?\d+)\]\n?/);
    if (tpMatch) { tp = parseInt(tpMatch[1]); body = body.replace(/^\[tp:-?\d+\]\n?/, ''); }
    let letra = '';
    const letraMatch = body.match(/\[LETRA\]([\s\S]*?)\[\/LETRA\]/);
    if (letraMatch) { letra = letraMatch[1].trim(); body = body.replace(/\n*\[LETRA\][\s\S]*?\[\/LETRA\]/, '').trim(); }
    const verified=/\(verificado\)/i.test(title);
    const cleanTitle=title.replace(/\s*\(verificado\)/i,'').trim();
    const key=firstChord(body);
    res.push({title:cleanTitle,verified,key:key!=='N/A'?key:'-',content:body,letra,tp,artist,linkYT,linkSP});
  }
  return res;
}

// Versão rápida para o banco — extrai só metadados (título, tom, verified, artist, links)
// A cifra/letra completa fica no rawBanco e é extraída só ao abrir a música
function parseSongsRapido(raw) {
  if (!raw || raw.trim() === '') return [];
  const blocks = raw.split('--END--');
  const res = [];
  for (const b of blocks) {
    const c = b.trim(); if (!c) continue;
    const ls = c.split('\n'); let title = 'Sem título', restIdx = 0;
    for (let i = 0; i < ls.length; i++) {
      if (ls[i].trim()) { title = ls[i].trim(); restIdx = i + 1; break; }
    }
    const verified = /\(verificado\)/i.test(title);
    const cleanTitle = title.replace(/\s*\(verificado\)/i, '').trim();

    // Extrai metadados das primeiras linhas sem processar tudo
    let key = '-', artist = '', linkYT = '', linkSP = '';
    for (let i = restIdx; i < ls.length; i++) {
      const l = ls[i].trim();
      if (!key || key === '-') {
        const k = firstChord(l);
        if (k && k !== 'N/A') { key = k; }
      }
      const am = l.match(/^\[ARTIST:(.*?)\]$/);   if (am) artist = am[1].trim();
      const ym = l.match(/^\[LINK_YT:(.*?)\]$/);  if (ym) linkYT = ym[1].trim();
      const sm = l.match(/^\[LINK_SP:(.*?)\]$/);  if (sm) linkSP = sm[1].trim();
    }
    res.push({ title: cleanTitle, verified, key, artist, linkYT, linkSP, _rawIdx: res.length });
  }
  return res;
}

// Extrai cifra e letra completa de um bloco raw específico (lazy loading)
function _extrairConteudoMusica(raw, titulo) {
  const blocks = raw.split('--END--');
  for (const b of blocks) {
    const c = b.trim(); if (!c) continue;
    const ls = c.split('\n'); let title = '', body = '';
    for (let i = 0; i < ls.length; i++) {
      if (ls[i].trim()) { title = ls[i].trim(); body = ls.slice(i + 1).join('\n').trim(); break; }
    }
    const cleanTitle = title.replace(/\s*\(verificado\)/i, '').trim();
    if (cleanTitle.toLowerCase() !== titulo.toLowerCase()) continue;
    const tpMatch = body.match(/^\[tp:(-?\d+)\]\n?/);
    if (tpMatch) body = body.replace(/^\[tp:-?\d+\]\n?/, '');
    let letra = '';
    const letraMatch = body.match(/\[LETRA\]([\s\S]*?)\[\/LETRA\]/);
    if (letraMatch) { letra = letraMatch[1].trim(); body = body.replace(/\n*\[LETRA\][\s\S]*?\[\/LETRA\]/, '').trim(); }
    return { content: body, letra };
  }
  return null;
}

