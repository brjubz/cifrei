    <div id="perfil-nome-atual" style="font-size:20px;font-weight:900;color:#fff;font-family:var(--font-chord);margin-bottom:20px;"></div>

    <!-- Campo novo nome -->
    <div style="text-align:left;margin-bottom:16px;">
      <label style="font-size:11px;color:var(--faint);text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:6px;">Alterar nome</label>
      <input id="perfil-novo-nome" type="text" maxlength="30"
