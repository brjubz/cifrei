<div id="modal-perfil" onclick="if(event.target===this)fecharModalPerfil()" style="display:none;position:fixed;inset:0;z-index:99990;background:rgba(0,0,0,.75);backdrop-filter:blur(6px);align-items:center;justify-content:center;">
