<!-- ══ APP ══════════════════════════════════ -->
<div id="app" style="display:none;">
<main>

  <!-- LIST -->
  <div class="view active" id="view-list">
    <div class="list-header">
      <div>
        <div style="display:flex; align-items:center;">
          <h2>Setlist</h2>
          <div id="presence-avatars" class="presence-wrap"></div>
        </div>
        <p id="list-cnt-txt">0 músicas</p>
        <div class="week-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Repertório da semana
        </div>
      </div>
    </div>
    <div class="song-list" id="song-list"></div>
  </div>

  <!-- BANCO -->
  <div class="view" id="view-banco">
    <div class="banco-header">
      <div>
        <h2>Banco de Músicas</h2>
        <div class="banco-header-row">
          <p id="banco-cnt-txt">Carregando...</p>
          <div id="presence-avatars-banco" class="presence-wrap" style="transform: scale(0.9); transform-origin: left center;"></div>
        </div>
      </div>
    </div>

    <!-- Histórico de setlists -->
    <div id="historico-section" style="margin-bottom:16px;display:none;">
      <!-- Cabeçalho colapsável -->
      <button onclick="_toggleHistorico()" id="historico-toggle-btn"
        style="width:100%;display:flex;align-items:center;gap:8px;background:rgba(24,24,27,.6);border:1px solid var(--bg3);border-radius:12px;padding:12px 16px;cursor:pointer;color:var(--muted);transition:border-color .15s;"
        onmouseenter="this.style.borderColor='rgba(52,211,153,.3)'" onmouseleave="this.style.borderColor='var(--bg3)'">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span style="font-size:13px;font-weight:700;color:#fff;flex:1;text-align:left;">Setlists Anteriores</span>
        <span id="historico-count-badge" style="font-size:10px;background:var(--bg3);padding:2px 8px;border-radius:99px;"></span>
        <svg id="historico-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14" style="transition:transform .2s;"><polyline points="6 9 12 15 18 9"/></svg>
      </button>

      <!-- Conteúdo expansível -->
      <div id="historico-body" style="display:none;margin-top:8px;">
        <!-- Filtro por data -->
        <div style="display:flex;gap:6px;margin-bottom:10px;overflow-x:auto;padding-bottom:2px;" id="historico-filtros"></div>
        <!-- Lista -->
        <div id="historico-list" style="display:flex;flex-direction:column;gap:10px;"></div>
      </div>
    </div>

    <div class="search-wrap">
      <div class="search-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
      <input class="search-input" id="search-input" type="text" placeholder="Buscar música..." oninput="filtrarBanco()" />
    </div>
    <div class="banco-list" id="banco-list"></div>
  </div>

  <!-- Modal letra sonoplastia -->
  <div id="sono-cifra-drawer" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.85);backdrop-filter:blur(8px);align-items:flex-end;justify-content:center;">
    <div style="background:var(--bg2);border:1px solid var(--bg3);border-radius:20px 20px 0 0;width:100%;max-width:540px;max-height:88vh;display:flex;flex-direction:column;animation:slideUp .25s cubic-bezier(.22,1,.36,1);">
      <!-- Header -->
      <div style="padding:16px 20px 12px;border-bottom:1px solid var(--bg3);">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
          <div style="min-width:0;">
            <div id="sono-cifra-title" style="font-size:17px;font-weight:800;color:#fff;line-height:1.2;"></div>
            <div id="sono-cifra-artist" style="font-size:12px;color:var(--faint);margin-top:3px;"></div>
          </div>
          <button onclick="fecharSonoCifra()" style="background:var(--bg3);border:none;border-radius:50%;width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;color:var(--muted);font-size:18px;">✕</button>
        </div>
      </div>
      <!-- Conteúdo letra -->
      <div id="sono-cifra-content" style="flex:1;overflow-y:auto;padding:20px;font-size:15px;line-height:1.8;color:#e4e4e7;white-space:pre-wrap;font-family:var(--font-ui);"></div>
      <!-- Botão copiar -->
      <div style="padding:14px 20px 28px;">
        <button onclick="copiarLetraSono()" id="btn-copiar-sono"
          style="width:100%;padding:14px;background:var(--green);border:none;border-radius:14px;color:#000;font-size:14px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          Copiar Letra
        </button>
      </div>
    </div>
  </div>

  <!-- READER -->
  <div class="view" id="view-reader">
    <div class="reader-nav">
      <button class="reader-back" onclick="leaveReader()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        <span id="reader-back-txt">Setlist</span>
      </button>
      <div class="perf-badge">Performance</div>
    </div>
    
    <!-- CONTAINER DOS AVATARES NO READER -->
    <div class="song-counter">
      <span class="counter-badge" id="r-counter">1/1</span>
      <span style="margin-right: 4px;">Original: <span id="r-key">C</span></span>
      <div id="presence-avatars-reader" class="presence-wrap" style="margin-left: 4px; transform: scale(0.85); transform-origin: left center; height: 26px;"></div>
    </div>
    
    <div class="reader-title" id="r-title">Título</div>

    <!-- BARRA DE PROGRESSO DO TURNO (abaixo do título) -->
    <div class="reader-progress-section" id="reader-progress-section" style="display:none;">
      <div class="reader-progress-wrap">
        <span class="reader-progress-turno-label" id="reader-progress-label"></span>
        <div class="reader-progress-bg">
          <div class="reader-progress-fill" id="reader-progress-fill" style="width:0%"></div>
        </div>
      </div>
    </div>

    <div class="cifra-box" id="gesture-area">
      <div class="cifra-content" id="cifra"></div>
      <textarea id="edit-area" style="display:none;" spellcheck="false" placeholder="Edite a cifra aqui..."></textarea>
    </div>

    <!-- Botão Finalizar Louvor: fixo no fim do conteúdo da página (não flutuante) -->
    <div class="finalizar-louvor-inline" id="finalizar-louvor-bar">
      <button class="finalizar-louvor-btn" id="finalizar-louvor-btn" onclick="finalizarLouvor()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 12l2 2 4-4"/><path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z"/>
        </svg>
        Finalizar Louvor
      </button>
    </div>

    <!-- Botões prev/next SEMPRE visíveis à direita -->
    <div class="nav-songs-float" id="nav-songs-float">
      <button class="nav-float-btn" id="btn-prev" onclick="navSong(-1)" title="Música anterior">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
      </button>
      <button class="nav-float-btn" id="btn-next" onclick="navSong(1)" title="Próxima música">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
    </div>

    <!-- Botão Adicionar do Preview -->
    <button id="preview-add-fab" class="preview-add-fab" onclick="addPreviewToSetlist()" title="Adicionar ao Setlist" style="display:none;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="20" height="20"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </button>

    <!-- FAB controles à direita -->
    <div class="fab-wrap">
      <div class="fab-menu hidden" id="fab-menu">

        <!-- Botões de sala -->
        <div id="fab-sala-controls" style="display:none;flex-direction:column;gap:12px;align-items:stretch;">
          <button id="fab-sirene-btn" onclick="abrirPopupChamados()" title="Chamar sonoplasta" style="width:100%;height:44px;background:#e11d48;border:none;border-radius:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(225,29,72,.5);transition:all .15s;">
            <svg viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1.5" width="22" height="22"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          </button>
          <button id="fab-lock-btn" onclick="toggleSalaBloqueio()" title="Bloquear/desbloquear sala" style="width:100%;height:44px;background:rgba(248,113,113,.15);border:1.5px solid #f87171;border-radius:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;">
            <svg viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="2.5" id="fab-lock-ico" width="22" height="22"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </button>
        </div>

        <!-- Toggle Cifra / Vocal — sempre visível no topo -->
        <div class="ctrl-panel" id="modo-toggle-panel" style="padding:0 2px;">
          <button id="btn-modo-toggle" onclick="toggleModoVocal()" style="background:var(--bg3);border:1px solid var(--bg4);border-radius:10px;padding:7px 14px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;font-size:13px;font-weight:700;color:#fff;white-space:nowrap;transition:all .2s;width:100%;">
            <span id="modo-toggle-ico">🎸</span>
            <span id="modo-toggle-txt">Cifra</span>
          </button>
        </div>

        <!-- Controles exclusivos do modo CIFRA -->
        <div id="fab-ctrl-cifra" style="display:flex;flex-direction:column;gap:12px;">
          <!-- Cor -->
          <div style="display:flex;gap:8px;">
            <div class="ctrl-panel" style="flex:1;">
              <button class="ctrl-btn" onclick="toggleColorPopover(event)">
                <div id="current-color-dot" style="width:16px;height:16px;border-radius:50%;background:var(--color);box-shadow:0 0 0 2px rgba(255,255,255,0.2);"></div>
              </button>
              <div class="ctrl-ctr"><div class="ctrl-label">Cor</div></div>
              <div class="color-popover" id="color-popover"></div>
            </div>
          </div>
          <!-- Editar / Salvar+Cancel -->
          <div style="display:flex;gap:8px;">
            <div class="ctrl-panel" id="btn-edit-wrap" style="flex:1;">
              <button class="ctrl-btn" id="btn-edit" onclick="toggleEditMode()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              </button>
              <div class="ctrl-ctr"><div class="ctrl-label" id="edit-lbl">Editar</div></div>
            </div>
            <div id="btn-salvar-cancelar-cifra" style="display:none;gap:8px;flex:1;">
              <div class="ctrl-panel" style="flex:1;">
                <button class="ctrl-btn" onclick="toggleEditMode()" style="color:var(--green);">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                </button>
                <div class="ctrl-ctr"><div class="ctrl-label" style="color:var(--green);">Salvar</div></div>
              </div>
              <div class="ctrl-panel" style="flex:1;">
                <button class="ctrl-btn" onclick="cancelarEdicaoCifra()" style="color:#f87171;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
                <div class="ctrl-ctr"><div class="ctrl-label" style="color:#f87171;">Cancel</div></div>
              </div>
            </div>
          </div>
          <!-- Txt + Esp -->
          <div style="display:flex;gap:8px;">
            <div class="ctrl-panel" style="flex:1;">
              <button class="ctrl-btn" onclick="adjFont(.1)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
              <div class="ctrl-ctr"><div class="ctrl-label">Txt</div><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg></div>
              <button class="ctrl-btn" onclick="adjFont(-.1)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
            </div>
            <div class="ctrl-panel" style="flex:1;">
              <button class="ctrl-btn" onclick="adjSpacing(.1)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
              <div class="ctrl-ctr"><div class="ctrl-label">Esp</div><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></div>
              <button class="ctrl-btn" onclick="adjSpacing(-.1)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
            </div>
          </div>
          <!-- Tom -->
          <div style="display:flex;gap:8px;">
            <div class="ctrl-panel" style="flex:1;">
              <button class="ctrl-btn" onclick="adjTranspose(1)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
              <div class="ctrl-ctr"><div class="ctrl-label">Tom</div><div class="ctrl-val" id="tp-val">0</div></div>
              <button class="ctrl-btn" onclick="adjTranspose(-1)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
            </div>
            <button id="btn-salvar-tom" onclick="salvarTomAtual()"
              style="display:none;background:var(--green);border:none;border-radius:12px;padding:0 14px;color:#000;font-size:11px;font-weight:800;cursor:pointer;white-space:nowrap;">
              Salvar Tom
            </button>
          </div>
          <!-- Tela cheia -->
          <div style="display:flex;gap:8px;">
            <div class="ctrl-panel" style="flex:1;">
              <button class="ctrl-btn" onclick="toggleFS()">
                <svg id="fs-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
              </button>
              <div class="ctrl-ctr"><div class="ctrl-label">Tela</div></div>
            </div>
          </div>
        </div>

        <!-- Controles exclusivos do modo VOCAL -->
        <div id="fab-ctrl-vocal" style="display:none;flex-direction:column;gap:12px;">
          <!-- Editar / Salvar+Cancel -->
          <div style="display:flex;gap:8px;">
            <div class="ctrl-panel" id="btn-edit-vocal-wrap" style="flex:1;">
              <button class="ctrl-btn" id="btn-edit-vocal" onclick="toggleEditMode()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              </button>
              <div class="ctrl-ctr"><div class="ctrl-label" id="edit-lbl-vocal">Editar</div></div>
            </div>
            <div id="btn-salvar-cancelar-vocal" style="display:none;gap:8px;flex:1;">
              <div class="ctrl-panel" style="flex:1;">
                <button class="ctrl-btn" onclick="toggleEditMode()" style="color:var(--green);">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                </button>
                <div class="ctrl-ctr"><div class="ctrl-label" style="color:var(--green);">Salvar</div></div>
              </div>
