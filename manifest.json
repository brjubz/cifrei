async function requestWakeLock() {
  try { if ('wakeLock' in navigator) wakeLock = await navigator.wakeLock.request('screen'); } catch (err) {}
}
function releaseWakeLock() {
  if (wakeLock !== null) { wakeLock.release().then(()=> wakeLock = null); }
}
document.addEventListener('visibilitychange', () => {
  if (wakeLock !== null && document.visibilityState === 'visible') requestWakeLock();
});

function isChord(l){
  if(!l||!l.trim())return false;
  const ws=l.trim().split(/\s+/);
  let chords=0, texts=0;
  for(const w of ws){
    const cl=w.replace(/^[|()[\]\-,.:*%]+|[|()[\]\-,.:*%]+$/g,'');
    if(!cl||/^(intro|solo|interl|ponte|final|refrão|refrao|bridge|chorus|bis|2x|3x|4x|dedilhado|repete|riff|base)$/i.test(cl))continue;
    if(CRE.test(cl)) chords++; else texts++;
  }
  return chords > 0 && texts === 0;
}
function firstChord(txt){
  for(const l of txt.split('\n')){
    if(isChord(l)){
      for(const w of l.trim().split(/\s+/)){
        const c=w.replace(/^[|()[\]\-,.:*%]+|[|()[\]\-,.:*%]+$/g,'');
        if(CRE.test(c))return c;
      }
    }
  }
  return 'N/A';
}
function transpNote(n,s){const b=F2S[n]||n;const i=SCALE.indexOf(b);if(i<0)return n;return SCALE[((i+s)%12+12)%12];}
function transpChord(ch,s){return ch.replace(/[A-G][b#]?/g,m=>transpNote(m,s));}
function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

