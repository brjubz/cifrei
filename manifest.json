<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>cifrei · Ministério de Louvor</title>
<meta name="description" content="App do ministério de louvor — cifras, setlist e mais">
<meta name="theme-color" content="#09090b">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="cifrei">
<link rel="manifest" href="/manifest.json">
<link rel="icon" type="image/png" href="/icon-app.png">
<link rel="apple-touch-icon" href="/icon-app.png">
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;700;900&family=Raleway:wght@500;700;800;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#09090b;--bg2:#18181b;--bg3:#27272a;
  --text:#f4f4f5;--muted:#a1a1aa;--faint:#52525b;
  --green:#34d399;--gdim:rgba(52,211,153,.12);
  --red:#f87171;--rdim:rgba(248,113,113,.1);
  --blue:#60a5fa;--bdim:rgba(96,165,250,.12);
  --ebd-color:#fbbf24;--ebd-dim:rgba(251,191,36,.12);
  --culto-color:#c084fc;--culto-dim:rgba(192,132,252,.12);
  --font-chord:'Barlow',sans-serif;
  --font-lyric:'Barlow',sans-serif;
  --font-logo:'Raleway',sans-serif;
  --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
}
body{background:var(--bg);color:var(--text);font-family:var(--font-lyric);min-height:100vh;line-height:1.5;}

/* ── MODAL DE NOME (PRESENÇA) ───────────── */
.name-modal {
  position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 9999;
  display: flex; align-items: center; justify-content: center; backdrop-filter: blur(8px);
}
.name-modal-box {
  background: var(--bg2); border: 1px solid var(--bg3); padding: 32px 24px;
  border-radius: 20px; width: 90%; max-width: 340px; text-align: center;
  box-shadow: 0 20px 50px rgba(0,0,0,0.6); animation: fadeInUp 0.4s ease;
}
.name-modal-box h3 { font-family: var(--font-chord); font-size: 22px; color: #fff; margin-bottom: 8px; letter-spacing: -0.5px; }
.name-modal-box p { color: var(--muted); font-size: 14px; margin-bottom: 24px; line-height: 1.4; }
.name-modal-box input {
  width: 100%; background: var(--bg); border: 1px solid var(--bg3); border-radius: 12px;
  padding: 14px 16px; color: #fff; font-size: 16px; outline: none; margin-bottom: 16px; font-family: var(--font-lyric);
  transition: border-color 0.2s;
}
.name-modal-box input:focus { border-color: var(--green); }
.name-modal-box button {
  width: 100%; background: var(--green); color: #000; font-family: var(--font-chord);
  font-weight: 900; font-size: 16px; padding: 14px; border-radius: 12px; border: none; cursor: pointer; transition: all 0.2s;
}
.name-modal-box button:hover { transform: scale(1.02); background: #6ee7b7; }

/* ── SPLASH ─────────────────────────────── */
@keyframes pulseGlow {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.15); }
}
@keyframes fadeOut {
  from { opacity: 1; transform: scale(1); }
  to { opacity: 0; transform: scale(0.96); }
}
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
#splash{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 24px;text-align:center;position:relative;overflow:hidden;}
#splash::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(52,211,153,.35) 0%,transparent 70%);pointer-events:none;animation: pulseGlow 5s ease-in-out infinite;transform-origin: top center;}
.splash-logo{width:110px;height:110px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;filter:drop-shadow(0 0 15px rgba(52,211,153,.3));}
.splash-logo img{width:100%;height:100%;object-fit:contain;}
.splash-title{font-family:var(--font-logo);font-size:clamp(40px,8vw,64px);font-weight:800;letter-spacing:-1px;color:#fff;line-height:1;}
.splash-welcome{font-family:var(--font-chord);font-weight:700;font-size:16px;color:var(--green);margin-top:8px;}
.splash-sub{font-family:var(--font-chord);font-size:15px;font-weight:400;color:var(--muted);margin-top:12px;max-width:320px;line-height:1.4;}
.splash-desc{font-size:14px;color:var(--faint);margin-top:16px;max-width:320px;line-height:1.6;}

.splash-buttons{margin-top:36px;display:flex;flex-direction:column;gap:12px;align-items:center;width:100%;max-width:280px;}

.start-btn{
  width:100%;background:var(--green);color:#000;
  font-family:var(--font-chord);font-weight:900;font-size:16px;
  padding:16px 32px;border-radius:999px;border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:10px;
  box-shadow:0 0 40px rgba(52,211,153,.3);transition:all .2s;
}
.start-btn:hover{background:#6ee7b7;transform:scale(1.02);}
.start-btn:active{transform:scale(.97);}
.start-btn svg{width:18px;height:18px;}

.banco-btn{
  width:100%;background:transparent;color:var(--muted);
  font-family:var(--font-chord);font-weight:700;font-size:14px;
  padding:14px 32px;border-radius:999px;border:1px solid var(--bg3);cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:8px;
  transition:all .2s;
}
.banco-btn:hover{color:#fff;border-color:var(--blue);background:var(--bdim);}
.banco-btn svg{width:16px;height:16px;}

.splash-err{margin-top:20px;padding:14px 18px;background:var(--rdim);border:1px solid rgba(248,113,113,.3);border-radius:14px;color:var(--red);font-size:13px;max-width:340px;display:none;align-items:flex-start;gap:10px;text-align:left;}
.splash-err svg{width:16px;height:16px;flex-shrink:0;margin-top:2px;}

.btn-spinner{width:18px;height:18px;border:2.5px solid rgba(0,0,0,.2);border-top-color:#000;border-radius:50%;animation:spin .6s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}

.splash-footer{position:absolute;bottom:24px;font-family:var(--font-chord);font-size:12px;font-weight:500;color:var(--faint);letter-spacing:0.5px;}
.splash-footer a{color:var(--muted);text-decoration:none;transition:color .2s;}
.splash-footer a:hover{color:var(--green);}

/* ── NAV ────────────────────────────────── */
nav{position:sticky;top:0;z-index:50;background:rgba(9,9,11,.9);backdrop-filter:blur(16px);border-bottom:1px solid var(--bg3);padding:10px 20px;display:none;align-items:center;justify-content:space-between;}
nav.show{display:flex;}
.nav-logo{display:flex;align-items:center;gap:9px;cursor:pointer;}
.nav-logo-icon{width:28px;height:28px;display:flex;align-items:center;justify-content:center;}
.nav-logo-icon img{width:100%;height:100%;object-fit:contain;}
.nav-title{font-family:var(--font-logo);font-size:20px;font-weight:800;color:#fff;letter-spacing:-0.5px;}

.nav-right{display:flex;gap:4px;align-items:center;}
/* Indicador de conexão */
.conn-indicator{display:flex;align-items:center;gap:5px;padding:3px 9px;border-radius:99px;font-size:10px;font-weight:700;letter-spacing:.5px;transition:all .4s ease;border:1px solid transparent;}
.conn-indicator.online{background:rgba(52,211,153,.12);border-color:rgba(52,211,153,.25);color:var(--green);}
.conn-indicator.offline{background:rgba(248,113,113,.12);border-color:rgba(248,113,113,.3);color:#f87171;animation:connPulse 1.5s ease-in-out infinite;}
.conn-indicator.syncing{background:rgba(251,191,36,.1);border-color:rgba(251,191,36,.25);color:#fbbf24;}
.conn-dot{width:6px;height:6px;border-radius:50%;background:currentColor;flex-shrink:0;}
.conn-indicator.online .conn-dot{animation:connBlink 2.5s ease-in-out infinite;}
@keyframes connBlink{0%,100%{opacity:1;}50%{opacity:.3;}}
@keyframes connPulse{0%,100%{opacity:1;}50%{opacity:.5;}}
.nav-icon-btn{
  width:38px;height:38px;border-radius:10px;background:transparent;
  border:none;color:var(--muted);cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;position:relative;
}
.nav-icon-btn:hover{color:#fff;background:rgba(255,255,255,.05);}
.nav-icon-btn.active{color:var(--green);background:var(--gdim);}
.nav-icon-btn svg{width:20px;height:20px;}
.nav-badge{
  position:absolute;top:2px;right:2px;background:var(--green);color:#000;
  font-family:var(--font-chord);font-weight:900;font-size:10px;
  padding:1px 5px;border-radius:6px;transform:scale(0.85);transform-origin:top right;
}

/* ── MAIN ───────────────────────────────── */
main{max-width:860px;margin:0 auto;padding:28px 20px;}
.view{display:none;}
.view.active{display:block;}

/* ── LIST & PRESENCE ────────────────────── */
.list-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;}
.list-header h2{font-family:var(--font-chord);font-size:26px;font-weight:900;color:#fff;letter-spacing:-.5px;}
.list-header p{color:var(--muted);font-size:12px;margin-top:3px;}
.presence-wrap { display: flex; align-items: center; margin-left: 12px; }
.presence-avatar {
  width: 42px; height: 42px; border-radius: 50%; border: 2px solid var(--bg);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-chord); font-size: 15px; font-weight: 900; color: #000;
  margin-left: -10px; text-transform: uppercase; cursor: help;
  box-shadow: 0 2px 5px rgba(0,0,0,0.4); transition: transform 0.2s, z-index 0.2s;
  position: relative; z-index: 1;
  background-size: cover; background-position: center;
}
.presence-avatar:hover { transform: translateY(-3px); z-index: 10 !important; border-color: #fff; }
.presence-avatar:first-child { margin-left: 0; }
.presence-avatar.em-sala {
  border-color: var(--green) !important;
  cursor: pointer !important;
  animation: pulseSalaGreen 1.2s ease-out infinite;
}
@keyframes pulseSalaBlocked {
  0%   { box-shadow: 0 0 0 0 rgba(248,113,113,.9), 0 2px 5px rgba(0,0,0,.4); border-color: #f87171; }
  40%  { box-shadow: 0 0 0 7px rgba(248,113,113,0), 0 2px 5px rgba(0,0,0,.4); border-color: #fca5a5; }
  100% { box-shadow: 0 0 0 0 rgba(248,113,113,0),  0 2px 5px rgba(0,0,0,.4); border-color: #f87171; }
}
@keyframes pulseSalaGreen {
  0%   { box-shadow: 0 0 0 0 rgba(52,211,153,.9), 0 2px 5px rgba(0,0,0,.4); border-color: var(--green); }
  40%  { box-shadow: 0 0 0 7px rgba(52,211,153,0), 0 2px 5px rgba(0,0,0,.4); border-color: #6ee7b7; }
  100% { box-shadow: 0 0 0 0 rgba(52,211,153,0),  0 2px 5px rgba(0,0,0,.4); border-color: var(--green); }
}
@keyframes chamadoAlerta {
  0%,100% { box-shadow: 0 0 0 0 rgba(248,113,113,.0); background: var(--bg2); }
  25%     { box-shadow: 0 0 0 8px rgba(248,113,113,.5); background: rgba(248,113,113,.15); }
  50%     { box-shadow: 0 0 0 0 rgba(248,113,113,.0); background: rgba(248,113,113,.08); }
  75%     { box-shadow: 0 0 0 6px rgba(248,113,113,.4); background: rgba(248,113,113,.15); }
}
.sono-chamados-alerta { animation: chamadoAlerta 1s ease-in-out infinite !important; border-color: rgba(248,113,113,.6) !important; }
.presence-avatar.em-sala-bloqueada {
  border-color: #f87171 !important;
  animation: pulseSalaBlocked 1.2s ease-out infinite;
  cursor: not-allowed !important;
}

.week-badge{display:inline-flex;align-items:center;gap:5px;background:var(--gdim);border:1px solid rgba(52,211,153,.2);color:var(--green);font-family:var(--font-chord);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:2px;padding:3px 9px;border-radius:5px;margin-top:5px;}
.week-badge svg{width:10px;height:10px;}
.song-list{display:flex;flex-direction:column;gap:8px;position:relative;}
.song-item{background:rgba(24,24,27,.7);border:1px solid var(--bg3);border-radius:14px;display:flex;align-items:center;overflow:hidden;transition:border-color .15s, background .15s; width:100%;}
.song-item:hover{border-color:rgba(52,211,153,.3);}
.song-arrows{display:flex;flex-direction:column;border-right:1px solid rgba(63,63,70,.5);background:rgba(24,24,27,.9);}
.arr-btn{padding:5px 7px;background:none;border:none;color:var(--faint);cursor:pointer;transition:color .15s;display:flex;}
.arr-btn:hover{color:var(--green);}
.arr-btn:disabled{opacity:0;pointer-events:none;}
.song-body{flex:1;padding:12px 16px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;}
.song-num{width:32px;height:32px;border-radius:9px;background:var(--bg3);display:flex;align-items:center;justify-content:center;font-family:var(--font-chord);font-weight:900;color:var(--muted);font-size:13px;flex-shrink:0;transition:all .2s;}
.song-item:hover .song-num{background:var(--green);color:#000;}
.song-info{margin-left:12px;flex:1;}
.song-title{font-family:var(--font-chord);font-size:15px;font-weight:700;color:#f4f4f5;transition:color .2s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:340px;display:flex;align-items:center;gap:5px;}
.song-item:hover .song-title{color:var(--green);}
.song-key{font-family:var(--font-chord);font-size:9px;font-weight:700;color:var(--green);text-transform:uppercase;letter-spacing:2px;margin-top:2px;}
.verified-icon{color:#60a5fa;flex-shrink:0;display:flex;align-items:center;}
.play-icon{width:28px;height:28px;background:var(--green);border-radius:50%;display:none;align-items:center;justify-content:center;flex-shrink:0;}
.play-icon svg{width:11px;height:11px;color:#000;}
@media(min-width:480px){.song-item:hover .play-icon{display:flex;}}
.del-btn{padding:14px;background:none;border:none;cursor:pointer;color:var(--faint);transition:all .15s;display:flex;}
@keyframes slideUp{from{transform:translateY(100%);opacity:0;}to{transform:translateY(0);opacity:1;}}
@keyframes pulseGlow{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(1.3);}}
.btn-tom-lista{background:var(--bg3);border:1px solid var(--bg4);color:var(--green);border-radius:7px;padding:3px 8px;font-size:11px;font-weight:700;cursor:pointer;font-family:var(--font-chord);white-space:nowrap;}
.del-btn:hover{color:var(--red);background:var(--rdim);}
.del-btn svg{width:16px;height:16px;}

/* ── TURNO TAGS ─────────────────────────── */
.turno-divider {
  display: flex; align-items: center; gap: 10px;
  margin: 16px 0 8px 0;
}
.turno-tag {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: var(--font-chord); font-weight: 900; font-size: 12px;
  text-transform: uppercase; letter-spacing: 1.5px;
  padding: 6px 14px; border-radius: 8px;
}
.turno-tag.ebd {
  background: rgba(251,191,36,.15); border: 1px solid rgba(251,191,36,.3);
  color: var(--ebd-color);
}
.turno-tag.culto {
  background: rgba(192,132,252,.15); border: 1px solid rgba(192,132,252,.3);
  color: var(--culto-color);
}
.turno-tag svg { width: 14px; height: 14px; flex-shrink: 0; }
.turno-line { flex: 1; height: 1px; background: var(--bg3); }

/* ── TURNO PROGRESS BAR ─────────────────── */
.turno-progress-wrap {
  display: flex; align-items: center; gap: 8px;
  margin: 0 0 4px 0; padding: 0;
}
.turno-progress-label {
  font-family: var(--font-chord); font-size: 9px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1px; flex-shrink: 0; min-width: 36px;
}
.turno-progress-label.ebd { color: var(--ebd-color); }
.turno-progress-label.culto { color: var(--culto-color); }
.turno-progress-bar-bg {
  flex: 1; height: 3px; border-radius: 999px; background: var(--bg3); overflow: hidden;
}
.turno-progress-bar-fill {
  height: 100%; border-radius: 999px; transition: width 0.5s cubic-bezier(0.25,1,0.5,1);
}
.turno-progress-bar-fill.ebd { background: var(--ebd-color); }
.turno-progress-bar-fill.culto { background: var(--culto-color); }

/* ── SONOPLASTIA ─────────────────────────────── */
@keyframes spinSun{to{transform:rotate(360deg)}}
@keyframes floatCloud{0%{transform:translate(0,0) scale(var(--sc,1))}100%{transform:translate(900px,0) scale(var(--sc,1))}}
@keyframes twinkle{0%,100%{opacity:.3}50%{opacity:1}}
@keyframes sunsetPulse{0%,100%{opacity:.85}50%{opacity:1}}
@keyframes moonGlow{0%,100%{filter:drop-shadow(0 0 6px rgba(254,249,195,.4))}50%{filter:drop-shadow(0 0 16px rgba(254,249,195,.8))}}
.sono-card{background:rgba(24,24,27,.7);border:1px solid rgba(63,63,70,.5);border-radius:18px;padding:20px;backdrop-filter:blur(8px);}
.sono-section-label{font-family:var(--font-chord);font-size:10px;font-weight:700;color:var(--faint);text-transform:uppercase;letter-spacing:2px;margin-bottom:12px;display:flex;align-items:center;gap:6px;}
@keyframes chamadoPulse{0%,100%{box-shadow:0 0 0 0 rgba(225,29,72,.6);}50%{box-shadow:0 0 0 10px rgba(225,29,72,0);}}
.sono-chamado-item{display:flex;align-items:center;gap:14px;padding:16px;background:rgba(225,29,72,.12);border:1.5px solid rgba(225,29,72,.35);border-radius:14px;margin-bottom:8px;animation:chamadoPulse 1.4s ease-out infinite;}
.sono-chamado-ok{background:#34d399;border:none;border-radius:10px;padding:11px 18px;color:#000;font-weight:900;font-size:13px;cursor:pointer;flex-shrink:0;transition:all .15s;}
.sono-chamado-ok:hover{background:#6ee7b7;transform:scale(1.05);}
@keyframes sonoAlertaBorder{0%,100%{border-color:rgba(225,29,72,.35);}50%{border-color:rgba(225,29,72,.85);box-shadow:0 0 20px rgba(225,29,72,.2);}}
.sono-alerta-card{border-color:rgba(225,29,72,.5)!important;animation:sonoAlertaBorder 1s ease-in-out infinite!important;}
.sono-presence-row{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid rgba(63,63,70,.3);}
.sono-presence-row:last-child{border-bottom:none;padding-bottom:0;}
.sono-avatar{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:18px;color:#000;flex-shrink:0;transition:box-shadow .3s;background-size:cover;background-position:center;}
.sono-music-row{display:flex;align-items:center;gap:10px;padding:11px 12px;border-radius:12px;cursor:pointer;transition:background .15s;}
.sono-music-row:hover{background:rgba(255,255,255,.06);}
.sono-music-tag{font-size:10px;font-weight:800;padding:2px 8px;border-radius:5px;flex-shrink:0;letter-spacing:.5px;}
.sono-music-tag.ebd{background:rgba(251,191,36,.15);color:#fbbf24;}
.sono-music-tag.culto{background:rgba(52,211,153,.12);color:#34d399;}
.sono-music-nome{font-size:14px;font-weight:700;color:#fff;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sono-music-key{font-size:11px;color:var(--faint);flex-shrink:0;}
.sono-hist-row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid rgba(63,63,70,.2);}
.sono-hist-row:last-child{border-bottom:none;}

/* ── BANCO ───────────────────────────────── */
.banco-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;}
.banco-header h2{font-family:var(--font-chord);font-size:26px;font-weight:900;color:#fff;letter-spacing:-.5px;}
.banco-header p{color:var(--muted);font-size:12px;margin-top:3px;}
.banco-header-row { display: flex; align-items: center; gap: 8px; }
.search-wrap{position:relative;margin-bottom:16px;}
.search-input{width:100%;background:rgba(24,24,27,.8);border:1px solid var(--bg3);border-radius:12px;padding:11px 16px 11px 40px;font-size:14px;color:#f4f4f5;outline:none;transition:border-color .2s;font-family:var(--font-lyric);}
.search-input:focus{border-color:var(--green);}
.search-input::placeholder{color:var(--faint);}
.search-icon{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--faint);pointer-events:none;}
.search-icon svg{width:16px;height:16px;}
.banco-list{display:flex;flex-direction:column;gap:7px;}
.banco-item{background:rgba(24,24,27,.5);border:1px solid var(--bg3);border-radius:12px;display:flex;align-items:center;justify-content:space-between;padding:12px 16px;gap:12px;transition:all .15s;}
.banco-item:hover{background:rgba(24,24,27,.9);border-color:rgba(52,211,153,.2);}
.banco-info{flex:1;min-width:0;cursor:pointer;}
.banco-title{font-family:var(--font-chord);font-size:14px;font-weight:700;color:#f4f4f5;display:flex;align-items:center;gap:5px;flex-wrap:wrap;}
.banco-key{font-family:var(--font-chord);font-size:9px;font-weight:700;color:var(--faint);text-transform:uppercase;letter-spacing:1px;margin-top:2px;}
.banco-actions{display:flex;gap:6px;align-items:center;}
.vote-btn{background:none;border:none;cursor:pointer;font-size:18px;padding:2px 4px;line-height:1;transition:transform .15s;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.vote-btn:hover{transform:scale(1.25);}
.vote-btn:active{transform:scale(.9);}
.preview-btn{background:var(--bg3);border:1px solid rgba(255,255,255,.1);color:#fff;font-family:var(--font-chord);font-weight:700;font-size:11px;padding:6px 10px;border-radius:8px;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:5px;}
.preview-btn:hover{background:var(--faint);}
.preview-btn svg{width:13px;height:13px;}
/* Botão add ao setlist agora verde escuro */
.add-setlist-btn{background:rgba(16,101,69,.5);border:1px solid rgba(52,211,153,.3);color:#34d399;font-family:var(--font-chord);font-weight:700;font-size:11px;padding:6px 10px;border-radius:8px;cursor:pointer;white-space:nowrap;transition:all .15s;display:flex;align-items:center;gap:5px;}
.add-setlist-btn:hover{background:#059669;color:#fff;border-color:#059669;}
.add-setlist-btn svg{width:13px;height:13px;}
.add-setlist-btn.added{background:rgba(52,211,153,.15);color:var(--green);cursor:default;border-color:rgba(52,211,153,.3);}
.banco-empty{text-align:center;padding:40px 20px;color:var(--faint);font-family:var(--font-chord);font-size:14px;}

/* ── READER ──────────────────────────────── */
#view-reader{padding-bottom:110px;}
.reader-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;}
.reader-back{display:flex;align-items:center;gap:5px;font-family:var(--font-chord);font-size:12px;font-weight:700;color:var(--muted);background:var(--bg2);border:1px solid var(--bg3);padding:6px 12px;border-radius:999px;cursor:pointer;transition:color .2s;}
.reader-back:hover{color:#fff;}
.perf-badge{font-family:var(--font-chord);font-size:10px;font-weight:700;color:var(--green);text-transform:uppercase;letter-spacing:2px;background:var(--gdim);border:1px solid rgba(52,211,153,.2);padding:4px 10px;border-radius:5px;display:none;}
@media(min-width:480px){.perf-badge{display:flex;}}
.song-counter{display:inline-flex;align-items:center;flex-wrap:wrap;gap:7px;font-family:var(--font-chord);font-size:10px;font-weight:700;color:var(--green);text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;}
.counter-badge{background:var(--green);color:#000;padding:2px 7px;border-radius:4px;font-size:9px;}

/* ── BARRA DE PROGRESSO DO READER ───────── */
.reader-progress-section {
  margin-bottom: 16px;
  margin-top: -4px;
}
.reader-progress-wrap {
  display: flex; align-items: center; gap: 8px;
}
.reader-progress-turno-label {
  font-family: var(--font-chord); font-size: 9px; font-weight: 800;
  text-transform: uppercase; letter-spacing: 1.5px; flex-shrink: 0;
  display: inline-flex; align-items: center; gap: 4px; min-width: 40px;
}
.reader-progress-turno-label.ebd { color: var(--ebd-color); }
.reader-progress-turno-label.culto { color: var(--culto-color); }
.reader-progress-bg {
  flex: 1; height: 4px; border-radius: 999px; background: var(--bg3); overflow: hidden;
}
.reader-progress-fill {
  height: 100%; border-radius: 999px; transition: width 0.7s cubic-bezier(0.25,1,0.5,1);
}
.reader-progress-fill.ebd { background: linear-gradient(90deg, #f59e0b, var(--ebd-color)); }
.reader-progress-fill.culto { background: linear-gradient(90deg, #9333ea, var(--culto-color)); }

.reader-title{font-family:var(--font-chord);font-size:clamp(24px,5vw,44px);font-weight:900;color:#fff;letter-spacing:-1px;margin-bottom:12px;line-height:1.1;display:flex;align-items:center;gap:10px;}
.title-bar{width:48px;height:4px;background:var(--green);border-radius:999px;margin-bottom:28px;}

/* Redução de fonte para visualização mobile */
.cifra-box{background:rgba(24,24,27,.6);border:1px solid var(--bg3);border-radius:20px;padding:24px;overflow-x:auto;min-height:55vh; font-size: 16px;}
@media(max-width: 600px) {
  .cifra-box { font-size: 11.5px; padding: 16px; }
}

.cifra-content{padding-bottom:32px;}
@keyframes slideInRight{from{transform:translateX(48px);opacity:0}to{transform:translateX(0);opacity:1}}
@keyframes slideInLeft{from{transform:translateX(-48px);opacity:0}to{transform:translateX(0);opacity:1}}
.slide-in-right{animation:slideInRight .28s cubic-bezier(.22,1,.36,1) both}
.slide-in-left{animation:slideInLeft .28s cubic-bezier(.22,1,.36,1) both}

#edit-area {
  width: 100%; min-height: 55vh; background: rgba(0,0,0,.2); color: #fff;
  border: 1px dashed rgba(63,63,70,.8); border-radius: 12px; padding: 16px;
  font-family: var(--font-mono); font-size: 1em; line-height: 1.5;
  resize: vertical; outline: none; transition: border-color 0.2s; white-space: pre;
}
#edit-area:focus { border-color: var(--green); }
.chord-line{font-family:var(--font-mono);font-weight:700;font-size:1em;white-space:pre;margin-top:2px;line-height:1.1;}
.lyric-line{font-family:var(--font-mono);font-weight:400;font-style:normal;font-size:1em;color:#d4d4d8;line-height:1.2;white-space:pre;}

/* ── BOTÃO FINALIZAR LOUVOR ─────────────── */
.finalizar-louvor-inline {
  display: none; align-items: center; justify-content: flex-start;
  margin-top: 28px; padding: 0;
}
.finalizar-louvor-inline.visible { display: flex; }
.finalizar-louvor-btn {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-chord); font-weight: 900; font-size: 13px;
  padding: 12px 22px; border-radius: 12px; border: none; cursor: pointer;
  transition: all 0.2s;
}
.finalizar-louvor-btn.ebd {
  background: rgba(251,191,36,.15); border: 1px solid rgba(251,191,36,.4);
  color: var(--ebd-color);
}
.finalizar-louvor-btn.ebd:hover { background: rgba(251,191,36,.28); transform: translateY(-1px); }
.finalizar-louvor-btn.culto {
  background: rgba(192,132,252,.15); border: 1px solid rgba(192,132,252,.4);
  color: var(--culto-color);
}
.finalizar-louvor-btn.culto:hover { background: rgba(192,132,252,.28); transform: translateY(-1px); }
.finalizar-louvor-btn svg { width: 15px; height: 15px; }

/* ── MODAL RESUMO LOUVOR ────────────────── */
.resumo-modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.88); z-index: 9999;
  display: none; align-items: center; justify-content: center;
  backdrop-filter: blur(10px); padding: 20px;
}
.resumo-modal-overlay.show { display: flex; }
.resumo-modal {
  background: var(--bg2); border-radius: 24px; width: 90%; max-width: 380px;
  overflow: hidden; box-shadow: 0 30px 80px rgba(0,0,0,0.7);
  animation: fadeInUp 0.4s ease;
}
.resumo-modal-header {
  padding: 28px 28px 20px;
  text-align: center;
}
.resumo-modal-header.ebd {
  background: linear-gradient(135deg, rgba(251,191,36,.2) 0%, rgba(251,191,36,.05) 100%);
  border-bottom: 1px solid rgba(251,191,36,.2);
}
.resumo-modal-header.culto {
  background: linear-gradient(135deg, rgba(192,132,252,.2) 0%, rgba(192,132,252,.05) 100%);
  border-bottom: 1px solid rgba(192,132,252,.2);
}
.resumo-modal-icon {
  width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center;
  justify-content: center; margin: 0 auto 14px; font-size: 28px;
}
.resumo-modal-icon.ebd { background: rgba(251,191,36,.2); border: 1px solid rgba(251,191,36,.4); }
.resumo-modal-icon.culto { background: rgba(192,132,252,.2); border: 1px solid rgba(192,132,252,.4); }
.resumo-modal-title {
  font-family: var(--font-chord); font-size: 22px; font-weight: 900;
  color: #fff; letter-spacing: -0.5px; margin-bottom: 4px;
}
.resumo-modal-subtitle {
  font-family: var(--font-chord); font-size: 12px; color: var(--muted);
  text-transform: uppercase; letter-spacing: 2px;
}
.resumo-modal-body { padding: 24px 28px; }
.resumo-stat {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 0; border-bottom: 1px solid rgba(63,63,70,.4);
}
.resumo-stat:last-of-type { border-bottom: none; }
.resumo-stat-label {
  font-family: var(--font-chord); font-size: 13px; color: var(--muted);
  display: flex; align-items: center; gap: 7px;
}
.resumo-stat-label svg { width: 14px; height: 14px; opacity: 0.7; }
.resumo-stat-value {
  font-family: var(--font-chord); font-size: 20px; font-weight: 900; color: #fff;
}
.resumo-stat-value.highlight.ebd { color: var(--ebd-color); }
.resumo-stat-value.highlight.culto { color: var(--culto-color); }
.resumo-modal-footer { padding: 0 28px 28px; }
.resumo-ok-btn {
  width: 100%; padding: 14px; border-radius: 12px; border: none; cursor: pointer;
  font-family: var(--font-chord); font-weight: 900; font-size: 15px; transition: all 0.2s;
}
.resumo-ok-btn.ebd { background: var(--ebd-color); color: #000; }
.resumo-ok-btn.ebd:hover { background: #fcd34d; transform: scale(1.02); }
.resumo-ok-btn.culto { background: var(--culto-color); color: #000; }
.resumo-ok-btn.culto:hover { background: #d8b4fe; transform: scale(1.02); }

/* ── FAB ─────────────────────────────────── */
.fab-wrap{position:fixed;bottom:20px;right:18px;z-index:100;display:flex;flex-direction:column;align-items:flex-end;gap:8px;pointer-events:none;}
.fab-menu{display:flex;flex-direction:column;gap:12px;transition:all .3s;transform-origin:bottom right;pointer-events:auto;}
.fab-menu.hidden{opacity:0;transform:scale(.9) translateY(10px);pointer-events:none;}
.ctrl-panel{background:rgba(24,24,27,.95);backdrop-filter:blur(20px);border:1px solid rgba(63,63,70,.5);border-radius:14px;padding:6px;box-shadow:0 16px 48px rgba(0,0,0,.5);display:flex;flex-direction:column;align-items:center;gap:3px;position:relative;}
.ctrl-btn{width:32px;height:32px;border-radius:9px;background:none;border:none;color:#d4d4d8;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .15s,color .15s;}
.ctrl-btn:hover{background:var(--bg3);color:#fff;}
.ctrl-btn svg{width:14px;height:14px;}
.ctrl-label{font-family:var(--font-chord);font-size:7px;font-weight:700;color:var(--green);text-transform:uppercase;letter-spacing:1px;}
.ctrl-val{font-family:var(--font-chord);font-size:13px;font-weight:900;color:#fff;line-height:1;}
.ctrl-div{width:24px;height:1px;background:rgba(63,63,70,.5);margin:1px 0;}
.ctrl-ctr{display:flex;flex-direction:column;align-items:center;padding:3px 0;}
.play-fab{width:40px;height:40px;border-radius:11px;background:var(--bg3);border:none;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;pointer-events:auto;}
.play-fab.active{background:var(--green);color:#000;box-shadow:0 0 18px rgba(52,211,153,.4);transform:scale(1.05);}
.play-fab svg{width:16px;height:16px;}

.color-popover {
  position: absolute; right: 100%; top: 50%; transform: translateY(-50%) translateX(10px) scale(0.9);
  background: rgba(24,24,27,.95); backdrop-filter: blur(20px); border: 1px solid rgba(63,63,70,.5);
  border-radius: 12px; padding: 6px; display: flex; gap: 6px; opacity: 0; pointer-events: none;
  transition: all .2s cubic-bezier(0.175, 0.885, 0.32, 1.275); margin-right: 12px; box-shadow: 0 8px 32px rgba(0,0,0,.5);
}
.color-popover.show { opacity: 1; transform: translateY(-50%) translateX(0) scale(1); pointer-events: auto; }
.color-dot{width:20px;height:20px;border-radius:50%;border:none;cursor:pointer;transition:transform .15s;}
.color-dot:hover{transform:scale(1.15);}
.color-dot.sel{outline:2px solid #fff;outline-offset:2px;transform:scale(1.1);}

.nav-songs-float{
  display:flex;flex-direction:row;gap:10px;
  position:fixed;bottom:20px;right:82px;z-index:150;
  transition: opacity 0.3s, visibility 0.3s;
}
.nav-float-btn{
  width:46px;height:46px;border-radius:50%;
  background:rgba(24,24,27,.95);backdrop-filter:blur(20px);
  border:1px solid rgba(63,63,70,.5);
  color:#d4d4d8;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 8px 24px rgba(0,0,0,.4);
  transition:all .2s; pointer-events:auto;
}
.nav-float-btn:hover{background:var(--bg3);color:#fff;}
.nav-float-btn:disabled{opacity:.2;cursor:not-allowed;pointer-events:none;}
.nav-float-btn svg{width:20px;height:20px;}

.fab-main{width:48px;height:48px;border-radius:50%;background:var(--green);border:none;color:#000;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 0 20px rgba(0,0,0,.4);transition:all .3s;pointer-events:auto;}
.fab-main:hover{background:#6ee7b7;transform:scale(1.05);}
.fab-main.open{background:var(--bg3);color:#fff;}
.fab-main svg{width:20px;height:20px;}
.fab-ctrl-row{display:flex;gap:6px;justify-content:flex-end;}
.fab-lock-btn{background:var(--bg2);border:1px solid var(--bg3);border-radius:10px;padding:7px 12px;cursor:pointer;display:flex;align-items:center;gap:6px;font-family:var(--font-chord);font-size:11px;font-weight:700;color:var(--muted);transition:all .2s;white-space:nowrap;}
.fab-lock-btn.bloqueado{border-color:rgba(248,113,113,.4);color:#f87171;background:rgba(248,113,113,.1);}
.fab-lock-btn.desbloqueado{border-color:rgba(52,211,153,.4);color:var(--green);background:rgba(52,211,153,.1);}
.fab-lock-btn svg{width:14px;height:14px;flex-shrink:0;}

.preview-add-fab {
  width:48px;height:48px;border-radius:50%;background:var(--blue);border:none;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 0 20px rgba(96,165,250,.4);transition:all .3s, opacity 0.3s;position:fixed;bottom:20px;right:82px;z-index:150;pointer-events:auto;
}

.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--green);color:#000;font-family:var(--font-chord);font-weight:700;font-size:13px;padding:10px 20px;border-radius:999px;opacity:0;transition:all .3s;pointer-events:none;z-index:200;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* ── AVISO VERIFICADO ───────────────────── */
.verified-notice {
  display: flex; align-items: center; gap: 7px;
  background: rgba(96,165,250,.08); border: 1px solid rgba(96,165,250,.18);
  border-radius: 10px; padding: 8px 12px; margin-bottom: 16px;
  font-family: var(--font-chord); font-size: 12px; color: var(--muted); line-height: 1.4;
}
.verified-notice svg { flex-shrink: 0; }

/* ── BOTÃO BAIXAR CIFRAS ────────────────── */
.download-setlist-btn {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(52,211,153,.1); border: 1px solid rgba(52,211,153,.25);
  color: var(--green); font-family: var(--font-chord); font-weight: 700;
  font-size: 12px; padding: 8px 14px; border-radius: 10px; cursor: pointer;
  transition: all .2s; white-space: nowrap; flex-shrink: 0; align-self: flex-start; margin-top: 4px;
}
.download-setlist-btn:hover { background: rgba(52,211,153,.2); transform: translateY(-1px); }
.download-setlist-btn:active { transform: scale(.97); }

/* ── MODAL PROGRESSO DOWNLOAD ───────────── */
.download-modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 9999;
  display: none; align-items: center; justify-content: center;
  backdrop-filter: blur(10px); padding: 20px;
}
.download-modal-overlay.show { display: flex; }
.download-modal {
  background: var(--bg2); border: 1px solid var(--bg3); border-radius: 22px;
  width: 90%; max-width: 340px; padding: 28px 24px; text-align: center;
  box-shadow: 0 30px 80px rgba(0,0,0,0.6); animation: fadeInUp 0.35s ease;
}
.download-modal-icon {
  width: 52px; height: 52px; border-radius: 50%; background: var(--gdim);
  border: 1px solid rgba(52,211,153,.3); display: flex; align-items: center;
  justify-content: center; margin: 0 auto 16px;
}
.download-modal-icon svg { width: 22px; height: 22px; color: var(--green); }
.download-modal h3 {
  font-family: var(--font-chord); font-size: 18px; font-weight: 900;
  color: #fff; letter-spacing: -.5px; margin-bottom: 6px;
}
.download-modal p {
  font-family: var(--font-chord); font-size: 13px; color: var(--muted);
  margin-bottom: 20px; line-height: 1.5;
}
.download-progress-bar-bg {
  width: 100%; height: 6px; background: var(--bg3); border-radius: 999px;
  overflow: hidden; margin-bottom: 10px;
}
.download-progress-bar-fill {
  height: 100%; background: var(--green); border-radius: 999px;
  transition: width 0.4s cubic-bezier(0.25,1,0.5,1); width: 0%;
}
.download-progress-label {
  font-family: var(--font-chord); font-size: 12px; color: var(--faint);
}
.download-modal-close {
  margin-top: 18px; width: 100%; padding: 12px; border-radius: 10px;
  border: 1px solid var(--bg3); background: transparent; color: var(--muted);
  font-family: var(--font-chord); font-weight: 700; font-size: 14px; cursor: pointer;
  transition: all .2s; display: none;
}
.download-modal-close.show { display: block; }
.download-modal-close:hover { color: #fff; border-color: var(--muted); }
</style>
</head>
<body>

<!-- Modal de Presença -->
<div id="name-modal" class="name-modal" style="display:none;">
  <div class="name-modal-box">
    <h3>Bem-vindo ao cifrei!</h3>
    <p>Como você se chama? A equipe de louvor vai ver que você está online com eles.</p>
    <input type="text" id="user-name-input" placeholder="Seu nome ou apelido..." autocomplete="off" />
    <button onclick="saveName()">Entrar na Equipe</button>
  </div>
</div>

<!-- Modal Resumo Louvor -->
<div id="resumo-modal-overlay" class="resumo-modal-overlay">
  <div class="resumo-modal" id="resumo-modal">
    <div class="resumo-modal-header" id="resumo-modal-header">
      <div class="resumo-modal-icon" id="resumo-modal-icon"></div>
      <div class="resumo-modal-title" id="resumo-modal-title">Louvor Finalizado!</div>
      <div class="resumo-modal-subtitle" id="resumo-modal-subtitle">Resumo do Turno</div>
    </div>
    <div class="resumo-modal-body" id="resumo-modal-body"></div>
    <div class="resumo-modal-footer">
      <button class="resumo-ok-btn" id="resumo-ok-btn" onclick="fecharResumoModal()">Amém! 🙌</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<!-- Onboarding cifrei -->
<div id="onboarding-cifrei" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:99999;align-items:center;justify-content:center;backdrop-filter:blur(8px);">
  <div style="background:var(--bg2);border:1px solid var(--bg3);border-radius:20px;padding:32px 24px;max-width:360px;width:90%;text-align:center;box-shadow:0 24px 60px rgba(0,0,0,.6);">
    <div id="onb-cifrei-content"></div>
    <div style="display:flex;justify-content:center;gap:6px;margin-top:18px;" id="onb-cifrei-dots"></div>
    <div style="display:flex;gap:10px;margin-top:20px;justify-content:center;">
      <button onclick="fecharOnboardingCifrei()" style="background:none;border:1px solid var(--bg3);color:var(--muted);border-radius:10px;padding:8px 16px;cursor:pointer;font-size:13px;">Pular</button>
      <button id="onb-cifrei-next" onclick="onbCifreiNext()" style="background:var(--green);color:#000;border:none;border-radius:10px;padding:8px 22px;cursor:pointer;font-size:13px;font-weight:800;">Próximo →</button>
    </div>
  </div>
</div>

<!-- ══ LOADING OVERLAY ══════════════════════ -->
<!-- removido - causava bloqueio na entrada -->

<!-- ══ SPLASH ══════════════════════════════ -->
<div id="splash">
  
  <div class="splash-title">cifrei<sup style="font-size: 0.4em; font-weight: 700; margin-left: 4px;">&reg;</sup></div>
  
  <!-- MENSAGEM DE BOAS VINDAS -->
  <div class="splash-welcome" id="splash-welcome" style="display:none;"></div>
  
  

  <div class="splash-buttons">
    <button class="start-btn" id="start-btn" onclick="iniciar()">
      <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      Repertório Semanal
    </button>
    <button class="banco-btn" onclick="abrirBanco()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
      </svg>
      Banco de Músicas
    </button>
    <button class="banco-btn" onclick="abrirEscala()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
