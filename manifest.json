      <div id="perfil-avatar-wrap" style="width:80px;height:80px;border-radius:50%;overflow:hidden;border:3px solid var(--green);box-shadow:0 0 0 3px rgba(52,211,153,.2);"></div>
      <div style="position:absolute;bottom:0;right:0;width:24px;height:24px;background:var(--green);border-radius:50%;display:flex;align-items:center;justify-content:center;border:2px solid var(--bg2);">
        <svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.5" width="12" height="12"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
