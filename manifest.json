<div id="modal-afinador" style="display:none;position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,.95);backdrop-filter:blur(20px);align-items:flex-end;justify-content:center;" onclick="if(event.target===this)fecharAfinador()">
